<style>
  .section-video-image .block-top ul {
    position: relative;
  }
  .section-video-image .block-top ul li {
    background: #000;
    left: 0;
    right: 0;
    position: relative;
  }

  .slick-arrow.slick-hidden {
    display: none !important;
  }

  .section-video-image {
    background: #fedd00;
    margin-bottom: 0;
    border-radius: 0;
  }

  .block-video-image:after,
  .quote-content:before {
    opacity: 75%;
    mix-blend-mode: multiply;
  }

  .shopify-section-image-video.spaced-section--boxed {
    padding: 0;
  }

  .section-video-image .text-primary {
    font-family: Anton !important;
    font-size: 60px !important;
    line-height: 60px !important;
    color: #000000 !important;
  }
</style>
<script>
  document.addEventListener('DOMContentLoaded', function () {
    if (!window.jQuery) {
      console.warn('jQuery not loaded');
      return;
    }

    $('#section-{{ section.id }}').slick({
      dots: false,
      infinite: true,
      arrows: true,
      speed: 300,
      slidesToShow: 3,
      slidesToScroll: 1,
      asNavFor: '.slider-nav',
      prevArrow: $('.prev'),
      nextArrow: $('.next'),
      responsive: [
        {
          breakpoint: 1199,
          settings: {
            slidesToShow: 2,
            slidesToScroll: 1,
          },
        },
        {
          breakpoint: 767,
          settings: {
            slidesToShow: 1,
            slidesToScroll: 1,
          },
        },
      ],
    });
    $('.slider-nav').slick({
      slidesToShow: 1,
      slidesToScroll: 1,
      arrows: false,
      fade: true,
      asNavFor: '#section-{{ section.id }}',
    });
  });
</script>

{% schema %}
{
  "name": "Custom section Video",
  "tag": "section",
  "class": "shopify-section-image-video spaced-section--boxed",
  "settings": [
    {
      "type": "text",
      "id": "custom_heading",
      "label": "HTML Heading"
    },
    {
      "type": "textarea",
      "id": "sub_title",
      "label": "Sub Title"
    },
    {
      "type": "textarea",
      "id": "quote",
      "label": "Quote Content"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Image & Text",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image desktop"
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Content"
        }
      ]
    },
    {
      "type": "video",
      "name": "Video",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image desktop"
        },
        {
          "type": "text",
          "id": "video_mp4",
          "label": "link video mp4"
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Content"
        },
        {
          "type": "text",
          "id": "btn",
          "label": "Button text",
          "default": "view all"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Url"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom section Video"
    }
  ]
}
{% endschema %}
