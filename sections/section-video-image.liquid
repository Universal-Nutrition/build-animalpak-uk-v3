<div class="section-video-image " id="1">
  <div class="block-heading">
    <div class="block-top">
      <h2 class="text-primary heading font-bold">
        {{ section.settings.custom_heading | replace: '.', '<span class="text-accessible">.</span>' }}
      </h2>
      <div class="sub_title">
        {{ section.settings.sub_title }}
      </div>
      <div class="quote-content slider-nav">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'video' -%}
              <div class="quote-items">
                {{ block.settings.quote }}
              </div>
            {%- when 'slide' -%}
              <div class="quote-items">{{ block.settings.quote }}</div>
          {% endcase %}
        {% endfor %}
      </div>
      <ul>
        <li class="prev ">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
            <path d="M19 12L5 12M5 12L11 6M5 12L11 18" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </li>
        <li class="next">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
            <path d="M5 12H19M19 12L13 18M19 12L13 6" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </li>
      </ul>
    </div>
    <div class="block-video-image" id="section-{{ section.id }}">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'video' -%}
            <div class=" block-items" id="2">
              <div class="block-image-wapper">
                <div class="video-content">
                  <script type="text/javascript">
                    jQuery('.buttonVideo-{{forloop.index}}').click(function () {
                      $('video').get(0).pause();
                      $('video').get(1).pause();
                      $('video').get(2).pause();
                      $('.btn-video-play').find('i').removeClass('fa-pause').addClass('fa-play');
                      $('.video-content').removeClass('video-running');

                      if (jQuery(this).find('i').hasClass('fa-play')) {
                        jQuery(this).find('i').removeClass('fa-play').addClass('fa-pause');
                        jQuery(this).parents('.video-content').addClass('video-running');
                        jQuery('#video-{{ block.id }}').get(0).play();
                      } else {
                        jQuery('#video-{{ block.id }}').get(0).pause();
                        jQuery(this).find('i').removeClass('fa-pause').addClass('fa-play');
                        jQuery(this).parents('.video-content').removeClass('video-running');
                      }
                    });
                  </script>
                  <div class="video-wapper">
                    <video id="video-{{ block.id }}" poster="{{ block.settings.image | img_url: 'master' }}" controls>
                      <source class="mp4" type="video/mp4" src="{{ block.settings.video_mp4 }}">
                    </video>
                    <div class="btn-video-play buttonVideo-{{forloop.index}}">
                      <i class="fa fa-play">
                        <span class="play-icon">
