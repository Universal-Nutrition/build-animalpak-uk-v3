{% # 2026-03-13 Phase 2 UK Announcement section — revamped layout. %}

<div class='w-full bg-black text-white font-bebasNeueExpanded'>
  <section class='py-4 md:py-5 w-full'>
    <div class='flex flex-col md:flex-row md:items-center gap-4 md:gap-0 px-8 md:px-0 lg:px-0'>

      {%- comment -%} Benefits — order 1 on mobile (2-col grid), middle on desktop {%- endcomment -%}
      {%- if section.blocks.size > 0 -%}
        <ul class='order-1 md:order-none md:ml-auto grid grid-cols-2 md:flex md:flex-row md:items-center gap-3 md:gap-8 lg:gap-12 md:px-10 lg:px-14'>
          {%- for block in section.blocks -%}
            {%- if block.type == 'content' -%}
              <li class='flex items-center gap-3' {{ block.shopify_attributes }}>
                {%- if block.settings.icon != blank -%}
                  <div class='shrink-0 text-yellow'>
                    {%- render 'icon-announcement', icon: block.settings.icon, class: 'w-[26px] h-[26px] md:w-[30px] md:h-[30px]' -%}
                  </div>
                {%- endif -%}
                <div class='text-white text-sm md:text-[15px] lg:text-[17px] leading-tight uppercase'>
                  {{ block.settings.content_text }}
                </div>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}

      {%- comment -%} Horizontal divider between rows — mobile only {%- endcomment -%}
      <div class='order-2 md:hidden w-full h-px bg-white/30'></div>

      {%- comment -%} Newsletter CTA — order 2 on mobile, right on desktop {%- endcomment -%}
      {%- if section.settings.newsletter_text != blank or section.settings.newsletter_button_text != blank -%}
        <div class='order-2 md:order-none flex flex-row items-center gap-4 md:gap-6 shrink-0 md:pr-8 lg:pr-15'>
          {%- if section.settings.newsletter_text != blank -%}
            <div class='font-bebasNeueExpanded text-white text-sm md:text-[13px] lg:text-[15px] uppercase leading-tight max-w-[160px] md:max-w-[160px] lg:max-w-[200px]'>
              {{ section.settings.newsletter_text }}
            </div>
          {%- endif -%}
          {%- if section.settings.newsletter_button_text != blank -%}
            <a
              href='{{ section.settings.newsletter_button_link | default: "#" }}'
              class='font-anton text-white border-2 border-yellow px-6 py-3 md:px-8 md:py-4 uppercase text-[18px] md:text-[20px] whitespace-nowrap hover:bg-yellow hover:text-black transition-colors shrink-0'
            >
              {{ section.settings.newsletter_button_text }}
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- comment -%} Divider — hidden on mobile {%- endcomment -%}
      <div class='hidden md:block self-stretch w-px bg-white/30 shrink-0'></div>

      {%- comment -%} Heading — order 3 on mobile (bottom), left on desktop {%- endcomment -%}
      {%- if section.settings.heading_text != blank -%}
        <div class='announcement-heading hidden md:block font-anton md:pl-8 lg:pl-15 md:pr-12 text-white text-[22px] md:text-[24px] lg:text-[30px] uppercase whitespace-nowrap shrink-0'>
          {{ section.settings.heading_text }}
        </div>
      {%- endif -%}

    </div>
  </section>
</div>

<style>
  @media (min-width: 768px) {
    .announcement-heading { order: -1; }
  }
</style>

{% schema %}
{
  "name": "Announcement Section (v3)",
  "settings": [
    {
      "type": "text",
      "id": "heading_text",
      "label": "Heading Text",
      "default": "Shop by Goal"
    },
    {
      "type": "header",
      "content": "Newsletter CTA"
    },
    {
      "type": "text",
      "id": "newsletter_text",
      "label": "Newsletter Text",
      "default": "GET UPDATES & DISCOUNTS SENT TO YOUR INBOX"
    },
    {
      "type": "text",
      "id": "newsletter_button_text",
      "label": "Button Text",
      "default": "JOIN THE PAK"
    },
    {
      "type": "url",
      "id": "newsletter_button_link",
      "label": "Button Link"
    }
  ],
  "blocks": [
    {
      "name": "Button (legacy)",
      "type": "button",
      "settings": [
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "richtext", "id": "subtitle", "label": "Subtitle" },
        { "type": "text", "id": "button_text", "label": "Button Text" },
        { "type": "url", "id": "button_link", "label": "Button Link" }
      ]
    },
    {
      "name": "Benefit",
      "type": "content",
      "limit": 4,
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "tag",
          "options": [
            { "value": "tag",         "label": "Tag (Discount)" },
            { "value": "truck",       "label": "Truck (Delivery)" },
            { "value": "star",        "label": "Star (Quality)" },
            { "value": "shield",      "label": "Shield (Guarantee)" },
            { "value": "package",     "label": "Package (Orders)" },
            { "value": "gift",        "label": "Gift (Rewards)" },
            { "value": "zap",         "label": "Zap (Fast / Energy)" },
            { "value": "heart",       "label": "Heart (Care)" },
            { "value": "award",       "label": "Award (Achievement)" },
            { "value": "check-circle","label": "Check Circle (Verified)" },
            { "value": "percent",     "label": "Percent (Discount %)" },
            { "value": "mail",        "label": "Mail (Newsletter)" },
            { "value": "globe",       "label": "Globe (Worldwide)" },
            { "value": "clock",       "label": "Clock (Fast Dispatch)" },
            { "value": "thumbs-up",   "label": "Thumbs Up (Satisfaction)" },
            { "value": "leaf",        "label": "Leaf (Natural)" },
            { "value": "flame",       "label": "Flame (Trending)" },
            { "value": "dumbbell",    "label": "Dumbbell (Fitness)" }
          ]
        },
        {
          "type": "richtext",
          "id": "content_text",
          "label": "Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement Section",
      "settings": {
        "heading_text": "Shop by Goal",
        "newsletter_text": "GET UPDATES & DISCOUNTS SENT TO YOUR INBOX",
        "newsletter_button_text": "JOIN THE PAK",
        "newsletter_button_link": "#"
      },
      "blocks": [
        {
          "type": "content",
          "settings": {
            "icon": "tag",
            "content_text": "<p><strong>GET 10% OFF</strong> YOUR FIRST ORDER</p>"
          }
        },
        {
          "type": "content",
          "settings": {
            "icon": "truck",
            "content_text": "<p><strong>FREE DELIVERY</strong> ON ALL ORDERS OVER <strong>£50</strong></p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
