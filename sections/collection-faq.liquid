<script src="{{ 'product-faq.js' | asset_url }}" defer="defer"></script>

{% liquid
  assign color = section.settings.bg_color
  assign sectionHeading = section.settings.heading
  assign faqOneTitle = collection.metafields.custom.faq_1_title
  assign faqOneBody = collection.metafields.custom.faq_1_body
  assign faqTwoTitle = collection.metafields.custom.faq_2_title
  assign faqTwoBody = collection.metafields.custom.faq_2_body
  assign faqThreeTitle = collection.metafields.custom.faq_3_title
  assign faqThreeBody = collection.metafields.custom.faq_3_body
%}
{% if faqOneTitle != blank %}
<div id="section-collection-faq" class="collection-faq w-full " style="background-color: {{color}}; border-bottom: 2px solid #1C1C1C;">
  <div class="container">
  
    {% if sectionHeading != blank %}
      <h2 class="text-6xl md:text-[85.6px] uppercase text-left sm:text-center text-primary mb-6 sm:mb-12 font-bold leading-[0.8em]">{{ sectionHeading }}</h2>
    {% endif %}
  <div class="accordion-wrapper" style="background: none;">
      <div class="accordion">
        {% for i in (1..12) %}
          {% assign title = 'faq_' | append: i | append: '_title' %}
          {% assign body = 'faq_' | append: i | append: '_body' %}
          {% if collection.metafields.custom[title] != blank %}
            <details {% unless forloop.last %}class="border-b border-[#000]"{% endunless %}>
                <summary class="bg-yellow">
                  <div class="" style="padding: .5em 1em;">
                      <p class="w-full flex justify-between items-center h4 accordion__title text-base py-6 cursor-pointer font-sans font-bold tracking-normal text-primary">
                        {{collection.metafields.custom[title]}}
                        {% render 'icon-accordion' %}
                      </p>
                  </div>
                </summary>
                <div class="accordion__content text-base rte pb-[15px] pr-10" >
                  {{collection.metafields.custom[body]}}
                </div>
            </details>
          {% endif %}
        {% endfor %}
        
      </div>
  </div>
    </div>
  </div>
{% endif %}


<style>
details[open]>summary .icon-caret {
  transform: rotate(180deg);
}
#section-collection-faq h2 {
  justify-content: center;
  background: none;
  color: #FFF;
  margin: 0 auto;
  line-height: 1;
  font-family: Anton;
  font-size: 60px;
  color: #FFFFFF;
  padding-bottom: 25px;
  padding-left: 30px;
  padding-right: 30px;
}
#section-collection-faq .container {
  padding-bottom: 85px;
  padding-top: 60px;
}

.collection-faq h2:after {
  display: none;
}

.accordion__title {
  font-size: 23px;
  font-weight: 600 !important;
  font-family: "Familjen Grotesk", sans-serif !important;
  text-transform: Uppercase;
}

.accordion__content {
  
}

@media only screen and (max-width: 768px) {
  #section-collection-faq .container {
    padding-bottom: 30px;
    padding-top: 0;
  }
}

details {
  background-color: #FFF;
}
.accordion__content.rte {
  padding: 1em;
}
@media only screen and (min-width: 768px) {
  #section-collection-faq h2  {
    font-size: 60px;
  }
}

@media screen and (max-width: 767px) {
  #section-collection-faq h2  {
    padding-top: 1em;
  }
}
</style>

{% if collection.metafields.custom.faq_1_title != blank %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {% for i in (1..12) %}
      {% assign title = 'faq_' | append: i | append: '_title' %}
      {% assign body = 'faq_' | append: i | append: '_body' %}
      {% if collection.metafields.custom[title] != blank  %}
        {% unless forloop.first %},{% endunless %}
        {
          "@type": "Question",
          "name": "{{collection.metafields.custom[title] | replace: '"', '\"'}}",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "{{collection.metafields.custom[body] | replace: '"', '\"'}}"
          }
      }
      {% endif %}
    {% endfor %}
  ]
}
</script>
{% endif %}

{% schema %}
{
  "name": "Collection - FAQ Section",
  "class": "shopify-section-vue",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "FAQs"
    },
    {
      "type": "color",
      "id": "bg_color",
      "default": "#FFFFFF",
      "label": "Background Colour of Section"
    }
  ],
  "presets": [
    {
      "name": "Collection FAQ Section",
      "category": "Section"
    }
  ],
  "templates": ["collection"]
}
{% endschema %}