{% comment %}
------------------------------------------------------------------------------
  Section: Product Recommendations
  - Uses 'PDPs'
  Info: Render product-card-simple for each product in recommendations
------------------------------------------------------------------------------
{% endcomment %}
{% liquid
  assign background_image = section.settings.background_image
%}
<product-recommendations class="product-recommendations relative flex w-full" data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit=4">
  {% if background_image != blank %}
    <div class="absolute top-0 left-0 right-0 bottom-0 w-full h-full">
    {% capture sources %}
            <source srcset="{{ background_image | image_url: width: 1366 }}" media="(min-width: 1366px)">
            <source srcset="{{ background_image | image_url: width: 768 }}" media="(min-width: 768px)">
            <source srcset="{{ background_image | image_url: width: 767 }}" media="(max-width: 767px)">
            <source srcset="{{ background_image | image_url: width: 1000 }}" media="(max-width: 500px)">
    {% endcapture %}
    {% render 'media',
        sources: sources,
        src: background_image,
        alt: background_image.alt,
        classes: 'w-full h-full object-cover',
        picture_classes: 'absolute w-full h-full'
    -%}
    </div>
  {% endif %}
  {% if recommendations.performed and recommendations.products_count > 0 %}
    <div class="relative z-[2] mx-auto px-4 py-[80px] max-w-[1500px]">
    <h2 class="text-2xl md:text-5xl uppercase font-anton mb-8">{{ section.settings.heading | escape }}</h2>
      <ul class="flex flex-wrap gap-6 justify-center" role="list">
        {% for recommendation in recommendations.products limit:3 %}
          {% unless recommendation.tags contains 'algolia-ignore' %}
          <li class="{% if section.settings.card_layout == 'vertical' %}w-[280px]{% else %}w-[360px]{% endif %}">
            {% render 'product-card-simple',
              product: recommendation,
              layout: section.settings.card_layout,
              show_rating: section.settings.show_rating,
              show_subtitle: section.settings.show_subtitle
            %}
          </li>
            {% endunless %}
        {% endfor %}
      </ul>
    </div>
  {% endif %}
</product-recommendations>

{% javascript %}
  class ProductRecommendations extends HTMLElement {
    constructor() {
      super();

      const handleIntersection = (entries, observer) => {
        if (!entries[0].isIntersecting) return;
        observer.unobserve(this);

        fetch(this.dataset.url)
          .then((response) => response.text())
          .then((text) => {
            const html = document.createElement('div');
            html.innerHTML = text;
            const recommendations = html.querySelector('product-recommendations');
            if (recommendations && recommendations.innerHTML.trim().length) {
              this.innerHTML = recommendations.innerHTML;
              if (window.Alpine) Alpine.initTree(this);
            }
          })
          .catch((e) => {
            console.error(e);
          });
      };

      new IntersectionObserver(handleIntersection.bind(this), { rootMargin: '0px 0px 200px 0px' }).observe(this);
    }
  }

  customElements.define('product-recommendations', ProductRecommendations);
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.product-recommendations.name",
  "tag": "section",
  "class": "spaced-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    },
    {
      "type": "paragraph",
      "content": "t:sections.product-recommendations.settings.paragraph__1.content"
    },
    {
      "type": "text",
      "id": "heading",
      "default": "You may also like",
      "label": "t:sections.product-recommendations.settings.heading.label"
    },
    {
      "type": "header",
      "content": "Card Options"
    },
    {
      "type": "select",
      "id": "card_layout",
      "label": "Card Layout",
      "default": "vertical",
      "options": [
        { "value": "horizontal", "label": "Horizontal (image beside)" },
        { "value": "vertical", "label": "Vertical (image on top)" }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "Show Rating",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_subtitle",
      "label": "Show Subtitle",
      "default": true
    }
  ]
}
{% endschema %}
