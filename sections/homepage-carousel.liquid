{% assign slideDelay = section.settings.slide_delay %}
{%- for block in section.blocks -%}
    {%- assign _block = block.settings -%}
    <style>
        .image-wrapper {
            position: relative;
            width: 100%;
            height: 100%;
            overflow: hidden;
        }

        .image-wrapper-{{block.id}} img {
            position: absolute !important;

            top: 0;
            bottom: 0;
            left: 0;
            right: 0;

            width: 100%;
            height: 100%;

            object-fit: cover;
            object-position: {{_block.image_position_desktop}} center;

            @media (max-width: 768px) {
              object-position: {{_block.image_position_mobile}} center;
            }
        }

        {% if block.settings.button__alignment_desktop == 'center' %}
          @media screen and (min-width: 768px) {
            .homepage-carousel__actions-{{block.id}} {
              margin: 0 auto;
            }
          }
        {% endif %}

        section:has(.homepage-carousel) {
            max-height: 600px;
            @media (max-width: 768px) {
              height: 100%;
            }
        }

        @media (max-width: 768px) {
            section:has(.homepage-carousel) {
                max-height: 70vh;
            }
        }

        .homepage-carousel .homepage-carousel__content--{{block.id}} .homepage-carousel__subtitle {
            color: {{_block.subheading_color}} !important;
            text-align: {{_block.subheading_self_align}};
        }

        .homepage-carousel .homepage-carousel__content--{{block.id}} .homepage-carousel__btn-primary {
            background-color: {{_block.primary_bg_color}};
            color: {{_block.primary_text_color}};
        }

        .homepage-carousel .homepage-carousel__content--{{block.id}} .homepage-carousel__btn-primary:hover {
            background-color: {{_block.primary_bg_color_hover}};
            color: {{_block.primary_text_color_hover}};
        }

        .homepage-carousel .homepage-carousel__content--{{block.id}} .homepage-carousel__btn-secondary {
            background-color: {{_block.secondary_bg_color}};
            color: {{_block.secondary_text_color}};
        }

        .homepage-carousel .homepage-carousel__content--{{block.id}} .homepage-carousel__btn-secondary:hover {
            background-color: {{_block.secondary_bg_color_hover}};
            color: {{_block.secondary_text_color_hover}};
        }

        .homepage-carousel__btn-primary,
        .homepage-carousel__btn-secondary {
            font-size: {{_block.button_font_size}}px;
        }

        .homepage-carousel__content--{{block.id}} {
            padding-left: {{_block.slider_padding_left}}vw;
            padding-right: {{_block.slider_padding_right}}vw;
            padding-top: {{_block.slider_padding_top}}vh;
            padding-bottom: {{_block.slider_padding_bottom}}vh;
        }

        @media screen and (max-width: 1109px) {
            .homepage-carousel__content--{{block.id}} {
                padding-left: {{_block.slider_padding_left_tablet}}vw;
                padding-right: {{_block.slider_padding_right_tablet}}vw;
                padding-top: {{_block.slider_padding_top_tablet}}vh;
                padding-bottom: {{_block.slider_padding_bottom_tablet}}vh;
            }
        }

        @media (max-width: 767px) {
            .homepage-carousel .homepage-carousel__content--{{block.id}} .homepage-carousel__subtitle {
                font-size: {{_block.subheading_font_size_mobile}}px;
                color: {{_block.subheading_color_mobile}} !important;
                text-align: {{_block.subheading_self_align_mobile}};
            }

            .homepage-carousel .homepage-carousel__content--{{block.id}} .hero-title {
                text-align: {{_block.heading_self_align_mobile}};
            }

            .homepage-carousel__content--{{block.id}} {
                padding-left: {{_block.slider_padding_left_mobile}}vw;
                padding-right: {{_block.slider_padding_right_mobile}}vw;
                padding-top: {{_block.slider_padding_top_mobile}}vh;
                padding-bottom: {{_block.slider_padding_bottom_mobile}}vh;
            }
        }

        @media (min-width: 768px) {
            .homepage-carousel .homepage-carousel__content--{{block.id}} .hero-title {
                text-align: {{_block.heading_self_align}};
            }

            .homepage-carousel__content--{{block.id}} .homepage-carousel__btn-primary,
            .homepage-carousel__content--{{block.id}} .homepage-carousel__btn-secondary {
                min-width: 172px;
            }

        }

        .homepage-carousel__content--{{block.id}} .homepage-carousel__content-inner h1 {
            line-height: 1;
        }

        /* desktop */
        @media (min-width: 1110px) {
            .homepage-carousel__content--{{block.id}} .homepage-carousel__content-inner h1 {
                font-size: {{_block.heading_font_size }}px;
                color: {{_block.heading_color }};
                max-width: {{ _block.heading_maxwidth }}%;
            }

            .homepage-carousel__content--{{block.id}} .homepage-carousel__content-inner h1 strong,
            .homepage-carousel__content--{{block.id}} .homepage-carousel__content-inner h1 b {
                color: {{_block.heading_strong_color }};
            }

            .homepage-carousel__content--{{block.id}} .homepage-carousel__subtitle {
                font-size: {{_block.subheading_font_size}}px;
                max-width: {{ _block.subheading_maxwidth }}%;
            }
        }


        /* tablet */
        @media (min-width: 481px) and (max-width: 1109px) {
            .homepage-carousel__content--{{block.id}} .homepage-carousel__content-inner h1 {
                font-size: {{_block.heading_font_size_tablet }}px;
                color: {{_block.heading_color }};
            }

            .homepage-carousel__content--{{block.id}} .homepage-carousel__subtitle {
                font-size: {{_block.subheading_font_size_tablet}}px;
                line-height: 1.2;
            }

            .homepage-carousel__content--{{block.id}} {
                /* padding: 4vw; */
            }

            .homepage-carousel__content--{{block.id}} .homepage-carousel__content-inner h1 {
                max-width: {{ _block.heading_tablet_maxwidth }}%;
            }

            .homepage-carousel__content--{{block.id}} .homepage-carousel__content-inner .homepage-carousel__entry p {
                max-width: {{ _block.subheading_maxwidth_tablet }}%;
            }
        }

        /* tablet landscape */
        @media (min-width: 768px) and (max-width: 1109px) and (orientation: landscape) {
            .homepage-carousel__content--{{block.id}} .homepage-carousel__content-inner h1:after {
                content: '';
            }
        }

        /* mobile */
        @media (max-width: 480px) {
            .homepage-carousel__content--{{block.id}} .homepage-carousel__content-inner {
                flex: 1;
            }

            /* .homepage-carousel__content--{{block.id}} {
                padding: 4vw;
            } */
        }

        @media (max-width: 480px) {
            .homepage-carousel__content--{{block.id}} .homepage-carousel__content-inner h1 {
                font-size: {{_block.heading_font_size_mobile }}px;
                color: {{_block.heading_color_mobile }};
                line-height: 1;
            }

            .homepage-carousel__content--{{block.id}} .homepage-carousel__content-inner h1 strong,
            .homepage-carousel__content--{{block.id}} .homepage-carousel__content-inner h1 b {
                color: {{_block.heading_strong_color_mobile }};
            }

            .homepage-carousel__btn-primary {
                margin-bottom: 1em;
            }
        }

        @media (max-width: 767px) {
            .homepage-carousel__content-inner {
                margin-bottom: 18px;
            }

            .homepage-carousel__content-inner a {
                width: 100%;
            }
        }

        {% if _block.foreground_image_max_width > 0 %}
        @media (min-width: 768px) {
            .foreground-image-wrapper--{{ block.id }} {
                max-width: {{ _block.foreground_image_max_width }}px;
            }
        }
        {% endif %}

        {% if _block.foreground_image_max_width_mobile > 0 %}
        @media (max-width: 767px) {
            .foreground-image-wrapper--{{ block.id }} {
                max-width: {{ _block.foreground_image_max_width_mobile }}px;
            }
        }
        {% endif %}
    </style>
{%- endfor -%}

{%- assign visible_slide_count = 0 -%}

{%- assign homepage_carousel_slides_count = 0 -%}
{%- assign homepage_carousel_slides = "" -%}
{%- assign homepage_carousel_pagination = "" -%}

{%- assign homepage_carousel_slide_index = 0 -%}
{%- for block in section.blocks -%}
    {%- assign index = forloop.index0 -%}

    {%- assign _block = block.settings -%}
    {%- assign hide_section = false -%}

    {%- assign key = block.id | split: '__' | last -%}

    {%- assign current_timestamp = 'now' | date: '%s' | plus: 0 -%}
    {%- assign start_timestamp = _block.start_date | date: '%s' | times: 1 -%}
    {%- assign end_timestamp = _block.end_date | date: '%s' | times: 1 -%}

    {%- if start_timestamp > current_timestamp -%}
        {%- assign hide_section = true -%}
    {%- endif -%}

    {%- if current_timestamp > end_timestamp -%}
        {%- assign hide_section = true -%}
    {%- endif -%}

    {%- if start_timestamp == 0 and end_timestamp == 0 -%}
        {%- assign hide_section = false -%}
        {%- assign visible_slide_count = visible_slide_count | plus: 1 -%}
    {%- endif -%}

    {%- if hide_section -%}
        {%- continue -%}
    {%- endif -%}

    {%- assign loading = "lazy" -%}
    {%- if homepage_carousel_slide_index == 0 -%}
        {%- assign loading = "eager" -%}
    {%- endif -%}

    {%- capture homepage_carousel_slide -%}
        <div class="{% if section.blocks.size > 1 %}swiper-slide{% endif %} {% if homepage_carousel_slide_index == 0 %}swiper-slide-active{% endif %} relative w-full max-w-full min-h-[70vh] md:min-h-[600px] md:max-h-[55vh]">
            <div class="max-h-full h-full">
                {%- if _block.video != blank -%}
                    <video
                        id="vidplayer"
                        src='{{ _block.video }}'
                        muted
                        playsinline
                        loop
                        class='w-full hidden lg:block desktop'
                    ></video>

                    <video
                        id="vidplayer"
                        src='{{ _block.video_mob }}'
                        muted
                        playsinline
                        loop
                        class='w-full lg:hidden mobile'
                    ></video>
                {%- else -%}
                    {%- capture sources -%}
                        <source srcset="{{- _block.image | image_url: width: 2800 -}}" media="(min-width: 1920px)" />
                        <source srcset="{{- _block.image | image_url: width: 2400 -}}" media="(min-width: 1440px)" />
                        <source srcset="{{- _block.image | image_url: width: 1800 -}}" media="(min-width: 1280px)" />
                        <source srcset="{{- _block.image | image_url: width: 1600 -}}" media="(min-width: 1024px)" />
                        <source srcset="{{- _block.image | image_url: width: 1400 -}}" media="(min-width: 768px)" />
                        <source srcset="{{- _block.image_2 | image_url: width: 900 -}}" media="(max-width: 767px)" />
                    {%- endcapture -%}

                    {%- assign src = _block.image_2 | image_url: width: 900 -%}

                    {%- if homepage_carousel_slide_index == 0 -%}
                        {%- assign lazy_load = 'eager' -%}
                        {%- assign fetchpriority = 'high' -%}
                        {%- assign importance = 'high' -%}
                        {%- assign preload = true -%}
                    {%- else -%}
                        {%- assign lazy_load = 'lazy' -%}
                        {%- assign fetchpriority = 'low' -%}
                        {%- assign importance = 'low' -%}
                        {%- assign preload = false -%}
                    {%- endif -%}

                    {%- capture link_preloads -%}
                        <link href="{{- _block.image | image_url: width: 2800 -}}" as="image" media="(min-width: 1920px)" fetchpriority="{{- fetchpriority -}}" />
                        <link href="{{- _block.image | image_url: width: 2400 -}}" as="image" media="(min-width: 1440px)" fetchpriority="{{- fetchpriority -}}" />
                        <link href="{{- _block.image | image_url: width: 1800 -}}" as="image" media="(min-width: 1280px)" fetchpriority="{{- fetchpriority -}}" />
                        <link href="{{- _block.image | image_url: width: 1600 -}}" as="image" media="(min-width: 1024px)" fetchpriority="{{- fetchpriority -}}" />
                        <link href="{{- _block.image | image_url: width: 1400 -}}" as="image" media="(min-width: 768px)" fetchpriority="{{- fetchpriority -}}" />
                        <link href="{{- _block.image_2 | image_url: width: 900 -}}" as="image" media="(max-width: 767px)" fetchpriority="{{- fetchpriority -}}" />
                    {%- endcapture -%}

                    <div class="image-wrapper image-wrapper-{{block.id}} h-auto min-h-[70vh] md:min-h-[600px] md:max-h-[55vh]">
                        {%- render 'media',
                            sources: sources,
                            link_preloads: link_preloads,
                            src: src,
                            alt: _block.image_2.alt,
                            classes: 'w-full h-auto',
                            loading: loading,
                            lazy_load: lazy_load,
                            fetchpriority: fetchpriority,
                            importance: importance,
                            img_sizes: img_sizes,
                            preload: preload,
                            width: _block.image.width,
                            height: _block.image.height,
                            no_default_position: true
                        -%}
                    </div>
                {%- endif -%}

                <div class="gradient-overlay"></div>

                <div class="homepage-carousel__content homepage-carousel__content--{{ block.id }} {{ _block.x_align }} {{ _block.y_align }} {{ _block.x_align_mobile }} {{ _block.y_align_mobile }}

                {% if _block.foreground_image != blank %}
                  w-full
                {% endif %}
                absolute top-0 left-0 md:w-full h-full flex">
                    <div class="homepage-carousel__content-inner
                    {% if _block.foreground_image != blank %}
                      w-full md:w-auto h-full md:h-auto flex flex-col items-center md:items-start md:justify-center
                      {%- if _block.y_align_mobile == 'is-top-mobile' -%} justify-start
                      {%- elsif _block.y_align_mobile == 'is-middle-mobile' -%} justify-center
                      {%- else -%} justify-end
                      {%- endif -%}
                    {% endif %}">
                       {% if _block.foreground_image != blank %}
                        {% capture sources_foreground %}
                          <source srcset="{{- _block.foreground_image | image_url: width: 1920 -}}" media="(min-width: 1920px)" />
                          <source srcset="{{- _block.foreground_image | image_url: width: 1440 -}}" media="(min-width: 1440px)" />
                          <source srcset="{{- _block.foreground_image | image_url: width: 1280 -}}" media="(min-width: 1280px)" />
                          <source srcset="{{- _block.foreground_image | image_url: width: 1024 -}}" media="(min-width: 1024px)" />
                          <source srcset="{{- _block.foreground_image | image_url: width: 1023 -}}" media="(min-width: 768px)" />
                          <source srcset="{{- _block.foreground_image_mobile | image_url: width: 480 -}}" media="(max-width: 767px)" />
                        {% endcapture %}
                        <div class="relative foreground-image-wrapper--{{ block.id }}">
                          {% render 'media',
                            sources: sources_foreground,
                            link_preloads: link_preloads,
                            src: src,
                            alt: _block.foreground_image.alt,
                            classes: 'max-w-full w-auto max-h-[300px] md:max-h-[400px]',
                            loading: loading,
                            lazy_load: lazy_load,
                            fetchpriority: fetchpriority,
                            importance: importance,
                            img_sizes: img_sizes,
                            preload: preload,
                            width: _block.foreground_image.width,
                            height: _block.foreground_image.height
                          -%}
                        </div>
                        {% endif %}
                        {% if _block.custom_heading != blank %}
                            <div class='hero-title text-white font-albertRegular font-medium mb-4 lg:max-w-[unset] {{ _block.heading_self_align }} {{ _block.heading_self_align_mobile }}'>
                                <h1 class="xanimate uppercase mx-auto md:mx-0">
                                    {{ _block.custom_heading | newline_to_br | remove: "<p>" | remove: "</p>" }}
                                </h1>
                            </div>
                        {% endif %}

                        <div class="homepage-carousel__entry">
                            <p class="homepage-carousel__subtitle xanimate lg:text-xl md:text-lg font-bebasNeue mb-4 -sm:mb-8 mx-auto md:mx-0">
                                {{ _block.subheading | newline_to_br }}
                            </p>
                        </div>

                        {% if _block.button_label != blank or _block.secondary_button_label != blank %}
                            <div class="homepage-carousel__actions homepage-carousel__actions-{{block.id}} flex flex-wrap
                            {% if _block.button__alignment_desktop == 'left' and _block.foreground_image != blank %}
                              ml-[18px]
                            {% endif %}
                            ">
                                {%- if _block.button_label != blank -%}
                                    <a
                                            href='{{- _block.button_link -}}'
                                            class='homepage-carousel__btn-primary button-light flex justify-center items-center'
                                    >
                                        {{- _block.button_label -}}
                                    </a>
                                {%- endif -%}

                                {%- if _block.secondary_button_label != blank -%}
                                    <a
                                            href="{{- _block.secondary_button_link -}}"
                                            class="homepage-carousel__btn-secondary md:ml-6 mt-3 md:mt-0 button--secondary block button-light"
                                    >
                                        {{- _block.secondary_button_label -}}
                                    </a>
                                {%- endif -%}
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    {%- endcapture -%}
    {%- assign homepage_carousel_slides = homepage_carousel_slides | append: homepage_carousel_slide -%}

    {%- capture homepage_carousel_pagination_dot -%}
        <span class="swiper-pagination-bullet {% if homepage_carousel_slides_count == 0 %}swiper-pagination-bullet-active{% endif %}"></span>
    {%- endcapture -%}
    {%- assign homepage_carousel_pagination = homepage_carousel_pagination | append: homepage_carousel_pagination_dot -%}

    {%- assign homepage_carousel_slide_index = homepage_carousel_slide_index | plus: 1 -%}
    {%- assign homepage_carousel_slides_count = homepage_carousel_slides_count | plus: 1 -%}
{%- endfor -%}

{%- if homepage_carousel_slides -%}
    {{ 'bundle.section-homepage-carousel.css' | asset_url | stylesheet_tag }}

    <homepage-carousel
        class="swiper swiper-fade h-full {% unless _block.video != blank %} /*lg:grid-cols-2*/ {% endunless %} relative overflow-hidden homepage-carousel min-h-[70vh] md:min-h-[600px]"
        data-slide-delay="{{- section.settings.slide_delay -}}"
    >
        <div class="swiper-wrapper min-h-[70vh] md:min-h-[600px]">
            {{- homepage_carousel_slides -}}
        </div>

        {% if visible_slide_count > 1 %}
        <div class="swiper-button-next text-white">
            {% render 'icon-triangle-right', classes: '!w-6 !h-6 text-white' %}
        </div>

        <div class="swiper-button-prev text-white">
            {% render 'icon-triangle-left', classes: '!w-6 !h-6 text-white' %}
        </div>
        {% endif %}
        {%- if homepage_carousel_pagination -%}
            <div class="hero-pagination z-10 text-right mb-4 swiper-pagination-clickable swiper-pagination-bullets swiper-pagination-horizontal">
                {{- homepage_carousel_pagination -}}
            </div>
        {%- endif -%}
    </homepage-carousel>

    <script>
        if (window.innerWidth < 1024) {
            let vmobile = document.querySelector('video.mobile');
            if (vmobile) {
                vmobile.setAttribute('autoplay', 'true');
            }
        } else {
            let vdesktop = document.querySelector('video.desktop');
            if (vdesktop) {
                vdesktop.setAttribute('autoplay', 'true');
            }
        }
    </script>
{%- endif -%}

{% schema %}
{
  "name": "Homepage Carousel",
  "tag": "section",
  "class": "spaced-section spaced-section--full-width",
  "settings": [
    {
      "type": "text",
      "id": "slide_delay",
      "label": "Delay (milliseconds)"
    }
  ],
  "blocks": [
    {
      "name": "Slide",
      "type": "slide",
      "settings": [
        {
          "type": "text",
          "id": "start_date",
          "label": "Start Date",
          "info": "Start Date in format YYYY-MM-DD HH:MM:SS. Example: 2025-03-24 12:00:00"
        },
        {
          "type": "text",
          "id": "end_date",
          "label": "End Date",
          "info": "End Date in format YYYY-MM-DD HH:MM:SS. Example: 2025-03-24 12:00:00"
        },
        {
          "type": "text",
          "id": "video",
          "label": "Video link"
        },
        {
          "type": "text",
          "id": "video_mob",
          "label": "Mobile video link"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Desktop"
        },
        {
          "type": "image_picker",
          "id": "image_2",
          "label": "Mobile"
        },
        {
          "type": "image_picker",
          "id": "foreground_image",
          "label": "Foreground Image"
        },
        {
          "type": "image_picker",
          "id": "foreground_image_mobile",
          "label": "Foreground Image Mobile"
        },
        {
          "type": "range",
          "id": "foreground_image_max_width",
          "label": "Foreground Image Max Width - Desktop",
          "min": 50,
          "max": 800,
          "step": 10,
          "unit": "px",
          "default": 400,
          "info": "Only applies when a foreground image is set"
        },
        {
          "type": "range",
          "id": "foreground_image_max_width_mobile",
          "label": "Foreground Image Max Width - Mobile",
          "min": 50,
          "max": 600,
          "step": 10,
          "unit": "px",
          "default": 300,
          "info": "Only applies when a foreground image is set"
        },
        {
          "type": "checkbox",
          "id": "enable_lazy_loading",
          "label": "Enable Lazy Loading (disable for in viewport content)",
          "default": true
        },
        {
          "type": "select",
          "id": "image_position_desktop",
          "label": "Image Position Desktop",
          "options": [
            {
              "value": "top",
              "label": "Top"
            },
            {
              "value": "bottom",
              "label": "Bottom"
            },
            {
              "value": "center",
              "label": "Center"
            }
          ],
          "default": "center"
        },
        {
          "type": "select",
          "id": "image_position_mobile",
          "label": "Image Position Mobile",
          "options": [
            {
              "value": "top",
              "label": "Top"
            },
            {
              "value": "bottom",
              "label": "Bottom"
            },
            {
              "value": "center",
                  "label": "Center"
                }
              ],
              "default": "top"
        },
        {
          "type": "textarea",
          "id": "custom_heading",
          "label": "HTML Heading"
        },
        {
          "type": "textarea",
          "id": "subheading",
          "default": "Subtitle goes here!",
          "label": "Sub Heading"
        },
        {
          "type": "header",
          "content": "Primary Button"
        },
        {
          "type": "text",
          "id": "button_label",
          "default": "Shop now",
          "label": "Button Label"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        },
        {
          "type": "range",
          "id": "button_font_size",
          "min": 14,
          "max": 30,
          "step": 1,
          "unit": "px",
          "label": "Button Font Size",
          "default": 21
        },
        {
          "type": "color",
          "id": "primary_text_color",
          "label": "Text Color",
          "default": "#212121"
        },
        {
          "type": "color",
          "id": "primary_bg_color",
          "label": "Background Color",
          "default": "#F5D500"
        },
        {
          "type": "color",
          "id": "primary_text_color_hover",
          "label": "Hover : Text Color",
          "default": "#212121"
        },
        {
          "type": "color",
          "id": "primary_bg_color_hover",
          "label": "Hover : Background Color",
          "default": "#ffffff"
        },
        {
          "type": "header",
          "content": "Secondary Button"
