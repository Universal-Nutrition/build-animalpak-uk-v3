                text-wrapper absolute flex flex-col
                {% if block.settings.text_alignment == 'left' %}
                    items-left text-left
                {% elsif block.settings.text_alignment == 'right' %}
                    items-right text-right right-0 md:right-16 ml-auto
                {% else %}
                    mx-auto items-center text-center center-x w-[90%]
                {% endif %}
              "
            >
              {% if block.settings.custom_heading != blank %}
                <h1 class="animate uppercase">
                  {{ block.settings.custom_heading | newline_to_br }}
                </h1>
              {% endif %}
              <p class="sh-desktop animate lg:text-xl md:text-lg font-light font-sans text-white mb-4 sm:mb-8 lg:max-w-[550px]">
