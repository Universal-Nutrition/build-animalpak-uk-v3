                    <a
                      href="{{ block.settings.button_link }}"
                      class="button block lg:px-8 lg:py-[18px] font-bold"
                    >
                      {{ block.settings.button_label | upcase }}
                    </a>
                  {% endif %}
                  {% if block.settings.secondary_button_label != blank %}
                    <a
                      href="{{ block.settings.secondary_button_link }}"
                      class="ml-6 button block lg:px-8 lg:py-[18px] font-bold tracking-[1px]"
