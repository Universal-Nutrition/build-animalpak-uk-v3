  </div>
  <div class="hero-pagination z-10 text-right"></div>
</hero-slider>

<script>
  var slide_delay = `{{ section.settings.slide_delay }}`;
</script>

<script>
  requestIdleCallback(() => {
    var typed = new Typed('#typing', {
      strings: ['Act', 'Train', 'Eat', 'Think', 'Be ^3000'],
      showCursor: false,
      loop: true,
      fadeOut: true,
      fadeOutClass: 'typed-fade-out',
      fadeOutDelay: 500,
      typeSpeed: 100,
      shuffle: false,
    });
  });
</script>

{% schema %}
{
  "name": "Hero Banner (classic)",
  "tag": "section",
  "class": "spaced-section spaced-section--full-width",
  "settings": [
    {
      "type": "text",
      "id": "slide_delay",
      "label": "Delay (milliseconds)"
    }
  ],
  "blocks": [
    {
      "name": "Slide",
      "type": "slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Desktop"
        },
        {
          "type": "image_picker",
          "id": "image_2",
          "label": "Mobile"
        },
        {
          "type": "checkbox",
          "id": "enable_lazy_loading",
          "label": "Enable Lazy Loading (disable for in viewport content)",
          "default": true
        },
        {
          "type": "textarea",
          "id": "custom_heading",
          "label": "HTML Heading"
        },
        {
          "type": "textarea",
          "id": "subheading",
          "default": "Subtitle goes here!",
          "label": "Sub Heading Desktop"
        },
        {
          "type": "textarea",
          "id": "subheadingmob",
          "label": "Sub Heading Mobile"
        },
        {
          "type": "range",
          "id": "subheading_size",
          "label": "Subheading Font Size (mobile)",
          "min": 12,
          "max": 28,
          "step": 2,
          "default": 20,
          "unit": "px"
        },
        {
          "type": "text",
          "id": "button_label",
          "default": "Shop now",
          "label": "Button Label"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        },
        {
          "type": "text",
          "id": "secondary_button_label",
          "default": "Learn more",
          "label": "Secondary Button label"
        },
        {
          "type": "url",
          "id": "secondary_button_link",
          "label": "Secondary Button Link"
        },
        {
          "type": "select",
          "id": "text_alignment",
          "label": "Text alignment",
          "options": [
            {
              "value": "left",
              "label": "Left"
            },
            {
              "value": "right",
              "label": "Right"
            },
            {
              "value": "center",
              "label": "Center"
            }
          ],
          "default": "left"
        },
        {
          "type": "textarea",
          "id": "CustomTextBottom",
          "default": "Custom text",
          "label": "Custom text"
        },
        {
          "type": "image_picker",
          "id": "logo-image-1",
          "label": "Logo Image 1"
        },
        {
          "type": "image_picker",
          "id": "logo-image-2",
          "label": "Logo Image 2"
        },
        {
          "type": "image_picker",
          "id": "logo-image-3",
          "label": "Logo Image 3"
        },
        {
          "type": "image_picker",
          "id": "logo-image-4",
          "label": "Logo Image 4"
        },
        {
          "type": "image_picker",
          "id": "logo-image-5",
          "label": "Logo Image 5"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Banner",
      "blocks": [
        {
          "type": "slide"
        }
      ]
    }
  ]
}
{% endschema %}
