              </p>
              {% if block.settings.subheadingmob != blank %}
                <p
                  style="font-size:{{ block.settings.subheading_size }}px"
                  class="sh-mobile animate lg:text-xl md:text-lg font-light font-sans text-white mb-4 sm:mb-8 lg:max-w-[550px]"
                >
                  {{ block.settings.subheadingmob }}
                </p>
              {% endif %}
              {% if block.settings.button_label != blank or block.settings.secondary_button_label != blank %}
