                      block.settings['logo-image-1']
                      | img_url: 'master'
                      | img_tag: loading: 'lazy', sizes: sizes, widths: '165, 360, 535, 750, 1070, 1500'
                    }}
                  {%- endif -%}
                  {%- if block.settings['logo-image-2'] != blank -%}
                    {{
                      block.settings['logo-image-2']
                      | img_url: 'master'
                      | img_tag: loading: 'lazy', sizes: sizes, widths: '165, 360, 535, 750, 1070, 1500'
                    }}
                  {%- endif -%}
                  {%- if block.settings['logo-image-3'] != blank -%}
                    {{
                      block.settings['logo-image-3']
                      | img_url: 'master'
                      | img_tag: loading: 'lazy', sizes: sizes, widths: '165, 360, 535, 750, 1070, 1500'
                    }}
                  {%- endif -%}
                  {%- if block.settings['logo-image-4'] != blank -%}
                    {{
                      block.settings['logo-image-4']
                      | img_url: 'master'
                      | img_tag: loading: 'lazy', sizes: sizes, widths: '165, 360, 535, 750, 1070, 1500'
                    }}
                  {%- endif -%}
