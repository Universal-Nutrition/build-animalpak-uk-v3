{% capture filters %}
{% for filter in collection.filters %}
  {% if filter.type == 'list' %}
    {% assign label_lower = filter.label | downcase %}
    {% if label_lower contains 'type' or label_lower contains 'flavour' or label_lower contains 'flavor' or label_lower contains 'size' %}
      <div class="mb-6 pb-3 border-0 border border-b border-[#DBDBDB] border-solid w-full filter-group" data-has-active="{{ filter.active_values.size | default: 0 }}">
        <div class="filter-group-header text-[#212121] mb-4 uppercase font-sans text-[13.9px] font-bold flex justify-between items-center cursor-pointer select-none">
          <span>{{ filter.label }}</span>
          <span class="filter-toggle-icon text-[18px] leading-none">+</span>
        </div>
        <div class="mb-3 filter-options">
          {% for value in filter.values %}
            <label class="filter-option{% if value.active %} filter-option-active{% endif %} flex items-center gap-2 mb-2 cursor-pointer font-sans text-[13.91px] text-[#212121]">
              <input
                type="checkbox"
                class="filter-checkbox"
                {% if value.active %}checked{% endif %}
                onchange="window.location.href='{% if value.active %}{{ value.url_to_remove }}{% else %}{{ value.url_to_add }}{% endif %}'"
              >
              {{ value.label }}
            </label>
          {% endfor %}
        </div>
      </div>
    {% endif %}
  {% endif %}
{% endfor %}

{% for filter in collection.filters %}
  {% if filter.type == 'price_range' %}
    <div class="mb-6 pb-3 border-0 border border-b border-[#DBDBDB] border-solid w-full">
      <div class="filter-price-heading text-[#212121] mb-4 uppercase font-anton font-light text-[13.9px]">Price :</div>
      <div class="mb-3">
        <input
          data-minvalue="{{ filter.min_value.value | default: 0 | divided_by: 100.0 | ceil }}"
          data-maxvalue="{{ filter.max_value.value | default: filter.range_max | divided_by: 100.0 | ceil }}"
          type="text"
          class="js-range-slider"
          name="my_range"
          value=""
          data-skin="round"
          data-type="double"
          data-min="0"
          data-max="{{ filter.range_max | divided_by: 100.0 | ceil }}"
          data-grid="false"
          data-prefix="{{ cart.currency.symbol }}"
        >
      </div>
    </div>
  {% endif %}
{% endfor %}
{% endcapture %}
<div class="px-6 lg:px-[58px] pt-[35px] coll_nudge">
  <div class="flex justify-between items-center pb-[32px]">
    <div
      class="mobile-filter-trigger font-bold uppercase p-3 bg-black inline-flex items-center text-white text-[12.1px] cursor-pointer"
      onclick="collFilterOpen();"
    >
      <span class="mr-[10px]">{% include 'icon-filtering' %}</span>
      filter by
    </div>
    <div class="flex items-center gap-3">
      {% if settings.ss_enable %}
        <div id="searchspring-toolbar"></div>
      {% endif %}
      {%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}
      <select
        name="sort_by"
        class="facet-filters__sort font-bold select__select uppercase caption-large cursor-pointer block pl-3 pr-10 py-2 text-[12.1px] border-gray-300 border-solid focus:outline-none sm:text-sm"
        id="SortBy"
        aria-describedby="a11y-refresh-page-message"
      >
        {%- for option in collection.sort_options -%}
          <option
            class="text-gray-500 block px-4 py-2 text-sm cursor-pointer"
            value="{{ option.value | capitalize  }}"
            {% if option.value == sort_by %}
              selected="selected"
            {% endif %}
          >
            {{ option.name | capitalize }}
          </option>
        {%- endfor -%}
      </select>
    </div>
  </div>
  {% assign is_apparel = false %}
  {% for link in linklists['apparel-accessories'].links %}
    {% if collection.url == link.url %}
      {% assign is_apparel = true %}
      {% break %}
    {% endif %}
  {% endfor %}
  <div class="filters-overlay" id="filters-overlay" onclick="collFilterClose()"></div>
  <script>
  function collFilterOpen() {
    document.querySelector('.filters-wrap').classList.add('active', 'someClass');
    document.getElementById('filters-overlay').classList.add('active');
  }
  function collFilterClose() {
    document.querySelector('.filters-wrap').classList.remove('active', 'someClass');
    document.getElementById('filters-overlay').classList.remove('active');
  }
  </script>

  <div class="filters-wrap bg-white z-[9999] fixed top-0 left-0 w-full lg:w-[340px] h-screen overflow-scroll px-6">
    <a href="#" class="menu-close block pt-6 pb-4 text-right" onclick="collFilterClose(); return false;">
      {% include 'icon-close' %}
    </a>
    <div class="text-[42.56px] uppercase font-anton text-[#212121] mt-4 leading-[34.05px] mb-8">
      Filters
    </div>
    <div class="mb-28">
      {{ filters }}
    </div>
    <div class="filter-footer flex items-center fixed w-full lg:w-[340px] left-0 bottom-0 p-4 bg-white border-t border-[#DBDBDB]">
      <button onclick="window.location.href='{{ collection.url }}';" class="text-white h-[54px] flex items-center justify-center w-full text-[13.9px] font-bold uppercase bg-black">clear</button>
    </div>
  </div>

  <div class="flex flex-col">

    <div class="mb-[64px] lg:mb-[96px]">
      {% comment %} product grid {% endcomment %}
      <div class="collection-wrapper grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
        {% for product in collection.products %}
          {% include 'product-grid-item' %}
        {% endfor %}
        {% comment %}{% include 'promo-item' %}{% endcomment %}
      </div>
      {% comment %} pagination {% endcomment %}
