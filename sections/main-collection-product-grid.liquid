  <script>
$(document).ready(function() {
  // Toggle filter for menu-toggle
  $('.menu-toggle').click(function() {
    if ($(".filters-wrap").hasClass("someClass active")) {
      // If it's open, hide the filter by removing the classes
      $(".filters-wrap").removeClass("someClass active hidden");
    } else {
      // If it's closed, show the filter by adding the classes
      $(".filters-wrap").addClass("someClass active").removeClass("hidden");
    }
  });

  // Toggle filter for menu-toggle2
  $('.menu-toggle2').click(function() {
    if ($(".filters-wrap").hasClass("someClass active")) {
      // If it's open, hide the filter by removing the classes
      $(".filters-wrap").removeClass("someClass active hidden");
    } else {
      // If it's closed, show the filter by adding the classes
      $(".filters-wrap").addClass("someClass active").removeClass("hidden");
    }
  });

  // Close filter when clicking on menu-close
  $('.menu-close').click(function() {
    $(".filters-wrap").removeClass("someClass active hidden");
  });
});

  </script>
