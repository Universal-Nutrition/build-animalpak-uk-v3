  .checkbox-container{position:relative;height:50px;width:50px;margin-top:10px;cursor:pointer;}
  .checkbox-container input{position:absolute;top:0;left:0;height:100%;width:100%;opacity:0;z-index:9999;}
  .flex-checkbx:nth-child(1) .checkbox-container .checkbox-design{border:2px solid red;height:100%;width:100%;position:relative;margin-right:auto;border-radius:4px;}
  .flex-checkbx:nth-child(2) .checkbox-container .checkbox-design{border:2px solid #f5d500;height:100%;width:100%;position:relative;margin-right:auto;border-radius:4px;}
  .flex-checkbx:nth-child(3) .checkbox-container .checkbox-design{border:2px solid cyan;height:100%;width:100%;position:relative;margin-right:auto;border-radius:4px;}
  .flex-checkbx:nth-child(1) .checkbox-container input:checked + .checkbox-design:after{background:red;}
  .flex-checkbx:nth-child(2) .checkbox-container input:checked + .checkbox-design:after{background:yellow;}
  .flex-checkbx:nth-child(3) .checkbox-container input:checked + .checkbox-design:after{background:cyan;}
  .checkbox-container .checkbox-design:after{content:'';display:block;border-radius:50px;height:70%;width:70%;position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);background:#21212140;}
  .irs--round .irs-handle{background:#f5d500;border:none;}
  .irs--round .irs-bar{background-color:#cecece;}
  .irs--round .irs-from, .irs--round .irs-to, .irs--round .irs-single{
