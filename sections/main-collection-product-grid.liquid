  //       document.querySelector('.apparel-links-wrap').classList.remove('hidden')
  //       document.querySelector('.apparel-links-title').addEventListener('click', function() {
  //         this.classList.toggle('active')
  //         document.querySelector('.apparel-links-options').classList.toggle('active')
  //       })
