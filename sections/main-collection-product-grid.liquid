<script type="text/javascript">
(function() {
  function initMenus() {
    if (typeof jQuery === 'undefined') {
      // jQuery not loaded yet, wait and try again
      setTimeout(initMenus, 100);
      return;
    }

    jQuery(document).ready(function($){
      setTimeout(function(){
        // Check which menu has an active link and show only that one
        var $sbgMenu = $('#sbg');
        var $settingsMenu = $('#settingsmenu');

        // Count links in each menu (excluding the filter button)
        var sbgLinks = $sbgMenu.find('a:not(.menu-toggle)');
        var settingsLinks = $settingsMenu.find('a:not(.menu-toggle)');
        var sbgHasActive = sbgLinks.filter('.active').length > 0;
        var settingsHasActive = settingsLinks.filter('.active').length > 0;

        console.log('SBG has active:', sbgHasActive, 'Settings has active:', settingsHasActive);
        console.log('SBG links:', sbgLinks.length, 'Settings links:', settingsLinks.length);

        if(sbgHasActive) {
          $sbgMenu.addClass('active-menu');
        } else if(settingsHasActive) {
          $settingsMenu.addClass('active-menu');
        } else if(settingsLinks.length > 0) {
          // If neither has active but settings has links, show settings menu
          $settingsMenu.addClass('active-menu');
        } else if(sbgLinks.length > 0) {
          // If settings is empty, show sbg menu
          $sbgMenu.addClass('active-menu');
        }
      }, 100);
    });
  }

  initMenus();
})();
</script>
