  // }, 500)
  document.addEventListener('DOMContentLoaded', function () {
    // Auto-reopen sidebar if active filters are in the URL
    if (window.location.search.indexOf('filter.') !== -1) {
      collFilterOpen();
    }

    // Collapse filter groups that have active selections; expand/collapse on header click
    document.querySelectorAll('.filter-group').forEach(function (group) {
      var hasActive = parseInt(group.dataset.hasActive, 10) > 0;
      var header = group.querySelector('.filter-group-header');
      var icon = group.querySelector('.filter-toggle-icon');
      var allOptions = group.querySelectorAll('.filter-option');

      function collapse() {
        allOptions.forEach(function (opt) {
          opt.style.display = opt.classList.contains('filter-option-active') ? '' : 'none';
        });
        icon.textContent = '+';
        group.dataset.expanded = 'false';
      }

      function expand() {
        allOptions.forEach(function (opt) { opt.style.display = ''; });
        icon.textContent = '−';
        group.dataset.expanded = 'true';
      }

      if (hasActive) {
        collapse();
      } else {
        expand();
      }

      header.addEventListener('click', function () {
        if (group.dataset.expanded === 'true') {
          collapse();
        } else {
          expand();
        }
      });
    });

    var $range = $(".js-range-slider");
    if ($range.length) {
      var from, to;
      var updateValues = function () {
        var params = new URLSearchParams(window.location.search);
        var newparams = [];
        for (let param of params) {
          var k = param[0], v = param[1];
          if (k !== 'filter.v.price.gte' && k !== 'filter.v.price.lte') {
            newparams.push(encodeURIComponent(k) + '=' + encodeURIComponent(v));
          }
        }
        newparams.unshift('filter.v.price.gte=' + from);
        newparams.unshift('filter.v.price.lte=' + to);
        window.location.search = newparams.join('&');
      };
      $range.ionRangeSlider({
        onChange: function (data) { from = data.from; to = data.to; },
        onFinish: function (data) { updateValues(); }
      });
      var range = $range.data("ionRangeSlider");
      if (range) { range.update({ from: $range.data('minvalue'), to: $range.data('maxvalue') }); }
    }

    var sortSelect = document.querySelector('.sortselect');
    if (sortSelect) {
      sortSelect.addEventListener('change', function (e) {
        var params = new URLSearchParams(window.location.search);
        var newparams = [];
        for (let param of params) {
          var k = param[0], v = param[1];
          if (k !== 'sort_by') {
            newparams.push(encodeURIComponent(k) + '=' + encodeURIComponent(v));
          }
        }
        newparams.unshift('sort_by=' + e.currentTarget.value);
        window.location.search = newparams.join('&');
      });
    }
  });
</script>

