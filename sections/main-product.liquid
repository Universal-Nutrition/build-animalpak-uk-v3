<script>
    document.addEventListener('DOMContentLoaded', function () {
        function isIE() {
            const ua = window.navigator.userAgent;
            const msie = ua.indexOf('MSIE ');
            const trident = ua.indexOf('Trident/');

            return (msie > 0 || trident > 0);
        }

        if (!isIE()) return;
        const hiddenInput = document.querySelector('#{{ product_form_id }} input[name="id" data-productid="{{ product.id }}"]');
        const noScriptInputWrapper = document.createElement('div');
        const variantSwitcher = document.querySelector('variant-radios[data-section="{{ section.id }}"]') || document.querySelector('variant-selects[data-section="{{ section.id }}"]');
        noScriptInputWrapper.innerHTML = document.querySelector('.product-form__noscript-wrapper-{{ section.id }}').textContent;
        variantSwitcher.outerHTML = noScriptInputWrapper.outerHTML;

        document.querySelector('#Variants-{{ section.id }}').addEventListener('change', function (event) {
            hiddenInput.value = event.currentTarget.value;
        });
    });

    let nutrition = {}

        // product side info
        let triggers = document.querySelectorAll('.info-trigger')

    triggers.forEach(function(trigger) {
        trigger.addEventListener('click', function() {
           let htmlId = this.dataset.id,
    title = this.dataset.title,
    type = this.dataset.type,
    source = document.getElementById(htmlId),
    data = source ? source.innerHTML : 'Content not found',
    dataHtml;

          if (type === 'html' || type === 'text') {
  dataHtml = `<div class="product-info-wrap">${data}</div>`;

  setTimeout(function() {
    if (data && data.includes('data-itsgot-user') && !document.querySelector('script[src*="itsgot.com/embed.js"]')) {
      var embedScript = document.createElement('script');
      embedScript.src = '//itsgot.com/embed.js';
      embedScript.async = true;
      document.head.appendChild(embedScript);
    }
  }, 3000);
}

            if(type == 'img') {
                dataHtml =
                    `<div class="product-info-wrap">
          <img src="${data}" class="w-full" />
        </div>`
            }

            let elem = document.createElement('div')
            elem.classList.add('product-info-block')
            let html =
                `<div class="product-info-inner absolute p-16 bg-white h-full right-0 top-0">
            <span class="absolute close-info-block flex justify-center items-center">
                <svg class="pointer-events-none" width="20" height="20" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 2L2 12" stroke="white" stroke-width="1" stroke-linecap="square"/>
                <path d="M2 2L12 12" stroke="white" stroke-width="1" stroke-linecap="square"/>
                </svg>
            </span>
            <div class="product-info-title">${title}</div>
            ${dataHtml}
          </div>`

            elem.innerHTML = html
            document.querySelector('body').appendChild(elem)
            setTimeout(function() {
                document.querySelector('.product-info-inner').classList.add('active')
            })

            document.addEventListener('click', function(e) {
                if(e.target.classList.contains('close-info-block') || e.target.classList.contains('product-info-block')) {
                    document.querySelector('.product-info-inner').classList.remove('active')
                    document.querySelector('.product-info-inner').addEventListener('transitionend', function() {
                        elem.remove()
                    })
                }
            })

        })

    })

    const readmore = document.querySelector('.read-more');
    if (readmore) {
      document.querySelector('.read-more').addEventListener('click', function() {
        document.querySelectorAll('.info-trigger')[0].click();
      });
    }
</script>

