{% for image in product.images %}
  {% assign size = forloop.length %}
{% endfor %}

{% assign is_stack = false %}
{% if product.tags contains 'stack' %}
  {% assign is_stack = true %}
{% endif %}

{% liquid
  assign is_preorder = false
  assign preorder_object = product.selected_or_first_available_variant.metafields.custom.preorder

  assign today = 'now' | date: '%Y-%m-%d'
  assign preorder_date = preorder_object.value.date | date: '%Y-%m-%d'

  if preorder_object != blank and preorder_date != blank and preorder_date > today
    assign is_preorder = true
  elsif preorder_object != blank and preorder_date == blank
    assign is_preorder = true
  endif
%}

{% style %}
  {%- for one_flavor in shop.metaobjects.flavor.values -%}
    {%- if one_flavor.image != blank -%}
      .flavor-option-icon[data-flavor="{{ one_flavor.title }}"] {
        background-image: url({{ one_flavor.image | image_url: width: 60 }});
      }
    {%- endif -%}
  {%- endfor -%}
{% endstyle %}

{% # Careful here - the version of Swiper (8.x) doesn't like being in a flex container. %}
<div class="product mx-auto md:mt-8 md:mx-auto h-full">
  <div class="product-wrapper">

    <!-- Mobile breadcrumbs (above gallery) -->
    <div class="block lg:hidden pl-4 pt-2">
      {% render 'breadcrumbs' %}
    </div>

    <!-- Image gallery -->
    <div class="product-image-wrapper">
      {% if size > 1 %}
        {% render 'product-gallery' %}
      {% else %}
        {% render 'product-gallery-single' %}
      {% endif %}
    </div>

    <!-- Product info -->
    <div class="product-info-wrapper">
      <!-- Desktop breadcrumbs (in info column) -->
      <div class="hidden lg:block">
        {% render 'breadcrumbs' %}
      </div>

      <div id="ProductInfo-{{ section.id }}" class="product__info-container">
        {%- assign product_form_id = 'product-form-' | append: section.id -%}

        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'text' -%}
              <p
                class="product__text{% if block.settings.text_style == 'uppercase' %} caption-with-letter-spacing{% elsif block.settings.text_style == 'subtitle' %} subtitle{% endif %}"
                {{ block.shopify_attributes }}
              >
                {{- block.settings.text -}}
              </p>

            {%- when 'title' -%}
              <div class="md:mb-1">
                <div class="product-title-container">
                  <div>
                    {% if product.collections[0] != blank %}
                      <p class="font-anton uppercase tracking-wider mb-1" style="font-size:14px;color:#000;padding-top:40px">{{ product.collections[0].title }}</p>
                    {% endif %}
                    {% if product.metafields.custom.product_subtype != blank %}
                      <span class="text-sm font-anton uppercase tracking-wider">{{ product.metafields.custom.product_subtype }}</span>
                    {% endif %}
                    <h1
                      class="text-[42.56px] lg:text-[56.29px] leading-[34.05px] lg:leading-[45.03px] mb-3 font-bold uppercase"
                      style="color:#000"
                      {{ block.shopify_attributes }}
                    >
                      {%- if product.title != blank -%}
                        {{ product.title | escape }}
                      {%- else -%}
                        {{ 'onboarding.product_title' | t }}
                      {%- endif -%}
                    </h1>
                  </div>
                </div>

                <a href="#yotpo-reviews-main-widget" aria-label="Navigate to Yotpo reviews widget to add your review" class="min-h-[22px] mb-2 font-bebasNeue text-sm flex items-center gap-1">
                  {% render 'review-stars', product: product, rating: product.metafields.yotpo.reviews_average, max_stars: 5 %}
                  <span>{{ product.metafields.yotpo.reviews_average }} ({{ product.metafields.yotpo.reviews_count }})</span>
                </a>

                {% assign current_variant = product.selected_or_first_available_variant %}
                <div class="product-sku mt-2 lg:mt-1 font-anton uppercase text-primary" style="font-size:13px;letter-spacing:0.05em">
                  SKU: {{ current_variant.sku }}
                </div>
              </div>

              {% if product.selling_plan_groups.size == 0 %}
                {% unless is_stack %}
                  <div class="mt-2 lg:mt-2 text-[20px] font-sans font-bold leading-[25.6px] text-primary">
                    {% if product.metafields.custom.price_text_override != blank %}
                      {{ product.metafields.custom.price_text_override | metafield_tag }}
                    {%- else -%}
                      <div class="price-container"></div>
                    {%- endif -%}
                  </div>
                {% endunless %}
              {% endif %}

            {%- when 'nutrition' -%}
              {%- assign product_nutrition = product.metafields.custom.nutrition_facts_how_to_use_warnings -%}
              {%- for variant in product.variants -%}
                {%- assign variant_nutrition = variant.metafields.custom.nutrition_facts_how_to_use_warnings -%}
                {%- assign effective_nutrition = variant_nutrition | default: product_nutrition -%}
                {%- if effective_nutrition != blank -%}
                  <div id="nutrition-html-{{ variant.id }}" style="display:none;">
                    {{ effective_nutrition }}
                  </div>
                {%- endif -%}
              {%- endfor -%}
              {%- unless has_variant_nutrition -%}
                {%- if product_nutrition != blank -%}
                  <div id="nutrition-html-{{ product.selected_or_first_available_variant.id }}" style="display:none;">
                    {{ product_nutrition }}
                  </div>
                {%- endif -%}
              {%- endunless -%}
              <button class="info-trigger info-trigger-nutrition flex items-center justify-between w-full py-5 font-anton uppercase text-black border-b border-black"
                      style="font-size:18px"
                      data-title="Nutritional Info"
                      data-type="html"
                      data-id="nutrition-html-{{ product.selected_or_first_available_variant.id }}">
                <span>Nutritional Info</span>
                <span>{% render 'icon-chevron-right' %}</span>
              </button>

            {%- when 'short_description' -%}
              <div class="short-description-block text-primary mt-5 -mb-4">
                {% if product.metafields.custom.short_description != blank %}
                  <div class="mb-3">{{ product.metafields.custom.short_description }}</div>
                {% endif %}
                {% unless is_stack %}
                  {% if product.metafields.custom.short_description_extra != blank %}
                    <div class="product-short-list">{{ product.metafields.custom.short_description_extra }}</div>
                  {% endif %}
                {% endunless %}
              </div>

            {%- when 'description' -%}
              <div x-data="{ open: false }" class="border-b border-black">
                <button @click="open = !open"
                        class="flex items-center justify-between w-full py-5 font-anton uppercase text-black"
                        style="font-size:18px">
                  <span>Description</span>
                  <span :class="open ? 'rotate-180' : ''" class="transition-transform duration-200">
                    {% render 'icon-chevron-bottom' %}
                  </span>
                </button>
                <div x-show="open" x-transition class="pb-4 text-primary" style="font-family:'BebasNeue',sans-serif;font-size:16px;">
                  {% if product.description != blank %}
                    <div class="description-accordion-body">{{ product.description }}</div>
                  {% endif %}
                </div>
              </div>

            {%- when 'faqs' -%}
              <a data-scroll-href="#section-product-faq"
                 class="flex items-center justify-between w-full py-5 font-anton uppercase text-black border-b border-black cursor-pointer"
                 style="font-size:18px">
                <span>FAQs</span>
                <span>{% render 'icon-chevron-right' %}</span>
              </a>

            {%- when 'price' -%}
              <div class="mt-3">
                <div class="no-js-hidden" id="price-{{ section.id }}" role="status" {{ block.shopify_attributes }}>
                  {%- render 'price',
                    product: product,
                    use_variant: true,
                    show_badges: true,
                    price_class: 'price--large'
                  -%}
                </div>

                {%- if shop.taxes_included or shop.shipping_policy.body != blank -%}
                  <div class="product__tax caption rte">
                    {%- comment -%}Tax Included label hidden per design{%- endcomment -%}
                    {%- if shop.shipping_policy.body != blank -%}
                      {{ 'products.product.shipping_policy_html' | t: link: shop.shipping_policy.url }}
                    {%- endif -%}
                  </div>
                {%- endif -%}
              </div>

            {%- when 'variant_picker' -%}
              {%- unless product.variants.size < 1 -%}
                {%- if block.settings.picker_type == 'button' -%}
                  <variant-radios
                    class="no-js-hidden"
                    data-section="{{ section.id }}"
                    data-url="{{ product.url }}"
                    data-update-url="false"
                    {{ block.shopify_attributes }}
                  >
                    {%- for option in product.options_with_values -%}
                      <fieldset class="js product-form__input">
                        <legend class="form__label">{{ option.name }}</legend>
                        {%- for value in option.values -%}
                          <input
                            type="radio"
                            id="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}"
                            name="{{ option.name }}"
                            value="{{ value | escape }}"
                            form="{{ product_form_id }}"
                            {% if option.selected_value == value %}
                              checked
                            {% endif %}
                          >
                          <label for="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}">
                            {{ value }}
                          </label>
                        {%- endfor -%}
                      </fieldset>
                    {%- endfor -%}
                    <script type="application/json">
                      {{ product.variants | json }}
                    </script>
                  </variant-radios>
                {%- else -%}
                  {% unless product.selected_or_first_available_variant.title contains 'efault' %}
                    <variant-selects
                      class="no-js-hidden block lg:flex mt-6 space-y-3"
                      data-section="{{ section.id }}"
                      data-url="{{ product.url }}"
                      data-update-url="false"
                      {{ block.shopify_attributes }}
                    >
                      {%- for option in product.options_with_values -%}
                        {% assign options_qty = option.values | size %}
                        <div class="font-bebasNeueExpanded text-sm text-primary uppercase" style="margin-bottom:2px">{{ option.name | replace: 'Serving Size', 'Size' }}</div>
                        <div class="product-form__input product-form__input--dropdown w-full option-{{ option.name | downcase }}" style="margin-top:0;padding-top:0">
                          <div class="select">
                            {% if product.variants[0].options.size < 3 and option.name == 'Flavour' %}
                              {%- assign option_index = forloop.index0 -%}

                              <!-- Alpine custom dropdown -->
                              <div
                                x-data="flavorDropdown('{{ option.selected_value | escape }}')"
                                x-on:keydown.escape.prevent="close()"
                                @click.outside="close()"
                                class="relative w-full border border-[#DBDBDB]"
                              >
                                <!-- Hidden native select — inside Alpine root so this.$el.querySelector('select') finds it -->
                                <select
                                  id="Option-{{ section.id }}-{{ option_index }}"
                                  class="select__select Option-{{ option_index }}"
                                  style="display:none"
                                  name="options[{{ option.name | escape }}]"
                                  form="{{ product_form_id }}"
                                >
                                  {%- for value in option.values -%}
                                    <option
                                      value="{{ value | escape }}"
                                      {% if option.selected_value == value %}selected{% endif %}
                                    >{{ value }}</option>
                                  {%- endfor -%}
                                </select>
                                <!-- Trigger button -->
                                <button
                                  type="button"
                                  @click="toggle()"
                                  :aria-expanded="open"
                                  class="flavor-dropdown-trigger flex items-center justify-between w-full h-[56px] px-3 bg-white cursor-pointer"
                                >
                                  <div class="flex items-center gap-2">
                                    <span
                                      class="flavor-option-icon w-9 h-9 rounded-full bg-cover bg-center bg-no-repeat shrink-0"
                                      :data-flavor="selectedValue"
                                      data-flavor="{{ option.selected_value | escape }}"
                                    ></span>
                                    <span x-text="selectedValue" class="text-primary font-bebasNeueExpanded text-sm">{{ option.selected_value }}</span>
                                  </div>
                                  <span :class="open ? 'rotate-180' : ''" class="transition-transform duration-200 pointer-events-none">
                                    {% render 'icon-chevron-bottom' %}
                                  </span>
                                </button>

                                <!-- Dropdown panel -->
                                <div
                                  x-show="open"
                                  x-transition.origin.top.left
                                  role="listbox"
                                  class="absolute left-0 right-0 z-10 bg-white border border-[#DBDBDB] border-t-0 flex flex-col max-h-[300px] overflow-y-auto"
                                >
                                  {%- for value in option.values -%}
                                    {%- liquid
                                      assign flavor_image = blank
                                      for one_flavor in shop.metaobjects.flavor.values
                                        if one_flavor.title == value
                                          assign flavor_image = one_flavor.image
                                        endif
                                      endfor
                                    -%}
                                    <div
                                      role="option"
                                      @click="select('{{ value | escape }}')"
                                      :aria-selected="selectedValue === '{{ value | escape }}'"
                                      :class="selectedValue === '{{ value | escape }}' ? 'bg-[#f5f5f5]' : 'hover:bg-[#f5f5f5]'"
                                      class="flex items-center gap-2.5 px-3 py-2 cursor-pointer relative min-h-[52px]"
                                    >
                                      {% if flavor_image != blank %}
                                        {{ flavor_image | image_url: width: 45 | image_tag: class: 'w-9 h-9 rounded-full object-cover shrink-0', width: 36, height: 36 }}
                                      {% else %}
                                        <span class="flavor-option-icon w-9 h-9 rounded-full bg-cover bg-center bg-no-repeat shrink-0" data-flavor="{{ value | escape }}"></span>
                                      {% endif %}
                                      <span class="text-primary font-bebasNeueExpanded text-sm">{{ value }}</span>
                                      <span
                                        x-show="selectedValue === '{{ value | escape }}'"
                                        class="absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 bg-black rounded-full flex items-center justify-center"
                                      >
                                        {% render 'icon-checkmark' %}
                                      </span>
                                      {% unless forloop.last %}
                                        <div class="absolute bottom-0 left-0 right-0 h-px bg-[#e3e3e3] pointer-events-none"></div>
                                      {% endunless %}
                                    </div>
                                  {%- endfor -%}
                                </div>
                              </div>

                            {% else %}
                              {%- assign option_index = forloop.index0 -%}
                              <!-- Alpine custom dropdown for non-Flavour options (e.g. Serving Size) -->
                              <div
                                x-data="sizeDropdown('{{ option.selected_value | escape }}')"
                                @click.outside="close()"
                                x-on:keydown.escape.prevent="close()"
                                class="relative w-full border border-[#DBDBDB]"
                              >
                                <!-- Hidden native select — drives variant-selects.js and onSelectChange -->
                                <select
                                  id="Option-{{ section.id }}-{{ option_index }}"
                                  class="select__select Option-{{ option_index }}"
                                  style="display:none"
                                  name="options[{{ option.name | escape }}]"
                                  form="{{ product_form_id }}"
                                >
                                  {%- for value in option.values -%}
                                    {%- assign hide_variant = false -%}
                                    {%- for variant in product.variants -%}
                                      {%- if value == variant.title -%}
                                        {%- if variant.metafields.custom.hide_variant == true -%}
                                          {%- assign hide_variant = true -%}
                                        {%- endif -%}
                                      {%- endif -%}
                                    {%- endfor -%}
                                    {%- unless hide_variant == true -%}
                                      <option value="{{ value | escape }}" {% if option.selected_value == value %}selected{% endif %}>{{ value }}</option>
                                    {%- endunless -%}
                                  {%- endfor -%}
                                </select>

                                <!-- Trigger button -->
                                <button
                                  type="button"
                                  @click="toggle()"
                                  :aria-expanded="open"
                                  class="flavor-dropdown-trigger flex items-center justify-between w-full h-[56px] px-3 bg-white cursor-pointer"
                                >
                                  <span x-text="selectedValue || '{{ option.name | escape }}'" class="text-primary font-bebasNeueExpanded text-sm"></span>
                                  <span :class="open ? 'rotate-180' : ''" class="transition-transform duration-200 pointer-events-none">
                                    {% render 'icon-chevron-bottom' %}
                                  </span>
                                </button>

                                <!-- Dropdown panel -->
                                <div
                                  x-show="open"
                                  x-transition.origin.top.left
                                  role="listbox"
                                  class="absolute left-0 right-0 z-10 bg-white border border-[#DBDBDB] border-t-0 flex flex-col max-h-[300px] overflow-y-auto"
                                >
                                  <template x-for="(opt, index) in options" :key="opt.value">
                                    <div
                                      role="option"
                                      @click="select(opt.value)"
                                      :aria-selected="selectedValue === opt.value"
                                      :class="selectedValue === opt.value ? 'bg-[#f5f5f5]' : 'hover:bg-[#f5f5f5]'"
                                      class="relative flex items-center gap-2.5 px-3 py-2 cursor-pointer min-h-[52px]"
                                    >
                                      <span x-text="opt.text" class="text-primary font-bebasNeueExpanded text-sm"></span>
                                      <span
                                        x-show="selectedValue === opt.value"
                                        class="absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 bg-black rounded-full flex items-center justify-center"
                                      >{% render 'icon-checkmark' %}</span>
                                      <div x-show="index < options.length - 1" class="absolute bottom-0 left-0 right-0 h-px bg-[#e3e3e3] pointer-events-none"></div>
                                    </div>
                                  </template>
                                </div>
                              </div>
                            {% endif %}
                          </div>
                        </div>
                      {%- endfor -%}
                      {% capture variants %}
                                                          [
                                                          {%- for variant in product.variants -%}
                                                              {
                                                              "available": {{variant.available }},
                                                              "barcode": "{{ variant.barcode }}",
                                                              "compare_at_price": {% unless variant.compare_at_price == blank %}{{ variant.compare_at_price }}{% else %}null{% endunless %},
                                                              "featured_image": {% unless variant.featured_image == blank %}"{{ variant.featured_image | img_url: 'master' }}"{% else %}null{% endunless %},
                                                              "id": {{ variant.id }},
                                                              "inventory_management": "{{ variant.inventory_management }}",
                                                              "name": "{{ variant.name }}",
                                                              "option1": {% unless variant.option1 == blank %}"{{ variant.option1 }}"{% else %}null{% endunless %},
                                                              "option2": {% unless variant.option2 == blank %}"{{ variant.option2 }}"{% else %}null{% endunless %},
                                                              "option3": {% unless variant.option3 == blank %}"{{ variant.option3 }}"{% else %}null{% endunless %},
                                                              "options": [
                                                              {% for option in variant.options -%}
                                                                  "{{ option }}"{% unless forloop.last == true%},{% endunless %}
                                                              {% endfor %}
                                                              ],
                                                              "amazon_link": "{{ variant.metafields.custom.asin }}",
                                                              "price": {{ variant.price }},
                                                              "public_title": "{{ variant.title }}",
                                                              "requires_shipping": {{ variant.requires_shipping }},
                                                              "sku": "{{ variant.sku }}",
                                                              "taxable": {{variant.taxable}},
                                                              "title": "{{variant.title}}",
                                                              "hide_variant": {% unless variant.metafields.custom.hide_variant == blank %}{{variant.metafields.custom.hide_variant}}{% else %}null{% endunless %},
                                                              "weight": {{ variant.weight }}

                                                              }{% unless forloop.last == true%},{% endunless %}
                                                          {% endfor %}
                                                          ]
                                                      {% endcapture %}
                      <script type="application/json">
                        {{ variants }}
                      </script>

                      <script defer>
                        let variant_data = {{ variants }}
                      </script>
                    </variant-selects>
                  {% endunless %}
                {%- endif -%}
              {%- endunless -%}

              <noscript class="product-form__noscript-wrapper-{{ section.id }}">
                <div class="product-form__input{% if product.has_only_default_variant %} hidden{% endif %}">
                  <label class="form__label" for="Variants-{{ section.id }}">
                    {{- 'products.product.product_variants' | t -}}
                  </label>
                  <div class="select">
                    <select
                      name="id"
                      data-productid="{{ product.id }}"
                      id="Variants-{{ section.id }}"
                      class="select__select"
                      form="{{ product_form_id }}"
                    >
                      {%- for variant in product.variants -%}
                        <option
                          {% if variant == product.selected_or_first_available_variant %}
                            selected="selected"
                          {% endif %}
                          {% if variant.available == false %}
                            disabled
                          {% endif %}
                          value="{{ variant.id }}"
                        >
                          {{ variant.title }}
                          {%- if variant.available == false %} - {{ 'products.product.sold_out' | t }}{% endif %}
                          - {{ variant.price | money | strip_html }}
                        </option>
                      {%- endfor -%}
                    </select>
                    {% render 'icon-caret' %}
                  </div>
                </div>
              </noscript>

            {% when 'blockqty' %}
              {{- '' -}}

            {% when 'listIconText' %}
              {% # Typically contains HTML with a class of "icon-text" %}
              <div class="pt-5 max-w-lg">{{ product.metafields.custom.custom_icon_text }}</div>

            {%- when 'buy_buttons' -%}
              {% unless is_stack %}
                {% if product.metafields.custom.hide_add_to_cart_button.value == true %}
                  <div class="product-form__buttons form w-full">
                    <div class="product-form__wrap w-full">
                      <button
                        type="submit"
                        name="add"
                        class="product-form__submit button w-full"
                        style="justify-content:center; align-items: center; margin-top:15px;"
                        disabled
                      >
                        {{ 'products.product.sold_out' | t }}
                      </button>
                    </div>
                  </div>
                {% else %}
                  {% if product.metafields.custom.remove_add_to_cart_button.value != true %}
                    <div class="lg:my-4 flex atc-stick flex-col " {{ block.shopify_attributes }}>
                      {%- if product != blank -%}
                        <product-form class="product-form flex w-full">
                          <div class="product-form__error-message-wrapper mb-3" role="alert" hidden>
                            <svg
                              aria-hidden="true"
                              focusable="false"
                              role="presentation"
                              class="icon icon-error w-6 h-6"
                              viewBox="0 0 13 13"
                            >
                              <circle cx="6.5" cy="6.50049" r="5.5" stroke="white" stroke-width="2" />
                              <circle cx="6.5" cy="6.5" r="5.5" fill="#EB001B" stroke="#EB001B" stroke-width="0.7" />
                              <path
                                      d="M5.87413 3.52832L5.97439 7.57216H7.02713L7.12739 3.52832H5.87413ZM6.50076 9.66091C6.88091 9.66091 7.18169 9.37267 7.18169 9.00504C7.18169 8.63742 6.88091 8.34917 6.50076 8.34917C6.12061 8.34917 5.81982 8.63742 5.81982 9.00504C5.81982 9.37267 6.12061 9.66091 6.50076 9.66091Z"
                                      fill="white" />
                              <path
                                      d="M5.87413 3.17832H5.51535L5.52424 3.537L5.6245 7.58083L5.63296 7.92216H5.97439H7.02713H7.36856L7.37702 7.58083L7.47728 3.537L7.48617 3.17832H7.12739H5.87413ZM6.50076 10.0109C7.06121 10.0109 7.5317 9.57872 7.5317 9.00504C7.5317 8.43137 7.06121 7.99918 6.50076 7.99918C5.94031 7.99918 5.46982 8.43137 5.46982 9.00504C5.46982 9.57872 5.94031 10.0109 6.50076 10.0109Z"
                                      fill="white" stroke="#EB001B" stroke-width="0.7">
                            </svg>
                            <span class="product-form__error-message text-error font-bold mb-3"></span>
                          </div>

                          {%- form 'product',
                            product,
                            data-productid: product.id,
                            id: product_form_id,
                            class: 'form w-full',
                            novalidate: 'novalidate',
                            data-type: 'add-to-cart-form'
                          -%}
                            <input
                              type="hidden"
                              name="id"
                              data-productid="{{ product.id }}"
                              value="{{ product.selected_or_first_available_variant.id }}"
                            >

                            <div class="product-form__buttons uk-replace w-full flex flex-col gap-3 text-[13.9px]">
                              <div class="product-form__wrap">
                                {% if is_preorder and preorder_object != blank %}
                                  {% render 'preorder-message', message: preorder_object.value.message %}
                                {% endif %}

                                {% if product.variants[0].metafields.custom.asin or product.metafields.custom.asin %}
                                  <a
                                    style="display: none"
                                    id="amazon_link"
                                    target="_blank"
                                    href="{{ settings.asin }}{% if product.variants[0].metafields.custom.asin %}{{ product.variants[0].metafields.custom.asin }}{% elsif product.metafields.custom.asin %}{{ product.metafields.custom.asin }}{% endif %}"
                                  >
                                    {{- settings.asin -}}
                                    {%- if product.variants[0].metafields.custom.asin -%}
                                      {{- product.variants[0].metafields.custom.asin -}}
                                    {%- elsif product.metafields.custom.asin -%}
                                      {{- product.metafields.custom.asin -}}
                                    {%- endif -%}
                                  </a>

                                  <button
                                    type="button"
                                    onclick="document.getElementById('amazon_link').click()"
                                    class="givler product-form__submit border border-solid border-yellow hover:bg-white hover:border-[#DBDBDB] bg-yellow uppercase w-full text-center py-[18px] transition duration-150 text-primary text-[13.9px] font-sans font-bold leading-[18.07px] tracking-[1px] rounded-md"
                                    style="padding:0"
                                  >
                                    <img src="https://cdn.shopify.com/s/files/1/0674/6164/4518/files/Amazon-Buy-Button.png">
                                  </button>
                                  <style>
                                    .product-section .product-form__buttons button {
                                      background: #000;
                                    }
                                  </style>
                                {% else %}
                                  <div class="grid gap-3 items-stretch w-full" style="grid-template-columns: 1fr 3fr">
                                    <quantity-input class="quantity border border-[#DBDBDB] w-full h-full">
                                      <button class="quantity__button no-js-hidden" name="minus" type="button">
                                        <span class="visually-hidden">
                                          {{- 'products.product.quantity.decrease' | t: product: product.title | escape -}}
                                        </span>
                                        {% render 'icon-minus' %}
                                      </button>
                                      <label for="Quantity-{{ section.id }}" class="sr-only">Qty</label>
                                      <input
                                        class="quantity__input p-0"
                                        type="number"
                                        name="quantity"
                                        id="Quantity-{{ section.id }}"
                                        min="1"
                                        value="1"
                                      >
                                      <button class="quantity__button no-js-hidden" name="plus" type="button">
                                        <span class="visually-hidden">
                                          {{- 'products.product.quantity.increase' | t: product: product.title | escape -}}
                                        </span>
                                        {% render 'icon-plus' %}
                                      </button>
                                    </quantity-input>
                                    <button
                                      type="submit"
                                      name="add"
                                      ss-track-cart-add="{{ product.variants[0].sku }}"
                                      class="product-form__submit border border-solid border-black bg-black uppercase w-full text-center py-[18px] transition duration-150 text-white text-[13.9px] font-anton tracking-[1px]"
                                      {% if product.selected_or_first_available_variant.available == false %}
                                        disabled
                                      {% endif %}
                                      {% if product.variants.size > 1 and is_preorder == false %}
                                        disabled
                                      {% endif %}
                                    >
                                      <span>
                                        {%- if is_preorder -%}
                                          PREORDER
                                        {%- elsif product.selected_or_first_available_variant.available -%}
                                          {% if product.variants.size > 1 -%}
                                            make selection
                                          {%- else -%}
                                            {{- 'products.product.add_to_cart' | t -}}
                                          {%- endif %}
                                        {%- else -%}
                                          {{ 'products.product.sold_out' | t }}
                                        {%- endif -%}
                                      </span>
                                    </button>
                                  </div>
                                {% endif %}

                                <p class="line-item-property__field hidden">
                                  <input
                                    id="enable-discount"
                                    type="text"
                                    value="true"
                                    name="properties[_enableDiscount]"
                                  >
                                </p>

                                {% if section.settings.gift_enabled %}
                                  <p class="line-item-property__field hidden">
                                    <label for="gift-id">Gift id</label>
                                    <input
                                      id="gift-id"
                                      type="text"
                                      value="{{ section.settings.gift_product.variants[0].id }}"
                                      name="properties[_Gift id]"
                                    >
                                  </p>
                                {% elsif product.metafields.custom.gift_with_purchase %}
                                  <p class="line-item-property__field hidden">
                                    <label for="gift-id">Gift id</label>
                                    <input
                                      id="gift-id"
                                      type="text"
                                      value="{{ product.metafields.custom.gift_product_variant_id | remove: 'gid://shopify/ProductVariant/' }}"
                                      name="properties[_Gift id]"
                                    >
                                  </p>
                                {% endif %}
                              </div>
                            </div>
                          {%- endform -%}
                        </product-form>
                      {%- else -%}
                        <div class="product-form">
                          <div class="product-form__buttons form">
                            <button
                              type="submit"
                              name="add"
                              class="product-form__submit button button--full-width button--primary"
                              disabled
                            >
                              {{ 'products.product.sold_out' | t }}
                            </button>
                          </div>
                        </div>
                      {%- endif -%}
                    </div>
                  {%- endif -%}
                {%- endif -%}
              {% endunless %}

            {%- when 'custom_liquid' -%}
              {{ block.settings.custom_liquid }}

            {%- when 'rating' -%}
              {%- if product.metafields.reviews.rating.value != blank -%}
                {% liquid
                  assign rating_decimal = 0
                  assign decimal = product.metafields.reviews.rating.value.rating | modulo: 1
                  if decimal >= 0.3 and decimal <= 0.7
                    assign rating_decimal = 0.5
                  elsif decimal > 0.7
                    assign rating_decimal = 1
                  endif
                %}
                <div
                  class="rating"
                  role="img"
                  aria-label="{{ 'accessibility.star_reviews_info' | t: rating_value: product.metafields.reviews.rating.value, rating_max: product.metafields.reviews.rating.value.scale_max }}"
                >
                  <span
                    aria-hidden="true"
                    class="rating-star color-icon-{{ settings.accent_icons }}"
                    style="--rating: {{ product.metafields.reviews.rating.value.rating | floor }}; --rating-max: {{ product.metafields.reviews.rating.value.scale_max }}; --rating-decimal: {{ rating_decimal }};"
                  ></span>
                </div>
                <p class="rating-text caption">
                  <span aria-hidden="true">
                    {{- product.metafields.reviews.rating.value }} /
                    {{ product.metafields.reviews.rating.value.scale_max -}}
                  </span>
                </p>
                <p class="rating-count caption">
                  <span aria-hidden="true">({{ product.metafields.reviews.rating_count }})</span>
                  <span class="visually-hidden">
                    {{- product.metafields.reviews.rating_count }}
                    {{ 'accessibility.total_reviews' | t -}}
                  </span>
                </p>
              {%- endif -%}

           {% when 'customTabs' %}
  <div class="block-custom-tabs py-6 md:py-0 flex space-x-4 mt-6 flex-wrap">
              {% if product.metafields.custom.shipping_returns != blank %}
                <span
                  class="info-trigger p-0 tracking-[1px] flex justify-between items-center font-bold capitalize lg:underline cursor-pointer text-[13.9px] leading-[22.24px] font-sans text-primary border-0 border-b border-solid border-black/[.2] lg:border-0"
                  data-info="{{product.metafields.custom.shipping_returns.value.content | escape }}"
                  data-title="shipping & returns"
                  data-type="text"
                  >shipping & returns <span class="lg:hidden">{% render 'icon-chevron-right' %}</span></span
                >
              {% endif %}

{% for block in section.blocks %}
                {% if block.type == 'tab' %}
                  {% if block.settings.tab_title != blank %}
                    {% for collection in product.collections %}
                      {% if collection.handle == block.settings.collection.handle %}
                        {% assign content = block.settings.content %}
                        {% if block.settings.page != blank %}
                          {% assign content = block.settings.page.content %}
                        {% endif %}
                        <span
                          class="info-trigger p-0 tracking-[1px] flex justify-between items-center font-bold py-[27px] lg:py-[unset] w-[unset] capitalize lg:underline cursor-pointer text-[13.9px] leading-[22.24px] font-sans text-primary border-0 border-b border-solid border-black/[.2] lg:border-0"
                          data-info="{{content | escape }}"
                          data-title="{{block.settings.tab_title}}"
                          data-type="text"
                        >
                          {{- block.settings.tab_title }}
                          <span class="lg:hidden">{% render 'icon-chevron-right' %}</span></span
                        >
                      {% endif %}
                    {% endfor %}
                  {% endif %}
                {% endif %}
              {% endfor %}
            </div>

          {%- when '@app' -%}
            {% render block %}
          {%- endcase -%}
        {%- endfor -%}
      </div>
    </div><!-- End product-info-wrapper -->

  </div><!-- End product-wrapper -->
</div><!-- End product -->


