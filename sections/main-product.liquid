<script>
  document.addEventListener('DOMContentLoaded', function () {
    function createVariant(optionElem, optionsName) {
      // Note that styling is done in custom CSS below (rather than Tailwind).
      const variantContainer = document.createElement('div');
      variantContainer.classList.add('variant-container');

      if (optionsName === 'options[Flavour]') {
        const variantImageContainer = document.createElement('span');
        variantImageContainer.classList.add('variant-image');
        variantImageContainer.style.background = optionElem.dataset.color || '#ccc';

        if (optionElem.dataset.image) {
          const variantImg = document.createElement('img');
          variantImg.src = optionElem.dataset.image;
          variantImageContainer.appendChild(variantImg);
        }

        const variantText = document.createElement('div');
        variantText.classList.add('select-value');
        variantText.innerHTML = optionElem.innerHTML;

        variantContainer.appendChild(variantImageContainer);
        variantContainer.appendChild(variantText);
      } else {
        variantContainer.textContent = optionElem.innerHTML;
      }

      return variantContainer;
    }

    function setupCustomDropdown() {
      const customSelect = document.querySelector('.custom-select select');
      if (!customSelect) {
        console.error('No custom select found on the page!');
        return;
      }

      const parentWrapper = customSelect.closest('.custom-select');
      const options = customSelect.options;
      const numOptions = options.length;

      let variantsContainer = document.createElement('div');
      variantsContainer.classList.add('select-items');

      for (let i = 0; i < numOptions; i++) {
        const optionElem = options[i];
        const variantContainer = createVariant(optionElem, customSelect.name);

        if (i === 0) {
          variantContainer.classList.add('select-selected', 'select-hide');
        } else if (i === 1) {
          variantContainer.classList.add('same-as-selected');
        }

        variantContainer.addEventListener('click', function () {
          // Update the native select
          customSelect.selectedIndex = i;

          // Trigger change event so VariantSelects class knows about it
          const changeEvent = new Event('change', { bubbles: true });
          customSelect.dispatchEvent(changeEvent);

          // Update visual display
          updateDisplay(parentWrapper.querySelector('.select-selected'), optionElem);
          clearPreviousSelection(variantsContainer);
          updateAmazonLink(optionElem);
          this.classList.add('same-as-selected');
        });

        variantsContainer.appendChild(variantContainer);
      }

      parentWrapper.appendChild(variantsContainer);
    }

    function updateDisplay(displayElement, selectedOption) {
      displayElement.innerHTML = '';

      const variantIndicator = document.createElement('span');
      variantIndicator.style.cssText = 'display:inline-block; border-radius:50%; height:20px; width:20px;';
      variantIndicator.style.background = selectedOption.dataset.color || '#ccc';

      displayElement.appendChild(variantIndicator);
      displayElement.appendChild(document.createTextNode(` ${selectedOption.innerText}`));
    }

    function clearPreviousSelection(parentElement) {
      parentElement
        .querySelectorAll('.same-as-selected')
        .forEach((element) => element.classList.remove('same-as-selected'));
    }

    function updateAmazonLink(selectedOption) {
      if (!window.variant_data) return;

      const matchingVariant = variant_data.find(
        (variant) => variant.title.trim().replace('amp;', '') === selectedOption.innerText.trim().replace('amp;', '')
      );

      if (matchingVariant && matchingVariant.amazon_link) {
        const amazonLink = document.querySelector('#amazon_link');
        if (amazonLink) {
          amazonLink.setAttribute('href', `{{ settings.asin }}${matchingVariant.amazon_link}`);
          amazonLink.innerText = `{{ settings.asin }}${matchingVariant.amazon_link}`;
        }
      }
    }

    function handleStickyButton() {
      const button = document.querySelector('.product-form__buttons');
      if (!button || window.innerWidth >= 1024) return;

      window.addEventListener('scroll', function () {
        document
          .querySelector('.product-form__wrap')
          .classList.toggle('is-sticky_', button.getBoundingClientRect().top < 0);
      });
    }

    function updateSubscriptionPrice() {
      const interval = setInterval(() => {
        let onetimeRadio = document.querySelector('.onetime-radio');
        if (!onetimeRadio) return;

        clearInterval(interval);
        let label = onetimeRadio.querySelector('.rc-radio__label');
        if (!label) return;

        let priceParts = label.innerText.split('$');
        if (priceParts.length < 2) return;

        label.innerHTML = `${priceParts[0]} <span>$${priceParts[1]}</span>`;

        let subsPrice = document.querySelector('.subscription-radio .rc-radio__price');
        if (subsPrice) {
          subsPrice.innerHTML = `<span class="original-price">$${priceParts[1]}</span>` + subsPrice.innerText;
        }
      }, 500);
    }

    setupCustomDropdown();
    handleStickyButton();
    updateSubscriptionPrice();
  });
</script>

