<!-- script to re render eacht variant output Nutrition Facts in the popup again -->
<script>
  document.addEventListener('DOMContentLoaded', function () {
    const variantSelect = document.querySelector('form[action^="/cart/add"] [name="id"]');
    const nutritionTrigger = document.querySelector('.info-trigger-nutrition');

    function getCurrentVariantId() {
      return variantSelect?.value || '';
    }

    function injectIframeForVariant(variantId) {
      const source = document.getElementById(`nutrition-html-${variantId}`);
      const target = document.querySelector('.product-info-wrap');

      if (source && target) {
        target.innerHTML = source.innerHTML;

        const iframe = target.querySelector('iframe');
        if (iframe) {
          const src = iframe.getAttribute('src');
          iframe.setAttribute('src', src);
          iframe.style.minHeight = '600px';
          iframe.style.height = '600px';
          iframe.style.display = 'block';

          iframe.addEventListener('load', function () {
            setTimeout(() => {
              try {
                if (window.iFrameResize) window.iFrameResize({}, this);
              } catch (e) {
                console.warn('⚠️ iframeResize error:', e);
              }
            }, 150);
          });
        }
      }
    }

    function handleNutritionPopupOpen() {
      const variantId = getCurrentVariantId();
      setTimeout(() => {
        const popup = document.querySelector('.product-info-wrap');
        if (popup && popup.offsetParent !== null) {
          setTimeout(() => injectIframeForVariant(variantId), 300);
        }
      }, 100);
    }

    if (nutritionTrigger) {
      nutritionTrigger.addEventListener('click', handleNutritionPopupOpen);
    }

    if (variantSelect && nutritionTrigger) {
      variantSelect.addEventListener('change', function () {
        nutritionTrigger.setAttribute('data-id', `nutrition-html-${this.value}`);
      });
      nutritionTrigger.setAttribute('data-id', `nutrition-html-${variantSelect.value}`);
    }
  });
</script>
