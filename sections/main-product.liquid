<script>
  // Alpine factory for the flavour custom dropdown.
  // Defined at window scope so Alpine can reference it before DOMContentLoaded.
  window.flavorDropdown = function (initialValue) {
    return {
      open: false,
      selectedValue: initialValue,
      toggle() { this.open = !this.open; },
      close() { this.open = false; },
      select(value) {
        this.selectedValue = value;
        this.open = false;
        // Sync the hidden native select so variant-selects.js picks up the change
        const select = this.$el.querySelector('select');
        for (let i = 0; i < select.options.length; i++) {
          if (select.options[i].value === value) { select.selectedIndex = i; break; }
        }
        select.dispatchEvent(new Event('change', { bubbles: true }));
        // Update Amazon link if this product uses ASIN per variant
        if (window.variant_data) {
          const match = variant_data.find(
            (v) => v.option1 && v.option1.trim().replace('amp;', '') === value.trim().replace('amp;', '')
          );
          if (match && match.amazon_link) {
            const a = document.querySelector('#amazon_link');
            if (a) a.setAttribute('href', '{{ settings.asin }}' + match.amazon_link);
          }
        }
      }
    };
  };

  // Alpine factory for non-Flavour dropdowns (e.g. Serving Size).
  // Uses MutationObserver to stay in sync when onSelectChange repopulates options.
  window.sizeDropdown = function (initialValue) {
    return {
      open: false,
      selectedValue: initialValue,
      options: [],
      init() {
        const sel = this.$el.querySelector('select');
        if (!sel) return;
        this._sync(sel);
        const self = this;
        new MutationObserver(() => self._sync(sel)).observe(sel, { childList: true });
      },
      _sync(sel) {
        this.options = Array.from(sel.options)
          .filter(o => !o.disabled)
          .map(o => ({ value: o.value, text: o.text }));
        if (this.options.length && !this.options.find(o => o.value === this.selectedValue)) {
          this.selectedValue = this.options[0].value;
        }
      },
      toggle() { this.open = !this.open; },
      close() { this.open = false; },
      select(value) {
        this.selectedValue = value;
        this.open = false;
        const sel = this.$el.querySelector('select');
        if (sel) {
          sel.value = value;
          sel.dispatchEvent(new Event('change', { bubbles: true }));
        }
      }
    };
  };

  document.addEventListener('DOMContentLoaded', function () {
    function handleStickyButton() {
      const button = document.querySelector('.product-form__buttons');
      if (!button || window.innerWidth >= 1024) return;

      window.addEventListener('scroll', function () {
        document
          .querySelector('.product-form__wrap')
          .classList.toggle('is-sticky_', button.getBoundingClientRect().top < 0);
      });
    }

    function updateSubscriptionPrice() {
      const interval = setInterval(() => {
        let onetimeRadio = document.querySelector('.onetime-radio');
        if (!onetimeRadio) return;

        clearInterval(interval);
        let label = onetimeRadio.querySelector('.rc-radio__label');
        if (!label) return;

        let priceParts = label.innerText.split('$');
        if (priceParts.length < 2) return;

        label.innerHTML = `${priceParts[0]} <span>$${priceParts[1]}</span>`;

        let subsPrice = document.querySelector('.subscription-radio .rc-radio__price');
        if (subsPrice) {
          subsPrice.innerHTML = `<span class="original-price">$${priceParts[1]}</span>` + subsPrice.innerText;
        }
      }, 500);
    }

    handleStickyButton();
    updateSubscriptionPrice();
  });
</script>

