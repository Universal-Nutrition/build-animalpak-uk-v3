{% liquid
  assign color = section.settings.bg_color
  assign sectionHeading = section.settings.heading
%}
{{ 'component-rte.css' | asset_url | stylesheet_tag }}
<div class="w-full !py-16 md:!py-32 mt-20 md:mt-28" style="background-color: {{color}};">
  <div class="container px-6 md:px-8 max-w-[728px]">

  {% if sectionHeading != blank %}
    <h2 class="text-[42.56px] md:text-[85.604px] uppercase text-left sm:text-center text-primary mb-1 sm:mb-4 font-bold leading-[0.8em]">{{ sectionHeading }}</h2>
  {% endif %}

  {% for block in section.blocks%}

    {% liquid
      assign faqTitle = block.settings.faq_title
      assign faqBody = block.settings.faq_content
    %}

    {% if faqTitle != blank %}
    <details {% unless forloop.last %}class="border-b border-[#DBDBDB]"{% endunless %}>
        <summary>
          <div>
              <p class="w-full leading-[160%] flex justify-between items-center h4 accordion__title text-base py-[18px] md:py-6 cursor-pointer font-sans font-bold tracking-normal text-primary">
                {{ faqTitle }}
                {% render 'icon-accordion' %}
              </p>
          </div>
        </summary>
        <div class="accordion__content rte text-[13.913px] md:text-base pb-6 pr-2 leading-[160%] text-primary">
          {{ faqBody }}
        </div>
    </details>
    {% endif %}

  {% endfor %}

  </div>
</div>

<style>
  details[open] > summary .icon-caret {
    transform: rotate(180deg);
  }

  .rte > p {
    margin: 0 0 20px;
    color: #212121;
  }
  
  @media only screen and (min-width: 768px){
    .rte > p {
      margin: 0 0 26px;
    }
  }
</style>

{% schema %}
{
  "name": "FAQ Section",
  "class": "shopify-section-vue",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "FAQs"
    },
    {
      "type": "color",
      "id": "bg_color",
      "default": "#FFFFFF",
      "label": "Background Color of section"
    }
  ],
  "blocks": [
    {
      "name": "FAQ",
      "type": "FAQ",
      "settings": [
        {
          "type": "text",
          "id": "faq_title",
          "label": "FAQ title",
          "default": "FAQ title"
        },
        {
          "type": "richtext",
          "id": "faq_content",
          "label": "FAQ content",
          "default": "<p>Donec ullamcorper nulla non metus auctor fringilla. Duis mollis, est non commodo luctus, nisi erat porttitor ligula, eget lacinia odio sem nec elit.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ Section",
      "category": "Section"
    }
  ]
}
{% endschema %}