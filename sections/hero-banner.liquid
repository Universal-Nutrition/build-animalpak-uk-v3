        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Mobile"
        },
        {
          "type": "image_picker",
          "id": "logo_graphic",
          "label": "Logo / Graphic (replaces text)"
        },
        {
          "type": "text",
