        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle"
        },
        {
          "type": "text",
          "id": "button_left_text",
          "label": "Left button text"
        },
        {
          "type": "url",
          "id": "button_left_link",
          "label": "Left button link"
        },
        {
          "type": "text",
          "id": "button_right_text",
          "label": "Right button text"
        },
        {
          "type": "url",
          "id": "button_right_link",
          "label": "Right button link"
        }
      ]
    }
  ]
}
{% endschema %}
