{% endstyle %}

{{ 'bundle.section-header-style-2.css' | asset_url | stylesheet_tag }}

<sticky-header class="header-s2 block group blurred transition duration-300 z-10">
    <!--
      Mobile menu

      Off-canvas menu for mobile, show/hide based on off-canvas menu state.
    -->
    <div class="relative z-40 xl:hidden h-0" role="dialog" aria-modal="true" aria-labelledby="mobile-navigation-menu">
        <!--
          Off-canvas menu backdrop, show/hide based on off-canvas menu state.

          Entering: "transition-opacity ease-linear duration-300"
            From: "opacity-0"
            To: "opacity-100"
          Leaving: "transition-opacity ease-linear duration-300"
            From: "opacity-100"
            To: "opacity-0"
        -->
        {% render 'navigation-mobile' %}
    </div>
    <!-- Top navigation -->
    <div class="w-full flex items-center justify-between" style="background-color: {{ section.settings.upper_nav_bg }}">
        <div class="block mx-8 lg:mx-15 w-full">
            <div class="flex items-center justify-between w-full">
                {% comment %} left side {% endcomment %}
                <div class="custom-orbe-wrap flex lg:justify-end lg:max-h-[28px] lg:pr-[20px]">
                    <button class="custom-orbe flex items-center lg:text-white text-[13.913px] leading-[160%] font-bebasNeueExpanded pr-4" aria-label="country selector">
                        <span class="orbe-flags-gb w-[15px] h-[15px] rounded-full bg-no-repeat bg-cover bg-center mr-2"></span>
                        <span style="color: {{ section.settings.header_text_color }};">
                UK
                </span>
                        <span class="ml-2 custom-orbe-arrow" style="color: {{ section.settings.header_text_color }};">
                  <svg xmlns="http://www.w3.org/2000/svg" width="10" height="7" viewBox="0 0 10 7" fill="none">
                    <path d="M4.71152 6.29486L0 1.58336L0.878188 0.70517L4.71152 4.5385L8.54486 0.70517L9.42304 1.58336L4.71152 6.29486Z" fill="currentColor"/>
                  </svg>
                </span>
                    </button>
                    <div id="custom__md-footer-selector-block"></div>
                </div>
                {% comment %} right side {% endcomment %}
                <div class="hidden lg:flex items-center">
                    <div class="flex items-center relative">
                        {% assign nav_links = 0 %}
                        {% for link in linklists[section.settings.upper_nav_menu].links %}
                                {% liquid
                                    assign link_icon = ''
                                    if link.title == 'Services'
                                        capture link_icon
                                            render 'icon-customer-service' with classes: 'w-4 h-4'
                                        endcapture
                                    elsif link.title == 'Orders'
                                        capture link_icon
                                            render 'icon-orders' with classes: 'w-4 h-4'
                                        endcapture
                                    elsif link.title == 'About Animal'
                                        capture link_icon
                                            render 'icon-about' with classes: 'w-4 h-4'
                                        endcapture
                                    elsif link.title == 'Blog'
                                        capture link_icon
                                            render 'icon-blog' with classes: 'w-4 h-4'
                                        endcapture
                                    elsif link.title == 'Programs'
                                        capture link_icon
                                            render 'icon-programs' with classes: 'w-4 h-4'
                                        endcapture
                                    endif
                                %}
                                <div class="service-links flex justify-center items-center relative">
                                    <a href="{{ link.url }}" class="h-10 flex gap-2.5 items-center text-white text-[13.913px] leading-[160%] font-bebasNeueExpanded pr-4 lg:pl-4">
                                        {% comment %} {% render 'icon-customer-service' with classes: 'w-4 h-4' %} {% endcomment %}
                                        {{ link_icon }}
                                        {{ link.title }}
                                        {% if link.links.size > 0 %}{% render 'icon-chevron-bottom' with classes: 'w-4 h-4' %}{% endif %}
                                    </a>
                                    {% if link.links.size > 0 %}
                                        <ul class="dropdown-menu invisible flex flex-col gap-2 absolute top-full shadow-md
                                      {% if forloop.last %} right-3 left-auto {% else %} left-3 right-auto {% endif %} rounded-lg py-5">
                                            <svg class="absolute {% if forloop.last %} right-5 {% else %} left-5 {% endif %} -top-2" xmlns="http://www.w3.org/2000/svg" width="16" height="8" viewBox="0 0 16 8" fill="none">
                                                <path d="M8 0L0 8H16L8 0Z" fill="white"/>
                                            </svg>
                                            {% for link in link.links %}
                                                <li>
                                                    <a href="{{ link.url }}" class="text-black leading-[160%] font-bebasNeueExpanded px-4 transition hover:underline w-full block">
                                                        {{ link.title }}
                                                    </a>
                                                </li>
                                            {% endfor %}
                                        </ul>
                                    {% endif %}
                                </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>
    </div>
    <header class="relative pb-2 pt-2 xl:py-0" style="background-color: {{ section.settings.header_bg }}; color: {{ section.settings.header_text_color }};">
        <nav aria-label="Top">
            <!-- Secondary navigation -->
            <main-header>
                <div class="mx-8 lg:mx-15 main-header__recharge-styles">
                    <div class="">
                        <div class="w-full mx-auto h-10.5 xl:h-16 flex items-center xl:justify-between">
                            <div class="flex items-center xl:hidden 121">
                                <!-- Mobile menu toggle, controls the 'mobileMenuOpen' state. -->
                                <button
                                        id="mobile-menu-button"
                                        js-trigger="mobile-menu-button"
                                        type="button"
                                        class=" bg-white-900 p-0 rounded-md text-black"
                                >
                                    <span class="sr-only">Open menu</span>
                                    <!-- Heroicon name: outline/menu -->
                                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="17" viewBox="0 0 22 17" fill="none">
                                        <path d="M1 1H21M1 8.38387H21M1 15.7677H21" stroke="{{ section.settings.header_text_color }}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                    </svg>
                                </button>
                                <div class="mobile-search xl:flex ml-4">
                                    {% comment %} Mobile {% endcomment %}
                                    <a href="#" class="block md:hidden trigger-search mobile-trigger-search">
                                        <span class="sr-only">Search</span>
                                        <!-- Heroicon name: outline/search -->
                                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                                            <path fill-rule="evenodd" clip-rule="evenodd" d="M10.5003 1.96903C9.14485 1.96914 7.80912 2.28837 6.60451 2.90008C5.3999 3.51179 4.36135 4.39824 3.57549 5.48548C2.78963 6.57272 2.27926 7.82921 2.08696 9.15013C1.89466 10.4711 2.026 11.8181 2.47003 13.0789C2.91406 14.3397 3.6579 15.4776 4.63949 16.3978C5.62108 17.318 6.81196 17.9938 8.11277 18.3687C9.41358 18.7436 10.7866 18.8069 12.1173 18.5531C13.448 18.2994 14.6977 17.736 15.7623 16.91L19.4143 20.5055C19.6029 20.6848 19.8555 20.7841 20.1177 20.7818C20.3799 20.7796 20.6307 20.676 20.8161 20.4935C21.0015 20.311 21.1066 20.064 21.1089 19.8059C21.1112 19.5478 21.0104 19.2991 20.8283 19.1134L17.1763 15.5179C18.1642 14.284 18.7794 12.8011 18.9514 11.239C19.1233 9.67686 18.8451 8.09865 18.1485 6.68495C17.4519 5.27126 16.3651 4.0792 15.0126 3.24519C13.66 2.41118 12.0962 1.96893 10.5003 1.96903ZM4.00025 10.3374C4.00025 8.6402 4.68507 7.0125 5.90406 5.81239C7.12305 4.61228 8.77635 3.93806 10.5003 3.93806C12.2242 3.93806 13.8775 4.61228 15.0964 5.81239C16.3154 7.0125 17.0003 8.6402 17.0003 10.3374C17.0003 12.0346 16.3154 13.6623 15.0964 14.8624C13.8775 16.0626 12.2242 16.7368 10.5003 16.7368C8.77635 16.7368 7.12305 16.0626 5.90406 14.8624C4.68507 13.6623 4.00025 12.0346 4.00025 10.3374Z" fill="currentColor"></path>
                                        </svg>
                                    </a>
                                    {% comment %} Desktop {% endcomment %}
                                    <a href="#" class="hidden md:block trigger-search">
                                        <span class="sr-only">Search</span>
                                        <!-- Heroicon name: outline/search -->
                                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                                            <path fill-rule="evenodd" clip-rule="evenodd" d="M10.5003 1.96903C9.14485 1.96914 7.80912 2.28837 6.60451 2.90008C5.3999 3.51179 4.36135 4.39824 3.57549 5.48548C2.78963 6.57272 2.27926 7.82921 2.08696 9.15013C1.89466 10.4711 2.026 11.8181 2.47003 13.0789C2.91406 14.3397 3.6579 15.4776 4.63949 16.3978C5.62108 17.318 6.81196 17.9938 8.11277 18.3687C9.41358 18.7436 10.7866 18.8069 12.1173 18.5531C13.448 18.2994 14.6977 17.736 15.7623 16.91L19.4143 20.5055C19.6029 20.6848 19.8555 20.7841 20.1177 20.7818C20.3799 20.7796 20.6307 20.676 20.8161 20.4935C21.0015 20.311 21.1066 20.064 21.1089 19.8059C21.1112 19.5478 21.0104 19.2991 20.8283 19.1134L17.1763 15.5179C18.1642 14.284 18.7794 12.8011 18.9514 11.239C19.1233 9.67686 18.8451 8.09865 18.1485 6.68495C17.4519 5.27126 16.3651 4.0792 15.0126 3.24519C13.66 2.41118 12.0962 1.96893 10.5003 1.96903ZM4.00025 10.3374C4.00025 8.6402 4.68507 7.0125 5.90406 5.81239C7.12305 4.61228 8.77635 3.93806 10.5003 3.93806C12.2242 3.93806 13.8775 4.61228 15.0964 5.81239C16.3154 7.0125 17.0003 8.6402 17.0003 10.3374C17.0003 12.0346 16.3154 13.6623 15.0964 14.8624C13.8775 16.0626 12.2242 16.7368 10.5003 16.7368C8.77635 16.7368 7.12305 16.0626 5.90406 14.8624C4.68507 13.6623 4.00025 12.0346 4.00025 10.3374Z" fill="currentColor"></path>
                                        </svg>
                                    </a>
                                </div>
                            </div>
                            <div class="header-s2__icons flex xl:hidden"></div>

                            <div class="header-s2__logo-wrap h-full flex xl:flex-0-auto relative z-[2] w-full xl:!w-fit justify-center xl:justify-start">
                                <a href="{{ routes.root_url }}" class="flex items-center">
                                    <span class="sr-only">Workflow</span>
                                    {%- if section.settings.logo_text == blank and section.settings.logo != blank -%}
                                        {%- assign logo_alt = section.settings.logo.alt | default: shop.name | escape -%}
                                        {%- assign logo_height = section.settings.logo_width | divided_by: section.settings.logo.aspect_ratio | floor -%}
                                        {{
                                            section.settings.logo
                                            | image_url: width: section.settings.width
                                            | image_tag:
                                            class: 'h-8 w-auto lg:w-[105px] lg:h-[52px] header-s2__logo',
                                            widths: '50, 100, 150, 200, 250, 300, 400, 500',
                                            height: logo_height,
                                            width: section.settings.logo_width,
                                            alt: logo_alt,
                                            loading: 'eager',
                                            fetchpriority: 'high'
                                        }}
                                    {%- elsif section.settings.logo_text != blank -%}
                                        <span class="max-h-10.5 lg:max-h-full flex lg:inline lg:h-10 max-w-logomob lg:max-w-full w-auto logo-container">
                                            {{- section.settings.logo_text -}}
                                        </span>
                                    {% endif %}
                                </a>
                            </div>

                            <div class="hidden xl:flex ml-0 w-full items-center justify-center pb-0 -xl:w-full w-auto xl:absolute xl:translate-x-2/4 xl:right-1/2">
                                <!-- /desktop view -->
                                <div class='mega-nav'>
                                    <div class='h-full flex justify-center space-x-8 gap-3 3xl:gap-5'>
                                        {% for link in linklists[section.settings.menu].links %}
                                            {% if link.links != blank %}
                                                <div class='flex mega-nav__link' data-item-index='{{ forloop.index }}'>
                                                    <div class='relative flex item-1' tabindex='-1'>
                                                        <!--
                                                          Item active: "border-indigo-600 text-indigo-600", Item inactive: "border-transparent text-gray-700 hover:text-gray-800"
                                                        -->
                                                        <button
                                                                id='meganav-heading--{{ forloop.index }}'
                                                                type='button'
                                                                class='!font-bebasNeueExpanded uppercase !text-base 3xl:!text-lg mega-nav__item py-1 px-2 gap-1 h-[62px] border-transparent text-black relative z-10 flex items-center transition-colors ease-out duration-200 border-b-1'
                                                                aria-expanded='false'
                                                                meganav_heading_index='{{forloop.index}}'
                                                                style="color: {{ section.settings.header_text_color }};"
                                                        >
                                                            {{ link.title -}}
                                                            {%- render 'icon-caret', stroke: 'currentColor', with dataAttributeVal: forloop.index, dataAttributeName: 'meganav_heading_index' %}
                                                        </button>
                                                    </div>

                                                    <!--
                                                      'Women' mega menu, show/hide based on flyout menu state.

                                                      Entering: "transition ease-out duration-200"
                                                        From: "opacity-0"
                                                        To: "opacity-100"
                                                      Leaving: "transition ease-in duration-150"
                                                        From: "opacity-100"
                                                        To: "opacity-0"
                                                    -->
                                                    {% render 'navigation-desktop', index: forloop.index, parent_link: link %}
                                                </div>

                                            {% else %}
                                                <div class="flex items-center h-[62px] !ml-0 !py-1 !px-2 nav__link">
                                                    <a
                                                            href='{{ link.url }}'
                                                            data-item-index='{{ forloop.index }}'
                                                            class='!font-bebasNeueExpanded uppercase mega-nav__item inline-flex items-center relative h-full !text-base 3xl:!text-lg'
                                                            style="color: {{ section.settings.header_text_color }};"
                                                    >
                                                        {{- link.title -}}
                                                    </a>
                                                </div>
                                            {% endif %}
                                        {% endfor %}
                                    </div>
                                </div>
