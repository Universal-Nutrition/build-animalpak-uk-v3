    position: relative;
    cursor: pointer;
    margin-bottom: 12px;
    width: 100%;
    text-align: left;
    padding-left: 0px;
    padding-right: 24px;
    border-bottom: 1px solid #e8e8e1;
    padding-bottom: 10px;
    }
    .accordion-header:after {
    content: '';
    background: url(https://cdn.shopify.com/s/files/1/0675/6882/8736/files/chev.svg);
    height: 9px;
    width: 14px;
    background-size: contain;
    display: block;
    position: absolute;
    right: 2px;
    top: 7px;
    }
    .accordion-header.active:after {
