    font-weight: normal;
    font-style: normal;
    font-display: swap;
    }

    @media (max-width: 1279px) {
      .header-s2__logo-wrap {
        position: absolute !important;
        left: 50% !important;
        transform: translateX(-50%) !important;
        width: auto !important;
        pointer-events: none;
      }
      .header-s2__logo-wrap a {
        pointer-events: auto;
