    background-image: url("data:image/svg+xml,%3Csvg width='24' height='24' viewBox='0 0 20 20' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath fill-rule='evenodd' clip-rule='evenodd' d='M9.99996 11.2929L13.1464 8.14648L13.8535 8.85359L9.99996 12.7071L6.14641 8.85359L6.85352 8.14648L9.99996 11.2929Z' fill='white'/%3E%3C/svg%3E")!important;
    }

    sticky-header #custom__md-footer-selector-block .md-footer-selector__content button.md-form__select span {
