{% if settings.ss_enable %}
  <div
    data-section-type="ss-recommendations-product"
    data-section-id="{{ section.id }}"
  >
    <script type="searchspring/personalized-recommendations" profile="{{ section.settings.profileId }}">
      seed = "{{ product.variants[0].sku }}";
    </script>
  </div>
{% endif %}

<style>
  .product-grid-item .absolute.hidden{
        height: 55%;
        top: 5%;
        
    }
    .product-grid-item .absolute.hidden img{
        object-fit: contain !important;
    }
    img.px-3{
        transition: .5s;
    }
    .product-grid-item:hover img.px-3{
        opacity: 0;
    }
</style>

{% schema %}
{
  "name": "SS Recs - Product",
  "class": "searchspring-recommendations",
  "presets": [
    {
      "category": "{{ section.settings.category }}",
      "name": "SS Recs - Product"
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "profileId",
      "label": "Searchspring Recommendations Profile ID",
      "default": "similar",
      "info": "To be used with product-related (similar and cross-sell) recommendation profile types. The profileId can be found in the Searchspring Management Console."
    }
  ]
}
{% endschema %}
