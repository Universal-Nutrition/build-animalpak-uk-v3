{% schema %}
{
  "name": "Product Image & Text",
  "class": "shopify-section-vue",
  "settings": [
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "Main Image"
    },
    {
      "type": "image_picker",
      "id": "mob_image",
      "label": "Mobile Image"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#FFFFFF"
    },
    {
      "type": "richtext",
      "id": "headline",
      "label": "Headline"
    }
  ],
  "blocks": [
    {
      "name": "Feature",
      "type": "feature",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "feature_title",
          "label": "Feature title"
        },
        {
          "type": "richtext",
          "id": "feature_text",
          "label": "Feature text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product - Image & Text section",
      "category": "Sections"
    }
  ],
  "templates": ["product"]
}
{% endschema %}
