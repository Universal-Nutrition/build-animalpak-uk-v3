<section class="relative w-full py-20" style="background-color: {{ section.settings.bg_color }};">
  {% if section.settings.bg_image != blank %}
    <div
      class="absolute inset-0 bg-left bg-no-repeat"
      style="background-image: url('{{ section.settings.bg_image | image_url: width: 550 }}');"
    ></div>
  {% endif %}

  <div class="relative flex flex-col items-center w-full max-w-4xl mx-auto p-6">
    {% for block in section.blocks %}
      {%- assign text_size = '' -%}

      {% if block.settings.size == 'large' %}
        {% assign text_size = 'text-[1.25rem] md:text-[1.875rem]' %}
      {% elsif block.settings.size == 'medium' %}
        {% assign text_size = 'text-md md:text-[1.25rem]' %}
      {% endif %}
      <div class="text-white w-full text-center text-pretty {{ text_size }}">
        {{ block.settings.content }}
      </div>
    {% endfor %}
  </div>

  {% if section.settings.bottom_tear_image != blank %}
    {% render: 'tear-image', image: section.settings.bottom_tear_image, position: 'bottom', overlap: true %}
  {% endif %}
</section>

{% schema %}
{
  "name": "Content Section",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "image_picker",
      "id": "bottom_tear_image",
      "label": "Bottom Tear Image"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#212121"
    }
  ],
  "blocks": [
    {
      "type": "content_block",
      "name": "Content Block",
      "settings": [
        {
          "type": "textarea",
          "id": "content",
          "label": "Content"
        },
        {
          "type": "select",
          "id": "size",
          "label": "Size",
          "options": [
            { "value": "medium", "label": "Medium" },
            { "value": "large", "label": "Large" }
          ],
          "default": "medium"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Content Section",
      "blocks": [{ "type": "content_block" }, { "type": "content_block" }]
    }
  ]
}
{% endschema %}
