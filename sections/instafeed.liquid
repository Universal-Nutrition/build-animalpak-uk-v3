{% style %}
  #shopify-section-{{ section.id }} {
    position: relative;
    z-index: 10;
  }
  @font-face {
    font-family: 'Hyperwave';
    src: url('{{ 'Hyperwave.woff' | asset_url }}') format('woff');
  }
{% endstyle %}

<div
  class="relative flex flex-col justify-center items-center pb-6 md:pb-12"
  style="background-color: {{ section.settings.bg_color }};"
>
  {% render 'tear-image': image: section.settings.bg_image position: 'top' overlap: true %}
  <div class="absolute w-full z-10" style="bottom: -36px; transform: scaleY(-1) scaleX(-1);">
    {{ section.settings.bg_image | image_url: height: 36 | image_tag: class: 'w-full h-[36px]' }}
  </div>

  {% if settings.social_instagram_link != blank %}
      <a target="_blank" href="{{settings.social_instagram_link}}" aria-label="instagram" class="block w-full">
  {% endif %}
  <div class="flex gap-10 pt-6 md:pt-10 justify-center w-full">
    <div class="leading-tight text-center w-full md:w-auto">
      <div class="text-[2rem] md:text-[2.5rem] text-white font-anton">{{ section.settings.title }}</div>
      <div class="text-[100px] md:text-[80px] -mt-5 -mb-10 text-goalYellow font-hyperwave">{{ section.settings.subtitle }}</div>
    </div>
    <div class="hidden md:block md:border-r-4 md:border-r-white"></div>
    <div class="hidden md:flex flex-col justify-center items-center">
      {{ section.settings.icon | image_url: width: 80 | image_tag: width: 80, height: 80 }}
    </div>
  </div>

  {% if settings.social_instagram_link != blank %}
      </a>
  {% endif %}

  {% # Insert the Instafeed manually (as opposed to using an app block). %}
  
</div>
<div id="insta-feed"></div>


{% schema %}
{
  "name": "Instagram Feed",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Follow us on Instagram"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "#BEANIMAL"
    },
    {
      "type": "image_picker",
      "id": "icon",
      "label": "Icon"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background image"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color"
    }
  ]
}
{% endschema %}
