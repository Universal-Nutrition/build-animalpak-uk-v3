{% assign section_id = section.id | replace: '-', '_' | replace: '--', '_' | replace: '__', '_' %}

<section id="shop-by-goal" class='bg-black relative'>
  <div class='w-full absolute z-10' style='transform: scale(-1); top: -1px;'>
    {{ section.settings.top_divider_image | image_url: width: 1920, height: 68 | image_tag: class: 'w-full', loading: 'lazy' }}
  </div>

  {% # Desktop version — 4 full-width columns %}
  <div class='hidden lg:flex flex-row h-[550px]'>
    {% for block in section.blocks %}
      <a href="{{ block.settings.link }}" class='relative flex-1 overflow-hidden'>
        <div class='absolute inset-0'>
          {{ block.settings.image | image_url: width: 894, height: 1386 | image_tag: class: 'object-cover h-full w-full', loading: 'lazy' }}
        </div>

        {% # Left gradient on first image %}
        {% if forloop.index0 == 0 %}
          <div class='h-full w-full absolute inset-0 [background:linear-gradient(to_right,rgba(0,0,0,1)_0%,rgba(0,0,0,0)_20%)]'></div>
        {% endif %}

        {% # Dark overlay for text legibility %}
        <div class='h-full w-full absolute inset-0 bg-black/30'></div>

        <div class='absolute inset-0 flex justify-center items-center'>
          <div class='text-center px-6 lg:px-4 2xl:px-6'>
            <div class='font-anton text-white text-[30px] leading-tight'>{{ block.settings.headline_top }}</div>
            <div class='font-anton text-yellow text-[30px] leading-tight'>{{ block.settings.headline_bottom }}</div>
          </div>
        </div>
      </a>
    {% endfor %}
  </div>

  {% # Mobile version — carousel %}
  <div
    class='flex relative lg:hidden h-[550px] w-full'
    x-data='shopByGoalCarousel_{{ section_id }}()'
  >
    <div
      class='min-w-full flex h-full overflow-y-hidden smooth-scroll overflow-x-scroll snap-x snap-mandatory no-scrollbar'
      x-ref='carousel'
      @scroll.debounce='updateActiveIndex'
    >
      {% for block in section.blocks %}
        <a href="{{ block.settings.link }}" class='relative inline-block shrink-0 w-full snap-center overflow-hidden'>
          <div class='absolute inset-0'>
            {{
              block.settings.image
              | image_url: width: 894, height: 1386
              | image_tag: class: 'object-cover w-full h-full', loading: 'lazy'
            }}
          </div>

          <div class='h-full w-full absolute inset-0 bg-black/30'></div>

          <div class='absolute inset-0 flex justify-center items-center'>
            <div class='text-center px-14'>
              <div class='font-anton text-white text-[30px] leading-tight'>{{ block.settings.headline_top }}</div>
              <div class='font-anton text-yellow text-[30px] leading-tight'>{{ block.settings.headline_bottom }}</div>
            </div>
          </div>
        </a>
      {% endfor %}
    </div>

    {% # Carousel controls %}
    <div class='absolute w-full flex justify-center -bottom-4 z-30 gap-3'>
      {% for block in section.blocks %}
        <div class='cursor-pointer' @click='scrollToactiveIndex({{ forloop.index0 }})'>
          <svg x-show='activeIndex === {{ forloop.index0 }}' width='12' height='12' viewBox='0 0 12 12' fill='none' xmlns='http://www.w3.org/2000/svg'>
            <circle cx="6" cy="6" r="6" fill="black"/>
            <circle cx="6" cy="6" r="4" fill="white"/>
          </svg>
          <svg x-show='activeIndex !== {{ forloop.index0 }}' width='12' height='12' viewBox='0 0 12 12' fill='none' xmlns='http://www.w3.org/2000/svg'>
            <circle cx="6" cy="6" r="6" fill="black"/>
          </svg>
        </div>
      {% endfor %}
    </div>

    <div class='w-full bottom-0 absolute z-10'>
      {{ section.settings.bottom_divider_image | image_url: width: 1920, height: 68 | image_tag: class: 'w-full', loading: 'lazy' }}
    </div>
  </div>

  <div class='w-full hidden lg:block bottom-0 absolute z-10'>
    {{ section.settings.bottom_divider_image | image_url: width: 1920, height: 68 | image_tag: class: 'w-full', loading: 'lazy' }}
  </div>
</section>

<script>
  function shopByGoalCarousel_{{ section_id }}() {
    return {
      activeIndex: 0,

      updateActiveIndex() {
        const carousel = this.$refs.carousel;
        if (!carousel) return;
        const scrollLeft = carousel.scrollLeft;
        const activeIndexWidth = carousel.children[0].offsetWidth + 16;
        this.activeIndex = Math.round(scrollLeft / activeIndexWidth);
      },

      scrollToactiveIndex(index) {
        const carousel = this.$refs.carousel;
        if (!carousel) return;
        const activeIndexWidth = carousel.children[0].offsetWidth + 16;
        carousel.scrollTo({ left: index * activeIndexWidth, behavior: "smooth" });
        this.activeIndex = index;
      }
    };
  }
</script>

{% schema %}
{
  "name": "Shop By Goal",
  "settings": [
    {
      "type": "image_picker",
      "id": "top_divider_image",
      "label": "Top Divider Image"
    },
    {
      "type": "image_picker",
      "id": "bottom_divider_image",
      "label": "Bottom Divider Image"
    }
  ],
  "blocks": [
    {
      "name": "Goal",
      "type": "goal",
      "limit": 4,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background Image"
        },
        {
          "type": "text",
          "id": "headline_top",
          "label": "Top Headline (white)"
        },
        {
          "type": "text",
          "id": "headline_bottom",
          "label": "Bottom Headline (yellow)"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop by Goal",
      "settings": {
        "top_divider_image": "shopify://shop_images/yellow-to-transparent-tear.png"
      },
      "blocks": [
        {
          "type": "goal",
          "settings": {
            "headline_top": "MAINTAIN MY",
            "headline_bottom": "HEALTH & ENERGY"
          }
        },
        {
          "type": "goal",
          "settings": {
            "headline_top": "INCREASE MY",
            "headline_bottom": "PERFORMANCE"
          }
        },
        {
          "type": "goal",
          "settings": {
            "headline_top": "MANAGE MY",
            "headline_bottom": "WEIGHT"
          }
        },
        {
          "type": "goal",
          "settings": {
            "headline_top": "BUILD STRENGTH",
            "headline_bottom": "& MUSCLE"
          }
        }
      ]
    }
  ]
}
{% endschema %}
