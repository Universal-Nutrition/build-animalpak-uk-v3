<script src="{{ 'product-faq.js' | asset_url }}" defer="defer"></script>

{% liquid
  assign color = section.settings.bg_color
%}
{% if product.metafields.custom.faq_1_title != blank %}
<div id="section-product-faq" class="product-faq w-full">

  {%- if section.settings.tear_image != blank -%}
    {%- assign tear_mobile = section.settings.tear_image_mobile | default: section.settings.tear_image -%}
    <div class="faq-tear faq-tear--top">
      <picture>
        <source srcset="{{ tear_mobile | image_url: width: 400, format: 'webp' }} 400w, {{ tear_mobile | image_url: width: 900, format: 'webp' }} 900w" sizes="100vw" media="(max-width: 767px)" type="image/webp" />
        <source srcset="{{ section.settings.tear_image | image_url: width: 1200, format: 'webp' }} 1200w, {{ section.settings.tear_image | image_url: width: 2000, format: 'webp' }} 2000w" sizes="100vw" media="(min-width: 768px)" type="image/webp" />
        <img src="{{ section.settings.tear_image | image_url: width: 1600, format: 'webp' }}" class="block w-full" loading="lazy" alt="">
      </picture>
    </div>
  {%- endif -%}

  <div class="faq-content-bg" style="background-color: {{color}};">
  <div class="container">

    <div class="faq-heading-wrap">
      <p class="faq-line1">{{ section.settings.heading_line1 }}</p>
      <p class="faq-line2">{{ section.settings.heading_line2 }}</p>
    </div>
  <div class="accordion-wrapper" style="background: none;">
      <div class="accordion">
        {% for i in (1..12) %}
          {% assign title = 'faq_' | append: i | append: '_title' %}
          {% assign body = 'faq_' | append: i | append: '_body' %}
          {% if product.metafields.custom[title] != blank %}
            <details class="faq-item">
              <summary class="faq-summary">
                <span class="faq-summary__title">{{product.metafields.custom[title]}}</span>
                <span class="faq-icon" aria-hidden="true">
                  <span class="faq-icon__plus">+</span>
                  <span class="faq-icon__minus">−</span>
                </span>
              </summary>
              <div class="faq-body">
                {{product.metafields.custom[body]}}
              </div>
            </details>
          {% endif %}
        {% endfor %}

      </div>
  </div>
    </div>
  </div>
  </div>

  {%- if section.settings.tear_image != blank -%}
    {%- assign tear_mobile = section.settings.tear_image_mobile | default: section.settings.tear_image -%}
    <div class="faq-tear faq-tear--bottom" style="margin-top: -1px;">
      <picture>
        <source srcset="{{ tear_mobile | image_url: width: 400, format: 'webp' }} 400w, {{ tear_mobile | image_url: width: 900, format: 'webp' }} 900w" sizes="100vw" media="(max-width: 767px)" type="image/webp" />
        <source srcset="{{ section.settings.tear_image | image_url: width: 1200, format: 'webp' }} 1200w, {{ section.settings.tear_image | image_url: width: 2000, format: 'webp' }} 2000w" sizes="100vw" media="(min-width: 768px)" type="image/webp" />
        <img src="{{ section.settings.tear_image | image_url: width: 1600, format: 'webp' }}" class="block w-full" loading="lazy" alt="" style="transform: scaleX(-1) scaleY(-1);">
      </picture>
    </div>
  {%- endif -%}

</div>
{% endif %}


<style>
  @font-face {
    font-family: 'Hyperwave';
    src: url('{{ 'Hyperwave.woff' | asset_url }}') format('woff');
    font-weight: normal;
    font-style: normal;
    font-display: swap;
  }
  .faq-heading-wrap {
    padding-left: 30px;
    padding-right: 30px;
    padding-bottom: 32px;
    text-align: center;
  }
  .faq-line1 {
    font-family: Anton, sans-serif;
    font-size: 50px;
    color: #ffffff !important;
    text-transform: uppercase;
    line-height: 1;
    margin: 0;
  }
  .faq-line2 {
    font-family: 'Hyperwave', sans-serif;
    font-size: 120px;
    color: #FEDD00 !important;
    line-height: 1;
    margin: 0;
    margin-top: -16px;
  }
  #section-product-faq .container {
    padding-bottom: 85px;
    padding-top: 60px;
  }
  .faq-item {
    background: #000;
    border-bottom: 1px solid #fff;
  }
  .faq-item:first-child {
    border-top: 1px solid #fff;
  }
  .faq-summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 22px 16px;
    cursor: pointer;
    list-style: none;
  }
  .faq-summary::-webkit-details-marker { display: none; }
  .faq-summary__title {
    font-family: Anton, sans-serif;
    font-size: 20px;
    font-weight: 400;
    text-transform: uppercase;
    color: #fff !important;
  }
  .faq-icon {
    font-size: 24px;
    color: #FEDD00 !important;
    line-height: 1;
    flex-shrink: 0;
    margin-left: 12px;
    position: relative;
    top: -2px;
  }
  .faq-icon__plus,
  .faq-icon__minus {
    color: #FEDD00 !important;
  }
  .faq-icon__minus { display: none; }
  details[open] .faq-icon__plus { display: none; }
  details[open] .faq-icon__minus { display: block; }
  .faq-body {
    padding: 0 16px 28px;
    color: #fff !important;
    font-family: 'BebasNeue', sans-serif;
    font-size: 16px;
  }
  .faq-body * {
    color: #fff !important;
    font-family: 'BebasNeue', sans-serif;
    font-size: 16px;
  }
  @media only screen and (max-width: 768px) {
    #section-product-faq .container {
      padding-bottom: 40px;
      padding-top: 32px;
    }
    .faq-line1 { font-size: 42px; }
    .faq-line2 { font-size: 72px; margin-top: -10px; }
  }
</style>

{% if product.metafields.custom.faq_1_title != blank %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {% for i in (1..12) %}
      {% assign title = 'faq_' | append: i | append: '_title' %}
      {% assign body = 'faq_' | append: i | append: '_body' %}
      {% if product.metafields.custom[title] != blank  %}
        {% unless forloop.first %},{% endunless %}
        {
          "@type": "Question",
          "name": "{{product.metafields.custom[title] | replace: '"', '\"'}}",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "{{product.metafields.custom[body] | replace: '"', '\"'}}"
          }
      }
      {% endif %}
    {% endfor %}
  ]
}
</script>
{% endif %}

{% schema %}
{
  "name": "Product - FAQ Section",
  "class": "shopify-section-vue",
  "settings": [
    {
      "type": "text",
      "id": "heading_line1",
      "label": "Heading line 1",
      "default": "Frequently Asked"
    },
    {
      "type": "text",
      "id": "heading_line2",
      "label": "Heading line 2",
      "default": "Questions"
    },
    {
      "type": "color",
      "id": "bg_color",
      "default": "#000000",
      "label": "Background Colour of Section"
    },
    {
      "type": "image_picker",
      "id": "tear_image",
      "label": "Tear image (desktop)"
    },
    {
      "type": "image_picker",
      "id": "tear_image_mobile",
      "label": "Tear image (mobile)"
    }
  ],
  "presets": [
    {
      "name": "Product FAQ Section",
      "category": "Section"
    }
  ],
  "templates": ["product"]
}
{% endschema %}
