{% liquid
  assign backgroundImage = section.settings.background_image
  assign textColor = section.settings.text_color
  assign tearImage = section.settings.tear_image
%}

{% for block in section.blocks %}
{% if block.settings.highlight_text != blank %}
    {% assign is_active = true %}
{% endif %}
{% endfor %}

{% if is_active %}
<pdp-highlight-image>
  <section id="section-highlights" class="overflow-hidden relative">
    <div class="container" style="margin: 100px auto; max-width: 1024px;">
      <div class="w-full relative z-10 text-wrapper bg-transparent pb-8 md:pb-0">
          {% if section.settings.headline %}
            <h2 class="uppercase text-left" style="color: {{ textColor }};">
              {{ section.settings.headline }}
            </h2>
          {% endif %}
          <ul class="grid">
            {% for block in section.blocks %}
              {% if block.settings.highlight_image != blank or block.settings.highlight_text != blank %}
                {% assign time = forloop.index | times: 150 %}
                <li>
                  <div class="flex items-center">
                    <div id="icon">
                      {% if block.settings.highlight_image != blank %}
                        <img id="icon-image" src="{{ block.settings.highlight_image | img_url: 'master' }}" alt="{{ block.settings.highlight_image.alt | escape }}" style="display: block; margin-right: 10px;">
                      {% endif %}
                    </div>
                    <div class="description" style="color: {{ textColor }};">{{ block.settings.highlight_text }}</div>
                  </div>
                </li>
              {% endif %}
            {% endfor %}
            </ul>
      </div>
    </div>    
  </section>
{% if section.settings.tear_image != blank %}
    <div class="bg-primary">
      {{ tearImage | image_url: width: 1920 | image_tag: class: "w-full" }}
    </div>
{% endif %}
</pdp-highlight-image>
{% endif %}

{% if section.settings.background_image %}
  <style>
    #section-highlights {
      background-color: #FBDE15;
      background-image: url('{{ backgroundImage | image_url: width: 1200 }}');
      background-position: center center;
      background-size: 600px auto;
  </style>
{% endif %}

<style>
#section-highlights ul {
  margin-bottom: 0;
}
#section-highlights li img {
  max-width: 100px;
}
#section-highlights h2 {
  line-height: 1.1;
  font-size: 40px;
  margin-bottom: .5em;
}
#section-highlights .description {
  font-size: 18px;
  line-height: 1.3;
}


#section-highlights .description h3 {
  display: block;
  font-family: "Familjen Grotesk", sans-serif;
  color: inherit !important;
  font-size: 23px;
  margin-bottom: .5em;
  text-transform: Uppercase;
  font-weight: 600 !important;
  letter-spacing: 0;
}

@media only screen and (min-width: 768px) {
  #section-highlights ul {
    grid-template-columns: repeat(2, 1fr);
    gap: 40px;
  }
  #section-highlights h2 {
    font-size: 60px;
  }
}



.text-image p,
.metafield-multi_line_text_field{
  background-color: transparent;
}

@media screen and(max-width: 640px) {
  #section-hero-medium.bgImage img {

  }
}

@media screen and(max-width: 550px) {
  #section-hero-medium.bgImage img {

  }
}
</style>

<script> 
  const iconImg = document.getElementById('icon-image');
  var icons = document.querySelectorAll('#icon');
  
  if (iconImg) {
    iconImg.addEventListener('load', function() {
      icons.forEach(function(element, index) {
        element.style.width = iconImg.width + 10 + 'px';
      });
    });
  }
</script> 



{% schema %}
{
  "name": "Product Highlights",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#FFFFFF"
    },
    {
      "type": "richtext",
      "id": "headline",
      "label": "Headline"
    },
    {
      "type": "image_picker",
      "id": "tear_image",
      "label": "Tear Image"
    }
  ],
  "blocks": [
    {
      "name": "Highlight",
      "type": "highlight",
      "limit": 4,
      "settings": [
        {
          "type": "image_picker",
          "id": "highlight_image",
          "label": "Highlight Image"
        },
        {
          "type": "richtext",
          "id": "highlight_text",
          "label": "Highlight Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Highlights Section",
      "category": "Sections"
    }
  ],
  "templates": ["product"]
}
{% endschema %}
