{% liquid
  assign textColor = section.settings.text_color
  assign tear_top_desktop = section.settings.tear_top_image
  assign tear_top_mobile = section.settings.tear_top_image_mobile | default: tear_top_desktop
  assign tear_top_fallback = tear_top_desktop | default: section.settings.tear_top_image_mobile
  assign tear_bottom_desktop = section.settings.tear_bottom_image
  assign tear_bottom_mobile = section.settings.tear_bottom_image_mobile | default: tear_bottom_desktop
  assign tear_bottom_fallback = tear_bottom_desktop | default: section.settings.tear_bottom_image_mobile
%}

{% for block in section.blocks %}
{% if block.settings.highlight_text != blank %}
    {% assign is_active = true %}
{% endif %}
{% endfor %}

{% if is_active %}
<pdp-highlight-image>
  <section id="section-highlights-{{ section.id }}" class="overflow-hidden relative">

    {%- if tear_top_desktop != blank or section.settings.tear_top_image_mobile != blank -%}
      <div class="section-highlights__tear section-highlights__tear--top">
        <picture>
          {%- if tear_top_mobile != blank -%}
            <source media="(max-width: 767px)"
              srcset="{{ tear_top_mobile | image_url: width: 400, format: 'webp' }} 400w, {{ tear_top_mobile | image_url: width: 600, format: 'webp' }} 600w, {{ tear_top_mobile | image_url: width: 900, format: 'webp' }} 900w"
            />
          {%- endif -%}
          {%- if tear_top_desktop != blank -%}
            <source media="(min-width: 768px)"
              srcset="{{ tear_top_desktop | image_url: width: 1200, format: 'webp' }} 1200w, {{ tear_top_desktop | image_url: width: 1600, format: 'webp' }} 1600w, {{ tear_top_desktop | image_url: width: 2400, format: 'webp' }} 2400w"
            />
          {%- endif -%}
          <img
            src="{{ tear_top_fallback | image_url: width: 1600, format: 'webp' }}"
            alt=""
            loading="lazy"
            class="block w-full"
          />
        </picture>
      </div>
    {%- endif -%}

    <div class="container" style="margin: 100px auto; max-width: 1024px;">
      <div class="w-full relative z-10 text-wrapper bg-transparent pb-8 md:pb-0">
          {% if section.settings.headline %}
            <h2 class="uppercase text-left" style="color: {{ textColor }};">
              {{ section.settings.headline }}
            </h2>
          {% endif %}
          <ul class="grid">
            {% for block in section.blocks %}
              {% if block.settings.highlight_image != blank or block.settings.highlight_text != blank %}
                {% assign time = forloop.index | times: 150 %}
                <li>
                  <div class="flex items-center">
                    <div id="icon">
                      {% if block.settings.highlight_image != blank %}
                        <img id="icon-image" src="{{ block.settings.highlight_image | img_url: 'master' }}" alt="{{ block.settings.highlight_image.alt | escape }}" style="display: block; margin-right: 10px;">
                      {% endif %}
                    </div>
                    <div class="description" style="color: {{ textColor }};">{{ block.settings.highlight_text }}</div>
                  </div>
                </li>
              {% endif %}
            {% endfor %}
            </ul>
      </div>
    </div>

    {%- if tear_bottom_desktop != blank or section.settings.tear_bottom_image_mobile != blank -%}
      <div class="section-highlights__tear section-highlights__tear--bottom">
        <picture>
          {%- if tear_bottom_mobile != blank -%}
            <source media="(max-width: 767px)"
              srcset="{{ tear_bottom_mobile | image_url: width: 400, format: 'webp' }} 400w, {{ tear_bottom_mobile | image_url: width: 600, format: 'webp' }} 600w, {{ tear_bottom_mobile | image_url: width: 900, format: 'webp' }} 900w"
            />
          {%- endif -%}
          {%- if tear_bottom_desktop != blank -%}
            <source media="(min-width: 768px)"
              srcset="{{ tear_bottom_desktop | image_url: width: 1200, format: 'webp' }} 1200w, {{ tear_bottom_desktop | image_url: width: 1600, format: 'webp' }} 1600w, {{ tear_bottom_desktop | image_url: width: 2400, format: 'webp' }} 2400w"
            />
          {%- endif -%}
          <img
            src="{{ tear_bottom_fallback | image_url: width: 1600, format: 'webp' }}"
            alt=""
            loading="lazy"
            class="block w-full"
          />
        </picture>
      </div>
    {%- endif -%}

  </section>
</pdp-highlight-image>
{% endif %}

{% style %}
  #section-highlights-{{ section.id }} {
    background-color: #FBDE15;
    background-position: center center;
    background-size: cover;
    {% if section.settings.background_image_mobile != blank %}
      background-image: url('{{ section.settings.background_image_mobile | image_url: width: 800 }}');
    {% elsif section.settings.background_image != blank %}
      background-image: url('{{ section.settings.background_image | image_url: width: 800 }}');
    {% endif %}
  }
  @media (min-width: 768px) {
    #section-highlights-{{ section.id }} {
      {% if section.settings.background_image != blank %}
        background-image: url('{{ section.settings.background_image | image_url: width: 1600 }}');
      {% endif %}
    }
  }
{% endstyle %}

<style>
#section-highlights-{{ section.id }} ul {
  margin-bottom: 0;
}
#section-highlights-{{ section.id }} li img {
  max-width: 100px;
}
#section-highlights-{{ section.id }} h2 {
  line-height: 1.1;
  font-size: 40px;
  margin-bottom: .5em;
}
#section-highlights-{{ section.id }} .description {
  font-size: 18px;
  line-height: 1.3;
}

#section-highlights-{{ section.id }} .description h3 {
  display: block;
  font-family: "Familjen Grotesk", sans-serif;
  color: inherit !important;
  font-size: 23px;
  margin-bottom: .5em;
  text-transform: Uppercase;
  font-weight: 600 !important;
  letter-spacing: 0;
}

@media only screen and (min-width: 768px) {
  #section-highlights-{{ section.id }} ul {
    grid-template-columns: repeat(2, 1fr);
    gap: 40px;
  }
  #section-highlights-{{ section.id }} h2 {
    font-size: 60px;
  }
}

.section-highlights__tear--top {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  z-index: 10;
  pointer-events: none;
  line-height: 0;
}
.section-highlights__tear--top picture {
  display: block;
  width: 100%;
  transform: scaleY(-1);
}

.section-highlights__tear--bottom {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 10;
  pointer-events: none;
  line-height: 0;
}
.section-highlights__tear--bottom picture {
  display: block;
  width: 100%;
}

.section-highlights__tear--top img,
.section-highlights__tear--bottom img {
  display: block;
  width: 100%;
  height: auto;
}

#section-highlights-{{ section.id }} .container {
  position: relative;
  z-index: 20;
}
</style>

<script>
  const iconImg = document.getElementById('icon-image');
  var icons = document.querySelectorAll('#icon');

  if (iconImg) {
    iconImg.addEventListener('load', function() {
      icons.forEach(function(element, index) {
        element.style.width = iconImg.width + 10 + 'px';
      });
    });
  }
</script>



{% schema %}
{
  "name": "Product Highlights",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image (Desktop)"
    },
    {
      "type": "image_picker",
      "id": "background_image_mobile",
      "label": "Background Image (Mobile, optional)"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#FFFFFF"
    },
    {
      "type": "richtext",
      "id": "headline",
      "label": "Headline"
    },
    {
      "type": "image_picker",
      "id": "tear_top_image",
      "label": "Tear Image \u2013 Top (Desktop)"
    },
    {
      "type": "image_picker",
      "id": "tear_top_image_mobile",
      "label": "Tear Image \u2013 Top (Mobile, optional)"
    },
    {
      "type": "image_picker",
      "id": "tear_bottom_image",
      "label": "Tear Image \u2013 Bottom (Desktop)"
    },
    {
      "type": "image_picker",
      "id": "tear_bottom_image_mobile",
      "label": "Tear Image \u2013 Bottom (Mobile, optional)"
    }
  ],
  "blocks": [
    {
      "name": "Highlight",
      "type": "highlight",
      "limit": 4,
      "settings": [
        {
          "type": "image_picker",
          "id": "highlight_image",
          "label": "Highlight Image"
        },
        {
          "type": "richtext",
          "id": "highlight_text",
          "label": "Highlight Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Highlights Section",
      "category": "Sections"
    }
  ],
  "templates": ["product"]
}
{% endschema %}
