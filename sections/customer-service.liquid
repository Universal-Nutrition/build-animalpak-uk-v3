<div id="{{section.id}}" class="py-16 px-6 lg:pt-16 lg:pb-24 lg:px-14">
    {% if section.settings.title != blank %}
        <h1>{{section.settings.title}}</h1>
    {% endif %}
    {% if section.settings.img != blank %}
        <img src="{{section.settings.img | img_url: 'master'}}" alt="{{section.settings.img.alt}}" class="hidden lg:block w-full mt-4">
    {% endif %}
    {% if section.settings.img_mob != blank %}
        <img src="{{section.settings.img_mob | img_url: 'master'}}" alt="{{section.settings.img.alt}}" class="lg:hidden w-full mt-4">
    {% endif %}
    <div class="mt-10 grid lg:grid-cols-3 gap-4 ml-0">
        {% for block in section.blocks %}
            {% if block.type == 'btn' %}
                <a href="{{block.settings.link}}" class="btn-primary w-full flex justify-center text-center">{{block.settings.text}}</a>
            {% endif %}
        {% endfor %}
    </div>
    <div class="mt-10">
        {% for block in section.blocks %}
            {% if block.type == 'content' %}
                <h2 class="mt-10">{{ block.settings.headline }}</h2>
                <div class="mt-2">
                    {{block.settings.content | newline_to_br}}
                {% if block.settings.page != blank %}
                    <div class="mt-2">
                        {{block.settings.page.content}}
                    </div>
                {% endif %}
                </div>
   
            {% endif %}
        {% endfor %}
    </div>
</div>

<style>
    #{{section.id}} strong{
        color: #000 !important;
    }
    #{{section.id}} li{
        margin-top: 10px;
        list-style: inside;
    }
</style>

{% schema %}
    {
        "name": "customer service",
        "settings": [
            {
                "type": "text",
                "id": "title",
                "label": "Title",
                "default": "CUSTOMER SUPPORT"
            },
            {
                "type": "image_picker",
                "id": "img",
                "label": "Image"
            },
            {
                "type": "image_picker",
                "id": "img_mob",
                "label": "Image for mobile"
            }
        ],
        "blocks": [
            {
                "name": "Button",
                "type": "btn",
                "settings": [
                    {
                        "type": "text",
                        "id": "text",
                        "label": "Button label"
                    },
                    {
                        "type": "url",
                        "id": "link",
                        "label": "Button link"
                    }
                ]
            },
            {
                "name": "Content",
                "type": "content",
                "settings": [
                    {
                        "type": "text",
                        "id": "headline",
                        "label": "Headline"
                    },
                    {
                        "type": "richtext",
                        "id": "content",
                        "label": "Text"
                    },
                    {
                        "type": "page",
                        "id": "page",
                        "label": "Page content"
                    }
                ]
            }
        ]
    }
{% endschema %}