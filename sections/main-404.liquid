<!-- This example requires Tailwind CSS v2.0+ -->
<!--
  This example requires updating your template:

  ```
  <html class="h-full">
  <body class="h-full">
  ```
-->
{{ 'bundle.section-main-404.css' | asset_url | stylesheet_tag }}

<main class="w-full flex items-center justify-between py-16 px-6 lg:pt-16 lg:pb-24 lg:px-14" style="background-color: {{ section.settings.bg_color }};">
  <div class="max-w-full lg:max-w-[44.5%]">
    <h1 class="main-404__title mb-3.5 lg:mb-3">{{ section.settings.title }}</h1>
    <h5 class="main-404__copy mb-8 lg:mb-15">{{ section.settings.text }}</h5>
    <div class="main-404__links">
    {% for block in section.blocks %}

      <div class="overflow-hidden w-fit">
        <a class="relative -left-[2.3rem] text-base xsm:text-base sm:text-lg font-semibold text-white w-fit flex mb-[20px] hover:left-[1.7rem] transition-all duration-500 whitespace-nowrap uppercase"
            href="{{ block.settings.button_link }}">
            <img class="mr-4" src="{{ 'arrow-right.svg' | asset_url }}">
            <span class="text-white">{{ block.settings.button_label }}</span>
            <img class="ml-4" src="{{ 'arrow-right.svg' | asset_url }}">
        </a>
    </div>
    {% endfor %}
    </div>
  </div>
  <div class="main-404__image-wrapper max-w-[52.5%] w-full hidden lg:block">
    {{ section.settings.image | image_url: width: section.settings.image.width | image_tag: alt: section.settings.image.alt, widths: '200, 300, 400, 500, 600, 700, 800, 900, 1000', loading: 'lazy', class: 'main-404__image' }}
  </div>
</main>

{% schema %}
{
  "name": "Main 404",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#000000"
    },
    {
      "type": "text",
      "id": "title",
      "default": "Title Goes here!",
      "label": "Title"
    },
    {
      "type": "text",
      "id": "text",
      "default": "Text goes here!",
      "label": "Text"
    }
  ],
  "max_blocks": 4,
  "blocks": [
    {
      "type": "link",
      "name": "Button",
      "settings": [
        {
          "type": "text",
          "id": "button_label",
          "default": "Button label",
          "label": "Button Label"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        }
      ]
    }
  ]
}
{% endschema %}