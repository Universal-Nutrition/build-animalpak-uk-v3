<script src="{{ 'header-footer.js' | asset_url }}" defer="defer"></script>

<!-- footer -->
<footer-block class="footer block relative bg-[#1C1C1C] pt-10 lg:pt-[66px] px-6 lg:px-[56px] overflow-hidden">
  <div class="lg:flex justify-between items-start footer-top">
    <div class="footer-wrapper lg:flex footer-wrapper">
      {% if section.settings.logo != blank %}
        <img src="{{section.settings.logo | img_url: "master"}}" alt="{{section.settings.logo.alt}}">
      {% endif %}
      <div class="lg:flex mt-10 lg:mt-0 footer-menu">
        {% for link in linklists[section.settings.menu].links %}
          {% if link.links != blank %}
              <div class="{% unless forloop.last %} mb-6 {% endunless %} pb-6 lg:ml-16 border-0 {% unless forloop.last %}{% endunless %} lg:border-0">
                <h3 class="text-base footer-link-title font-bold text-white font-sans uppercase flex justify-between items-center">{{ link.title }} <span class="lg:hidden">{% include 'icon-chevron-bottom' %}</span></h3>
                <ul role="list" class="mt-6 lg:mt-4 mb-0 space-y-3 hidden lg:block">
                  {% for childlink in link.links %}
                  <li>
                    <a href="{{ childlink.url }}" class="text-base text-white transition font-light font-sans duration-500 hover:!text-gray-300 leading-[25.6px] lg:leading-[160%]"> {{ childlink.title }} </a>
                  </li>
      
                  {% endfor %}
                </ul>
              
              </div>
          {% endif %}
          {% endfor %}
      </div>
    </div>
  </div>
  <div class="footer-bottom lg:flex justify-between pb-10 lg:pb-6 lg:py-6 border-0 lg:border-t border-solid border-white/[.2]">
    <div class="footer-wrapper">
    <div class="copyright-wrapper flex flex-col-reverse lg:flex-row mb-3 lg:mb-0">
      <span class="copyright text-white">{{section.settings.copyright | newline_to_br}}</span>
      <div class="flex mb-3 lg:mb-0">
        {% for link in linklists[section.settings.menu_secondary].links %}
          <a href="{{link.url}}" class="text-[13.91px] text-white leading-[22.26px] mr-6 z-[9]">{{link.title}}</a>
        {% endfor %}
      </div>
    </div>
    {% include 'payments-icons' %}
    </div>
  </div>
</footer-block>

<style>
  .footer-link-title.active span{
    transform: rotate(180deg);
  }
</style>

{% schema %}
{
  "name": "t:sections.footer.name",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "default": "main-menu",
      "label": "Main footer menu"
    },
    {
      "type": "link_list",
      "id": "menu_secondary",
      "default": "main-menu",
      "label": "Secondary footer menu"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "richtext",
      "id": "copyright",
      "label": "Copyright text",
      "default": "<p>Copyright © 2022 Universal Nutrition. All rights reserved.</p>"
    }
    
  ]
}
{% endschema %}
