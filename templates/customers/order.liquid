{{ 'customer.css' | asset_url | stylesheet_tag }}
{{ 'bundle.section-account.css' | asset_url | stylesheet_tag }}

<div class="min-h-[278px] bg-primary text-white">
  <div class="m-auto w-full max-w-[928px] px-6 pt-16 md:pt-15 lg:pt-24">
    <div class="flex justify-between mb-10 md:mb-[65px]">
      <h2 class="text-white leading-[80%] text-[48.944px] md:text-[60px] lg:text-[85.604px] tracking-[-1px] uppercase font-bold">Welcome, {{ customer.first_name }}</h2>
      <a class="text-[13.9px] shrink-0 uppercase tracking-[1px] font-bold text-white flex items-center" href="{{ routes.account_logout_url }}">
        {{ 'customer.log_out' | t }}
        <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-arrow ml-[10px]" fill="none" viewBox="0 0 27 26">
          <path stroke="#fff" stroke-width="2" d="M1.0835 13h23.8333"/>
          <path stroke="#fff" stroke-linecap="square" stroke-width="2" d="m18.9587 7.04175 5.9583 5.95835-5.9583 5.9583"/>
        </svg>
      </a>
    </div>
    <div>
      <ul class="md:flex font-compacta !mb-0 lg:pb-[18px]">
        <li class="md:mr-10 mb-[34px] md:mb-0">
          <a href="{{ routes.account_url }}" 
              class="relative text-[37.01px] block md:inline uppercase tracking-[-1px] leading-[80%] font-bold text-yellow :after:content-[''] after:absolute after:left-0 after:bottom-[-16px] md:after:bottom-[-20px] after:w-full after:h-[1px] md:after:h-1 after:bg-[#333232] md:after:bg-yellow">
            Orders
          </a>
        </li>
        <li class="md:mr-10 mb-[34px] md:mb-0">
          <p id="rc_link_container">
            <a href="/tools/recurring/login" class="relative text-[37.01px] block md:inline uppercase tracking-[-1px] leading-[80%] font-bold text-white hover:text-yellow after:content-[''] after:absolute after:left-0 after:bottom-[-16px] md:after:bottom-[-20px] after:w-full after:h-[1px] md:after:h-1 after:bg-[#333232] md:after:bg-transparent md:hover:after:bg-yellow md:opacity-50 hover:opacity-100">Subscriptions</a>
          </p>
        </li>
        <li class="md:mr-10 mb-[34px] md:mb-0 last:m-0 last:pb-[38px] md:last:pb-0">
          <a href="{{ routes.account_addresses_url }}" class="relative text-[37.01px] block md:inline uppercase tracking-[-1px] leading-[80%] font-bold text-white hover:text-yellow after:content-[''] after:absolute after:left-0 after:bottom-[-16px] md:after:bottom-[-20px] after:w-full after:h-[1px] md:after:h-1 after:bg-[#333232] md:after:bg-transparent md:hover:after:bg-yellow md:opacity-50 hover:opacity-100">Address book</a>
        </li>
        <li class="pb-[38px] md:pb-0">
          {% section 'loop-returns' %}
        </li>
      </ul>
    </div>
  </div>
</div>
<div class="customer order  max-w-[928px] m-auto py-[44px] md:py-24 px-6">
  <svg style="display:none">
    <symbol id="icon-discount" viewBox="0 0 12 12">
      <path fill-rule="evenodd" clip-rule="evenodd" d="M7 0h3a2 2 0 012 2v3a1 1 0 01-.3.7l-6 6a1 1 0 01-1.4 0l-4-4a1 1 0 010-1.4l6-6A1 1 0 017 0zm2 2a1 1 0 102 0 1 1 0 00-2 0z" fill="currentColor">
    </symbol>
  </svg>
  <div class="mb-6 md:mb-9">
    <a href="{{ routes.account_url }}" class="inline-flex items-center tracking-[1px] font-bold text-[13.9px] uppercase leading-[130%] text-primary">
      <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-arrow rotate-180 !w-6 !mr-[13px]" fill="none" viewBox="0 0 27 26">
        <path stroke="#212121" stroke-width="2" d="M1.0835 13h23.8333"/>
        <path stroke="#212121" stroke-linecap="square" stroke-width="2" d="m18.9587 7.04175 5.9583 5.95835-5.9583 5.9583"/>
      </svg>
      <span class="text-primary">Back to orders</span>
    </a>
  </div>

  <div>
    <div>
      <div class="md:flex justify-between mb-[28px] md:mb-10">
        <div>
          <h1 class="tracking-[-1px] uppercase text-[42.56px] md:text-[56.29px] leading-[80%] font-bold text-primary mb-2">{{ 'customer.order.title' | t: name: order.name }}</h1>
          <div class="mb-[10px] md:mb-8 last:mb-0 text-[13.913px] md:text-base text-primary">Thank you for placing this order. Your order details are below.</div>
          <div class="pt-4 md:hidden mb-[28px]">
            <dl class="block lg:flex w-full">
              <div class="w-fit lg:whitespace-nowrap">
                <dt class="font-bold text-[13.9px] uppercase leading-[150%] text-primary">Date placed</dt>
                <dd class="mt-[5px] capitalize text-[13.913px] leading-[160%] text-primary md:text-right">
                  <time datetime="2021-07-06">{{ order.created_at | date: "%b %d, %Y" }}</time>
                  {%- if order.cancelled -%}
                    {%- assign cancelled_at = order.cancelled_at | time_tag: format: "date_at_time" -%}
                    <p>{{ 'customer.order.cancelled_html' | t: date: cancelled_at }}</p>
                    <p>{{ 'customer.order.cancelled_reason' | t: reason: order.cancel_reason_label }}</p>
                  {%- endif -%}
                </dd>
              </div>
            </dl>
          </div>
          {%- assign fulfillment = '' -%}
          {%- for line_item in order.line_items -%}
            {%- if line_item.fulfillment -%}
              {%- assign fulfillment = line_item.fulfillment -%}
              {%- break -%}
            {%- endif -%}
          {%- endfor -%}
          {%- if fulfillment.tracking_url != blank and fulfillment.tracking_number != blank != blank -%}
            <div>
              <div class="font-bold mb-1 text-[13.9px] uppercase leading-[150%] text-primary">Tracking number</div>
              {%- if fulfillment.tracking_url -%}
                <a href="{{ fulfillment.tracking_url }}" class="text-[#FF0000] underline leading-[160%] text-[13.9px] md:text-base">
                  {{ fulfillment.tracking_number }}
                </a>
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>
        <div class="pt-4 hidden md:block">
          <dl class="block lg:flex w-full">
            <div class="w-fit lg:whitespace-nowrap">
              <dt class="font-bold text-[13.9px] uppercase leading-[150%] text-primary">Date placed</dt>
              <dd class="mt-[5px] capitalize text-[13.913px] leading-[160%] text-primary text-right">
                <time datetime="2021-07-06">{{ order.created_at | date: "%b %d, %Y" }}</time>
                {%- if order.cancelled -%}
                  {%- assign cancelled_at = order.cancelled_at | time_tag: format: "date_at_time" -%}
                  <p>{{ 'customer.order.cancelled_html' | t: date: cancelled_at }}</p>
                  <p>{{ 'customer.order.cancelled_reason' | t: reason: order.cancel_reason_label }}</p>
                {%- endif -%}
              </dd>
            </div>
          </dl>
        </div>
      </div>

      <div class="md:flex flex-wrap border-t border-b border-solid border-[#DBDBDB] pt-[34px] md:pt-10 mx-[-8px]">
        {%- for line_item in order.line_items -%}
          {% unless line_item.properties['isStackParent'] %}
          <div class="flex md:w-1/2 px-2 pb-8 md:pb-10">
          {%- if line_item.url != blank -%}
            <a href="{{ line_item.url }}" class="block flex-shrink-0 w-full max-w-[120px] md:max-w-[160px] h-[120px] md:h-[160px] bg-[#f5f5f5] mr-4 md:mr-6">
              <img
                  srcset="{%- if line_item.image.width >= 165 -%}{{ line_item.image | img_url: '165x' }} 165w,{%- endif -%}
                    {%- if line_item.image.width >= 360 -%}{{ line_item.image | img_url: '360x' }} 360w,{%- endif -%}
                    {%- if line_item.image.width >= 533 -%}{{ line_item.image | img_url: '533x' }} 533w,{%- endif -%}
                    {%- if line_item.image.width >= 720 -%}{{ line_item.image | img_url: '720x' }} 720w,{%- endif -%}
                    {%- if line_item.image.width >= 940 -%}{{ line_item.image | img_url: '940x' }} 940w,{%- endif -%}
                    {%- if line_item.image.width >= 1066 -%}{{ line_item.image | img_url: '1066x' }} 1066w,{%- endif -%}
                    {{ line_item.image | img_url: 'master' }} {{ line_item.image.width }}w"
                  src="{{ line_item.image | img_url: '533x' }}"
                  sizes="(min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 130 | divided_by: 4 }}px, (min-width: 990px) calc((100vw - 130px) / 4), (min-width: 750px) calc((100vw - 120px) / 3), calc((100vw - 35px) / 2)"
                  alt="{{ line_item.image.alt | escape }}"
                  loading="lazy"
                  class="motion-reduce w-full h-full object-contain"
                width="{{ line_item.image.width }}"
                height="{{ line_item.image.height }}"
                >
            </a>
          {%- else -%}
            <div class="w-full max-w-[120px] md:max-w-[160px] h-[120px] md:h-[160px] bg-[#f5f5f5] mr-6">
              <img
                  srcset="{%- if line_item.image.width >= 165 -%}{{ line_item.image | img_url: '165x' }} 165w,{%- endif -%}
                    {%- if line_item.image.width >= 360 -%}{{ line_item.image | img_url: '360x' }} 360w,{%- endif -%}
                    {%- if line_item.image.width >= 533 -%}{{ line_item.image | img_url: '533x' }} 533w,{%- endif -%}
                    {%- if line_item.image.width >= 720 -%}{{ line_item.image | img_url: '720x' }} 720w,{%- endif -%}
                    {%- if line_item.image.width >= 940 -%}{{ line_item.image | img_url: '940x' }} 940w,{%- endif -%}
                    {%- if line_item.image.width >= 1066 -%}{{ line_item.image | img_url: '1066x' }} 1066w,{%- endif -%}
                    {{ line_item.image | img_url: 'master' }} {{ line_item.image.width }}w"
                  src="{{ line_item.image | img_url: '533x' }}"
                  sizes="(min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 130 | divided_by: 4 }}px, (min-width: 990px) calc((100vw - 130px) / 4), (min-width: 750px) calc((100vw - 120px) / 3), calc((100vw - 35px) / 2)"
                  alt="{{ line_item.image.alt | escape }}"
                  loading="lazy"
                  class="motion-reduce w-full h-full object-contain"
                width="{{ line_item.image.width }}"
                height="{{ line_item.image.height }}"
                >
            </div>
          {%- endif -%}
          <div class="pt-2 md:pt-[12px]">
            {% if line_item.properties['isStackProduct'] %}
              {% assign stack_item = line_item %}
              {% for line_item in order.line_items %}
                {% if stack_item.properties['bundleId'] == line_item.properties['bundleId'] and line_item.properties['isStackParent'] %}
                  <div class="text-[14px]">
                    {{line_item.title}}
                  </div>
                {% endif %}
              {% endfor %}
            {% endif %}
            {%- if line_item.url != blank -%}
              <h2 class="leading-[80%] !mb-1 md:!mb-[2px]">
                <a href="{{ line_item.url }}" class="text-[24.33px] md:text-[37.01px] tracking-[-0.5px] md:tracking-[-1px] leading-[80%] uppercase font-bold text-[#212121]">{{ line_item.title }}</a>
              </h2>
            {%- else -%}
              <h2 class="leading-[80%] !mb-1 md:!mb-[2px]">
                <p class="text-[24.33px] md:text-[37.01px] tracking-[-0.5px] md:tracking-[-1px] leading-[80%] uppercase font-bold text-[#212121]">{{ line_item.title }}</p>
              </h2>
            {%- endif -%}

            {% if line_item.variant.title != 'Default Title' %}
              <div class="">
                {% assign variantOptions = line_item.variant.title | split: ' / ' %}
                {% assign count = 0 %}
                  {% for option in line_item.options_with_values %}
                    <div class="mb-1 md:mb-2 text-[12.098px] md:text-[13.9px] text-primary leading-[160%]"><b class="font-semibold">{{ option.name }} :</b> {{variantOptions[count]}}</div>
                    {% assign count = count | plus: 1 %}
                {% endfor %}
              </div>
            {% endif %}

            <div class="flex pt-[6px] md:pt-[15px]">
              <div class="mb-1 md:mb-2 text-[12.098px] md:text-[13.9px] text-primary leading-[160%] mr-4">
                <b class="font-semibold">Quantity</b> {{ line_item.quantity }}
              </div>
              <div class="mb-1 md:mb-2 text-[12.098px] md:text-[13.9px] text-primary leading-[160%]">
                <b class="font-semibold">Price</b> {{ line_item.final_price | money }}
              </div>
            </div>
            
          </div>
        </div>
          {% endunless %}
          
          
        {%- endfor -%}
      </div>
    </div>
      <div class="md:flex flex-wrap border-b border-solid border-[#DBDBDB] py-8 md:py-10 md:mx-[-32px] order__main-info">
        <div class="md:w-1/2 md:px-8 mb-[25px] md:mb-0">
          <h3 class="font-bold text-[13.9px] uppercase leading-[150%] text-primary font-sans tracking-normal mb-[10px] md:mb-4">{{ 'customer.order.shipping_address' | t }}</h3>
          {{ order.shipping_address | format_address }}
        </div>
        <div class="md:w-1/2 md:px-8">
        <h3 class="font-bold text-[13.9px] uppercase leading-[150%] text-primary font-sans tracking-normal mb-[10px] md:mb-4">{{ 'customer.order.billing_address' | t }}</h3>
        {{ order.billing_address | format_address }}
      </div>
    </div>
    <div class="md:flex flex-wrap border-b border-solid border-[#DBDBDB] py-8 md:py-10 md:mx-[-32px] order__main-info">
      <div class="md:w-1/2 md:px-8 mb-[25px] md:mb-0">
        <div>
          <h3 class="font-bold text-[13.9px] uppercase leading-[150%] text-primary font-sans tracking-normal mb-[10px] md:mb-4">Payment method</h3>
          <div class="text-primary leading-[160%] text-[13.9px] md:text-base">{{ order.payment_details.credit_card_company }}</div>
          <div class="text-primary leading-[160%] text-[13.9px] md:text-base">•••• Ending {{ order.payment_details.credit_card_last_four_digits }}</div>
        </div>
      </div>
      <div class="md:w-1/2 md:px-8">
        <div>
          <h3 class="font-bold text-[13.9px] uppercase leading-[150%] text-primary font-sans tracking-normal mb-[10px] md:mb-4">Shipping method</h3>
          <div class="text-primary leading-[160%] text-[13.9px] md:text-base">{{ fulfillment.tracking_company }}</div>
          {%- assign shippingTitle = order.shipping_method.title | remove: 'and Subscription shipping' | strip  -%}
          {%- if shippingTitle == 'Economy' -%}
            <div class="text-primary text-[13.9px] md:text-base">5 to 8 business days</div>
          {%- elsif shippingTitle == 'Standard' -%}
            <div class="text-primary text-[13.9px] md:text-base">3 to 4 business days</div>
          {%- else -%}
            <div class="text-primary text-[13.9px] md:text-base">The delivery time is not calculated</div>
            {{shippingTitle}}
          {%- endif -%}
        </div>
      </div>
    </div>
    <div class="pt-8 md:pt-10">
      <div class="flex justify-between items-center mb-[15.5px] md:mb-[18.5px]">
        <div class="font-bold text-[13.9px] uppercase leading-[150%] text-primary font-sans tracking-normal">Subtotal</div>
        <div class="text-primary text-[13.9px] md:text-base">{{ order.line_items_subtotal_price | money }}</div>
      </div>
        {%- if order.discount_applications != blank -%}
          {%- for discount_application in order.discount_applications -%}
            <div class="flex justify-between items-center mb-[15.5px] md:mb-[18.5px]">
              <div class="font-bold text-[13.9px] uppercase leading-[150%] text-primary font-sans tracking-normal">
                <span class="mr-[10px] text-primary">Discount</span>
                <span class="text-[12.098px] font-normal text-[#5E5A59] normal-case bg-[#DBDBDB] rounded-[48px] px-2 py-1">{{- discount_application.title -}}</span></div>
              <div class="text-primary text-[13.9px] md:text-base">-{{ discount_application.total_allocated_amount | money }} (
                {%- if discount_application.value_type == "percentage" -%}
                  {{ discount_application.value | round }}%
                {%- else -%}
                  {{ discount_application.value | round }}$
                {%- endif -%}
                )</div>
            </div>
        {%- endfor -%}
      {%- endif -%}
      {%- for shipping_method in order.shipping_methods -%}
        <div class="flex justify-between items-center mb-[15.5px] md:mb-[18.5px]">
          <div class="font-bold text-[13.9px] uppercase leading-[150%] text-primary font-sans tracking-normal">Shipping</div>
          <div class="text-primary text-[13.9px] md:text-base">{{ shipping_method.price | money }}</div>
        </div>
        {%- break -%}
      {%- endfor -%}
      <div class="flex justify-between items-center">
        <div class="font-bold text-[13.9px] uppercase leading-[150%] text-primary font-sans tracking-normal">Total</div>
        <div class="text-primary text-[13.9px] md:text-base">{{ order.total_price | money }}</div>
      </div>
    </div>
  </div>
</div>
