{{ 'customer.css' | asset_url | stylesheet_tag }}

<div class="customer reset-password">
  <div class="flex justify-center account-section account-section-bg">
    <div class="w-full py-16 md:py-24 px-6 lg:px-20 xl:px-20">
      <div class="mx-auto w-full max-w-[432px]">
        <svg style="display: none">
          <symbol id="icon-error" viewBox="0 0 13 13">
            <circle cx="6.5" cy="6.50049" r="5.5" stroke="white" stroke-width="2"/>
            <circle cx="6.5" cy="6.5" r="5.5" fill="#EB001B" stroke="#EB001B" stroke-width="0.7"/>
            <path d="M5.87413 3.52832L5.97439 7.57216H7.02713L7.12739 3.52832H5.87413ZM6.50076 9.66091C6.88091 9.66091 7.18169 9.37267 7.18169 9.00504C7.18169 8.63742 6.88091 8.34917 6.50076 8.34917C6.12061 8.34917 5.81982 8.63742 5.81982 9.00504C5.81982 9.37267 6.12061 9.66091 6.50076 9.66091Z" fill="white"/>
            <path d="M5.87413 3.17832H5.51535L5.52424 3.537L5.6245 7.58083L5.63296 7.92216H5.97439H7.02713H7.36856L7.37702 7.58083L7.47728 3.537L7.48617 3.17832H7.12739H5.87413ZM6.50076 10.0109C7.06121 10.0109 7.5317 9.57872 7.5317 9.00504C7.5317 8.43137 7.06121 7.99918 6.50076 7.99918C5.94031 7.99918 5.46982 8.43137 5.46982 9.00504C5.46982 9.57872 5.94031 10.0109 6.50076 10.0109Z" fill="white" stroke="#EB001B" stroke-width="0.7">
          </symbol>
        </svg>
        <h1 class="mb-4 md:mb-[18px] text-[42.56px] md:text-[56.29px] leading-[80%] tracking-[-1px] font-bold text-primary uppercase">
          {{ 'customer.reset_password.title' | t }}
        </h1>
        <p class="text-primary mb-8">
          {{ 'customer.reset_password.subtext' | t: email: email }}
        </p>
        {%- form 'reset_customer_password' -%}
          {%- if form.errors -%}
            <h2 class="text-[#ff0000] font-bold text-sm font-sans tracking-normal" tabindex="-1" autofocus>
              {{ 'templates.contact.form.error_heading' | t }}
            </h2>
            <ul class="!mt-1"> 
              {%- for field in form.errors -%}
                <li class="text-primary text-sm">
                  {%- if field == 'form' -%}
                    {{ form.errors.messages[field] }}
                  {%- else -%}
                    <a href="#RegisterForm-{{ field }}" class="text-primary text-sm">
                      {{ form.errors.translated_fields[field] | capitalize }}
                      {{ form.errors.messages[field] }}
                    </a>
                  {%- endif -%}
                </li>
              {%- endfor -%}
            </ul>
          {%- endif -%}

          <div class="field">
            <label for="password"  class="block !text-base !font-bold !text-primary !mb-[10px] !static">
              {{ 'customer.reset_password.password' | t }} *
            </label>
            <input
              type="password"
              name="customer[password]"
              id="password"
              required
              class="appearance-none block w-full h-12 px-3 py-2 border border-primary placeholder-gray-400 focus:outline-none focus:ring-primary focus:border-primary sm:text-sm"
              autocomplete="new-password"
              {% if form.errors contains 'password' %}
                aria-invalid="true"
                aria-describedby="password-error"
              {% endif %}
              placeholder="{{ 'customer.reset_password.password' | t }}"
            >
            {%- if form.errors contains 'password' -%}
              <small id="password-error" class="form__message text-primary">
                <svg aria-hidden="true" focusable="false" role="presentation">
                  <use href="#icon-error" />
                </svg>
                {{ form.errors.translated_fields['password'] | capitalize }} {{ form.errors.messages['password'] }}
              </small>
            {%- endif -%}
          </div>

          <div class="field">
            <label for="password_confirmation" class="block !text-base !font-bold !text-primary !mb-[10px] !static">
              {{ 'customer.reset_password.password_confirm' | t }}
            </label>
            <input
              type="password"
              name="customer[password_confirmation]"
              id="password_confirmation"
              class="appearance-none block w-full h-12 px-3 py-2 border border-primary placeholder-gray-400 focus:outline-none focus:ring-primary focus:border-primary sm:text-sm"
              autocomplete="new-password"
              required
              {% if form.errors contains 'password_confirmation' %}
                aria-invalid="true"
                aria-describedby="password_confirmation-error"
              {% endif %}
              placeholder="{{ 'customer.reset_password.password_confirm' | t }}"
            >
            {%- if form.errors contains 'password_confirmation' -%}
              <small id="password_confirmation-error" class="form__message">
                <svg aria-hidden="true" focusable="false" role="presentation">
                  <use href="#icon-error" />
                </svg>
                {{ form.errors.translated_fields['password_confirmation'] | capitalize }} {{ form.errors.messages['password_confirmation'] }}
              </small>
            {%- endif -%}
          </div>

          <button class="w-full mt-8 button inline-block lg:px-8 py-[14px] h-[54px] border border-solid border-yellow hover:!border-solid hover:!border-primary">
            {{ 'customer.reset_password.submit' | t }}
          </button>
        {%- endform -%}
      </div>
    </div>
  </div>
</div>
