  {
    "name": "BFCM Cart Prices",
    "settings": [
      {
        "type": "header",
        "content": "BFCM Cart Prices"
      },
      {
        "type": "checkbox",
        "id": "bfcm_cart",
        "default": false,
        "label": "BFCM Cart Prices",
        "info": "Cart Shipping bar for BFCM prices"
      },
      {
        "type": "range",
        "id": "free_gift_price_bfcm",
        "label": "Free gift price bfcm",
        "min": 50,
        "max": 200,
        "step": 5,
        "unit": "$",
        "default": 125
      },
      {
        "type": "text",
        "id": "sub_pre_free_gift",
        "label": "Sub price less than free gift",
        "default": "Thanks for subscribing you've got free shipping! You Are {gift_price_left} away from getting Our Limited Edition Gym Bag!",
        "info": "Use {gift_price_left} to show gift price left in cart"
      },
      {
        "type": "text",
        "id": "ot_pre_free_gift",
        "label": "No Sub price less than free gift",
        "default": "Free Shipping unlocked! You are {gift_price_left} away from unlocking our FREE Limited Edition Gym Bag!",
        "info": "Use {gift_price_left} to show gift price left in cart"
      },
      {
        "type": "text",
        "id": "ot_pre_free_ship",
        "label": "No Sub price less than free shipping",
        "default": "Spend {shipping_price_left} more for free shipping",
        "info": "Use {shipping_price_left} to show free shipping price left in cart"
      },
      {
        "type": "text",
        "id": "free_shipping_free_gift",
        "label": "Free shipping Free Gift present",
        "default": "You've got free shipping and a limited edition gym bag!"
      }
    ]
  },
