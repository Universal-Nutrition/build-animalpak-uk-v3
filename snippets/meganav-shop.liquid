<div class='mega-nav__dropdown absolute top-full inset-x-0 text-sm text-gray-500 bg-white hidden mnd_marker'
  meganav_index='{{forloop.index}}'>
  <div class="tabswrap desk">
    <div class="tabs">
      <div id="tabs-content">
        <div id="tab1" class="tab-content" style="display: block">
          <div class="tab-inner">
            <div class="tab-inner-1">
              <div class="tab-inner-1-wrap">
                {% for block in section.blocks %}
                {%- case block.type -%}
                {%- when 'supplements-1' -%}
                <div class="supp-1-inner">
                  <span>{{ block.settings.header }}</span>
                  {% for link in linklists[block.settings.menu].links %}
                  <a href="{{link.url}}" class="supp-1-link {{ block.settings.menu.handl }}">{{link.title}}</a>
                  {% endfor %}
                </div>
                {% endcase %}
                {% endfor %}
              </div>
            </div>
            <div class="tab-inner-2">
              <div class="supplements-2-wrap">
                {% for block in section.blocks %}
                {%- case block.type -%}
                {%- when 'supplements-2' -%}
                <div class="supp-2-inner" style="background:url({{block.settings.image | img_url: '400x' }})">
                  <div class="supp-2-text">{{ block.settings.name }}</div>
                  <div class="supp-2-link"><a href="{{ block.settings.link }}"><img
                        src="https://cdn.shopify.com/s/files/1/0675/6882/8736/files/tabler_arrow-right.svg"></a>
                  </div>
                  {% if block.settings.accent %} <div class="accent-yellow"><img
                      src="https://cdn.shopify.com/s/files/1/0675/6882/8736/files/Asset_1_1.png">
                  </div>{% endif %}
                </div>
                {% endcase %}
                {% endfor %}
              </div>

            </div>
            <div class="tab-inner-3">
              <div class="custom_recently_viewed">
                <div class="custom_recently_viewed_container">
                  <div class="custom_recently_heading">
                    <label class="recently_heading">Recently viewed</label>
                  </div>
                  <div class="custom_recently_container">
                    {% render 'recently-viewed' %}
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div> <!-- END tabs-content -->
    </div> <!-- END tabs -->
  </div>

  <!-- begin old menu stash -->
  {% comment %}{% include 'menubackup' %}{% endcomment %}
</div>