{% comment %}
  Renders a product card

  Accepts:
  - product_card_product: {Object} Product Liquid object (optional)
  - media_size: {String} Size of the product image card. Values are "square" and "portrait". Default is "square" (optional)
  - show_secondary_image: {Boolean} Show the secondary image on hover. Default: false (optional)
  - add_image_padding: {Boolean} Enables padding on the image to space out the grid
  - show_vendor: {Boolean} Show the product vendor. Default: false
  - show_image_outline: {Boolean} Show card outline. Default: true (optional)
  - show_rating: {Boolean} Show the product rating. Default: false

  Usage:
  {% render 'product-card', show_vendor: section.settings.show_vendor %}
{% endcomment %}

{{ 'component-rating.css' | asset_url | stylesheet_tag }}

<style>
  .card-information__text {
    justify-content: flex-start !important;
  }
  .card-information__description {
    justify-content: flex-start !important;
  }
  .card-information .price {
    justify-content: flex-start !important;
  }
  .card-information .yotpo .standalone-bottomline {
    justify-content: flex-start !important;
    padding-left: 0 !important;
    margin-left: 0 !important;
  }
  .card-information .yotpo .yotpo-bottomline {
    justify-content: flex-start !important;
    padding-left: 0 !important;
    margin-left: 0 !important;
  }
  .card-information .yotpo .yotpo-bottomline .yotpo-stars {
    margin-left: 0 !important;
    padding-left: 0 !important;
  }
  .card-information .yotpo {
    display: block !important;
  }
  .card-information .yotpo.bottomLine {
    display: flex !important;
    flex-direction: column !important;
  }
  .card-information .yotpo .yotpo-bottomline {
    justify-content: flex-start !important;
    display: flex !important;
  }
  .card__inner {
    padding: 0 !important;
    margin: 0 !important;
    position: relative !important;
  }
  .card__media-spacer {
    padding: 0 !important;
    margin: 0 !important;
  }
  .card-wrapper {
    gap: 0 !important;
  }
  .card-information {
    margin: 0 !important;
  }
  .grid__item {
    padding: 0 !important;
    margin-right: 1rem !important;
    margin-bottom: 1rem !important;
  }
  .card__badge {
    top: 0.5rem !important;
    left: 1rem !important;
    position: absolute !important;
  }
  .card-information__description {
    text-align: left !important;
  }
  .card-information__wrapper .yotpo {
    margin-left: 0 !important;
    padding-left: 0 !important;
    margin-top: 0 !important;
  }
  .card-information__wrapper .yotpo.bottomLine {
    margin-left: 0 !important;
  }
  .card-information .rating {
    margin-left: 0 !important;
    padding-left: 0 !important;
  }
  .rating-text,
  .rating-count {
    margin-left: 0 !important;
    padding-left: 0 !important;
    text-align: left !important;
  }
  .card-information__wrapper > .flex {
    margin-left: 0 !important;
    padding-left: 0 !important;
  }
  .card-wrapper .rating-star {
    letter-spacing: 0 !important;
  }
  .card-information__wrapper > .flex.flex-col {
    padding-top: 0 !important;
    padding-left: 0 !important;
    margin-left: -0.25rem !important;
  }
  @media (max-width: 768px) {
    .card-information__wrapper > .flex.flex-col {
      margin-left: -0.5rem !important;
    }
    .card-information__wrapper {
      padding: 0.75rem !important;
    }
  }
</style>

{%- if product_card_product.metafields.custom.hover_image != null and show_secondary_image -%}
  <a class='card__image-wrapper card__image--fill' href='{{ product_card_product.url }}'>
    <img
      srcset='
        {%- if product_card_product.metafields.custom.hover_image.width >= 165 -%}{{ product_card_product.metafields.custom.hover_image | img_url: '165x' }} 165w,{%- endif -%}
        {%- if product_card_product.metafields.custom.hover_image.width >= 360 -%}{{ product_card_product.metafields.custom.hover_image | img_url: '360x' }} 360w,{%- endif -%}
        {%- if product_card_product.metafields.custom.hover_image.width >= 533 -%}{{ product_card_product.metafields.custom.hover_image | img_url: '533x' }} 533w,{%- endif -%}
        {%- if product_card_product.metafields.custom.hover_image.width >= 720 -%}{{ product_card_product.metafields.custom.hover_image | img_url: '720x' }} 720w,{%- endif -%}
        {%- if product_card_product.metafields.custom.hover_image.width >= 940 -%}{{ product_card_product.metafields.custom.hover_image | img_url: '940x' }} 940w,{%- endif -%}
        {%- if product_card_product.metafields.custom.hover_image.width >= 1066 -%}{{ product_card_product.metafields.custom.hover_image | img_url: '1066x' }} 1066w,{%- endif -%}
        {{ product_card_product.metafields.custom.hover_image | img_url: 'master' }} {{ product_card_product.metafields.custom.hover_image.width }}w
      '
      src='{{ product_card_product.metafields.custom.hover_image | img_url: '533x' }}'
      sizes='(min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 130 | divided_by: 4 }}px, (min-width: 990px) calc((100vw - 130px) / 4), (min-width: 750px) calc((100vw - 120px) / 3), calc((100vw - 35px) / 2)'
      alt='{{ product_card_product.metafields.custom.hover_image.alt | escape }}'
      loading='lazy'
      class='motion-reduce'
      width='{{ product_card_product.metafields.custom.hover_image.width }}'
      height='{{ product_card_product.metafields.custom.hover_image.height }}'
    >
    {%- if product_card_product.metafields.custom.subtitle != blank -%}
      <figcaption class='card__image-caption'>{{ product_card_product.metafields.custom.subtitle }}</figcaption>
    {%- endif -%}
  </a>
{%- endif -%}

<a href='{{product_card_product.url}}' class='card-wrapper'>
  <div class='card-information'>
    <div class='card-information__wrapper p-6'>
      {%- if show_vendor -%}
        <span class='visually-hidden'>{{ 'accessibility.vendor' | t }}</span>
        <div class='caption-with-letter-spacing light'>{{ product_card_product.vendor }}</div>
      {%- endif -%}

      <h3 class='card-information__tex mb-0 text-left font-anton text-[24.33px] lg:text-[37.01px] leading-[19.46px] lg:leading-[29.61px] uppercase'>
        {{ product_card_product.title | escape }}
      </h3>

      <div
        class='yotpo bottomLine pt-3'
        data-product-id='{{ product_card_product.id }}'
        style='margin-left: 0 !important; margin-top: -5px;'
      ></div>

      <div class='card-information__description text-left !mb-0'>
        {{ product_card_product.metafields.custom.subtitle | escape }}
      </div>

      {% comment %} TODO: metafield {% endcomment %}
      <span class='caption-large light'>{{ block.settings.description | escape }}</span>
      {%- if show_rating and product_card_product.metafields.reviews.rating.value != blank -%}
        {% liquid
          assign rating_decimal = 0
          assign decimal = product_card_product.metafields.reviews.rating.value.rating | modulo: 1
          if decimal >= 0.3 and decimal <= 0.7
            assign rating_decimal = 0.5
          elsif decimal > 0.7
            assign rating_decimal = 1
          endif
        %}
        <div class='flex flex-col pt-5'>
          <div
            class='rating'
            role='img'
            aria-label='{{ 'accessibility.star_reviews_info' | t: rating_value: product_card_product.metafields.reviews.rating.value, rating_max: product_card_product.metafields.reviews.rating.value.scale_max }}'
          >
            <span
              aria-hidden='true'
              class='rating-star color-icon-{{ settings.accent_icons }}'
              style='--rating: {{ product_card_product.metafields.reviews.rating.value.rating | floor }}; --rating-max: {{ product_card_product.metafields.reviews.rating.value.scale_max }}; --rating-decimal: {{ rating_decimal }};'
            ></span>
          </div>
          <p class='rating-text caption'>
            <span aria-hidden='true'>
              {{- product_card_product.metafields.reviews.rating.value }} /
              {{ product_card_product.metafields.reviews.rating.value.scale_max -}}
            </span>
          </p>
          <p class='rating-count caption'>
            <span aria-hidden='true'>({{ product_card_product.metafields.reviews.rating_count }})</span>
            <span class='visually-hidden'>
              {{- product_card_product.metafields.reviews.rating_count }}
              {{ 'accessibility.total_reviews' | t -}}
            </span>
          </p>
        </div>
      {%- endif -%}
      {% if product_card_product.metafields.custom.stack_products.value != blank %}
        {% for product in product_card_product.metafields.custom.stack_products.value %}
          {% assign price = product.selected_or_first_available_variant.price %}
          {% for variant in product.variants %}
            {% if variant.available %}
              {% if variant.price < price %}
                {% assign price = variant.price %}
              {% endif %}
            {% endif %}
          {% endfor %}
          {% assign lowest_price = lowest_price | plus: price %}
        {% endfor %}
        <div class='price text-left'>
          <div>
            <div class='price__regular'>
              <span class='visually-hidden visually-hidden--inline'>Regular price</span>
              <span class='price-item price-item--regular text-[14px] text-gray-900'>
                Starting At: {{ lowest_price | money }}
              </span>
            </div>
            <div class='price__sale hidden'>
              <span class='visually-hidden visually-hidden--inline'>Regular price</span>
              <span>
                <s class='price-item price-item--regular'> </s> </span
              ><span class='visually-hidden hidden visually-hidden--inline'>Sale price</span>
              <span class='hidden price-item price-item--sale price-item--last'>
                Starting At: {{ lowest_price | money }}
              </span>
            </div>
            <small class='hidden caption hidden'>
              <span class='visually-hidden'>Unit price</span>
              <span class='price-item price-item--last'>
                <span></span>
                <span aria-hidden='true'>/</span>
                <span class='visually-hidden'>&nbsp;per&nbsp;</span>
                <span> </span>
              </span>
            </small>
          </div>
        </div>

      {% else %}
        {% render 'price', product: product_card_product, price_class: 'text-left' %}
      {% endif %}
    </div>
  </div>

  <div
    class='card card--product !overflow-visible{% if product_card_product.featured_media == nil %} card--text-only card--soft{% endif %}{% if product_card_product.featured_media != nil and show_image_outline %} card--outline{% endif %}'
    tabindex='-1'
  >
    <div class='card__inner'>
      {%- if product_card_product.featured_media -%}
        {%- liquid
          assign featured_media_aspect_ratio = product_card_product.featured_media.aspect_ratio

          if product_card_product.featured_media.aspect_ratio == null
            assign featured_media_aspect_ratio = 1
          endif
        -%}

        <div
          {% if add_image_padding %}
            class='card__media-full-spacer'
          {% endif %}
        >
          <div
            class='media media--transparent media--{{ media_size }} '
            {% if media_size == 'adapt' and product_card_product.featured_media %}
              style='padding-bottom: {{ 1 | divided_by: featured_media_aspect_ratio | times: 100 }}%;'
            {% endif %}
          >
            <img
              srcset='
                {%- if product_card_product.featured_media.width >= 165 -%}{{ product_card_product.featured_media | img_url: '165x' }} 165w,{%- endif -%}
                {%- if product_card_product.featured_media.width >= 360 -%}{{ product_card_product.featured_media | img_url: '360x' }} 360w,{%- endif -%}
                {%- if product_card_product.featured_media.width >= 533 -%}{{ product_card_product.featured_media | img_url: '533x' }} 533w,{%- endif -%}
                {%- if product_card_product.featured_media.width >= 720 -%}{{ product_card_product.featured_media | img_url: '720x' }} 720w,{%- endif -%}
                {%- if product_card_product.featured_media.width >= 940 -%}{{ product_card_product.featured_media | img_url: '940x' }} 940w,{%- endif -%}
                {%- if product_card_product.featured_media.width >= 1066 -%}{{ product_card_product.featured_media | img_url: '1066x' }} 1066w,{%- endif -%}
                {{ product_card_product.featured_media | img_url: 'master' }} {{ product_card_product.featured_media.width }}w
              '
              src='{{ product_card_product.featured_media | img_url: '533x' }}'
              sizes='(min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 130 | divided_by: 4 }}px, (min-width: 990px) calc((100vw - 130px) / 4), (min-width: 750px) calc((100vw - 120px) / 3), calc((100vw - 35px) / 2)'
              alt='{{ product_card_product.featured_media.alt | escape }}'
              loading='lazy'
              class='motion-reduce'
              width='{{ product_card_product.featured_media.width }}'
              height='{{ product_card_product.featured_media.height }}'
            >
          </div>
        </div>
      {%- else -%}
        <div class='card__content'>
          <div class='card__text h3'>
            {{ product_card_product.title }}
          </div>
        </div>
      {%- endif -%}

      <div class='card__badge h-fit absolute !top-4 !left-4'>
        {%- assign customBadge = false -%}
        {%- assign isAwardWinning = false -%}
        {% for tag in product_card_product.tags %}
          {%- if tag contains '__label:' -%}
            {% unless tag contains '__label:Award-winning' %}
              {% assign customBadge = tag | split: 'label:' | last %}
            {% endunless %}
          {%- endif -%}

          {%- if tag contains '__label:Award-winning' -%}
            {% assign isAwardWinning = true %}
          {%- endif -%}
        {% endfor %}
        {%- if product_card_product.available == false -%}
          <span class='bg-primary !text-[#fff] text-[12.098px] leading-[160%] font-semibold px-[9px] py-[3px] h-fit mr-2'>
            {{- 'products.product.sold_out' | t -}}
          </span>
        {%- elsif product_card_product.compare_at_price > product_card_product.price
          and product_card_product.available
        -%}
          <span class='bg-primary !text-[#fff] text-[12.098px] leading-[160%] font-semibold px-[9px] py-[3px] h-fit mr-2'>
            {{- 'products.product.on_sale' | t -}}
          </span>
        {%- elsif customBadge -%}
          <span class='bg-primary !text-[#fff] text-[12.098px] leading-[160%] font-semibold px-[9px] py-[3px] h-fit mr-2'>
            {{- customBadge -}}
          </span>
        {%- elsif isAwardWinning -%}
          <span class='bg-transparent text-[12.098px] leading-[160%] font-semibold px-[9px] py-[3px] h-fit mr-2'
            >Award winning</span
          >
        {%- endif -%}
      </div>
      
    </div>
  </div>
</a>
 