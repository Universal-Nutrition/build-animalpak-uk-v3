                        {% else %}
                            <a href="{{ blogs.fitness-bodybuilding.url }}/tagged/{{ tag | handle }}" class="article-item__article-tag font-semibold bg-primary text-white py-[2px] text-[12.1px] px-2 capitalize mr-2 mb-2">{{ tag | replace: '_', ' '}}</a>
                        {% endif %}
                    {% endif %}
                {% endunless %}
             {% endfor %}
        </div> -->
    </div>
</div>