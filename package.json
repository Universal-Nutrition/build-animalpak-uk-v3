{
  "name": "Animal",
  "version": "1.1.0",
  "description": "Animal theme",
  "main": "index.js",
  "keywords": [],
  "author": "Mara",
  "license": "MIT",
  "scripts": {
    "start": "run-p -sr shopify:serve webpack:watch",
    "deploy": "run-s webpack:build && shopify theme push --nodelete",
    "deploy:new": "run-s webpack:build && shopify theme push --unpublished --nodelete",
    "webpack:watch": "cross-env NODE_ENV=development BROWSERSLIST_ENV=development BROWSERSLIST_CONFIG=.browserslistrc webpack --config webpack.config.js --watch --progress",
    "webpack:build": "cross-env NODE_ENV=production BROWSERSLIST_ENV=production BROWSERSLIST_CONFIG=.browserslistrc webpack --config webpack.config.js --progress",
    "shopify:serve": "shopify theme dev --store=animalpak-uk.myshopify.com",
    "shopify:login": "shopify logout && shopify login --store animalpak-uk.myshopify.com",
    "shopify:pull": "shopify theme pull --nodelete",
    "lint": "run-s -c lint:*",
    "lint:shopify": "shopify theme check",
    "fix": "run-s -c fix:*",
    "fix:shopify": "shopify theme check -a"
  },
  "dependencies": {
    "@babel/core": "^7.23.2",
    "@babel/plugin-transform-runtime": "^7.23.2",
    "@babel/preset-env": "^7.23.2",
    "@shopify/cli": "^3.74.1",
    "@shopify/theme": "^3.50.0",
    "@tailwindcss/line-clamp": "^0.4.4",
    "@tailwindcss/typography": "^0.5.10",
    "@vue/compiler-sfc": "^3.3.4",
    "autoprefixer": "^10.4.16",
    "babel-loader": "^9.1.3",
    "clean-webpack-plugin": "^4.0.0",
    "cross-env": "^7.0.3",
    "css-loader": "^6.8.1",
    "css-minimizer-webpack-plugin": "^5.0.1",
    "dynamic-countdown": "^1.4.2",
    "eslint": "^8.51.0",
    "eslint-plugin-vue": "^9.17.0",
    "eslint-webpack-plugin": "^4.0.1",
    "mini-css-extract-plugin": "^2.7.6",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.31",
    "postcss-import": "^15.1.0",
    "postcss-loader": "^7.3.3",
    "sass": "^1.69.4",
    "sass-loader": "^13.3.2",
    "stylelint": "^15.11.0",
    "stylelint-config-recommended": "^13.0.0",
    "stylelint-webpack-plugin": "^4.1.1",
    "url-loader": "^4.1.1",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "webpack-merge": "^5.10.0"
  },
  "devDependencies": {
    "@shopify/prettier-plugin-liquid": "^1.8.2",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.6",
    "cssnano": "^6.0.1",  
    "jquery": "^3.7.1",
    "prettier": "^3.5.2",
    "swiper": "^8.4.4",
    "tailwindcss": "^3.3.3",
    "vanilla-lazyload": "^17.8.5",
    "webpack-remove-empty-scripts": "^1.0.4",
    "youtube-player": "^5.6.0"
  },
  "packageManager": "yarn@1.22.19+sha1.4ba7fc5c6e704fce2066ecbfb0b0d8976fe62447"
}
